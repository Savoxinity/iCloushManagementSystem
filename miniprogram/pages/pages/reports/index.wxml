<!-- 数据报表页面 -->
<view class="page-container">
  <!-- 维度切换 -->
  <view class="dim-bar">
    <view class="dim-item {{activeDim === 'day' ? 'active' : ''}}" bindtap="switchDim" data-dim="day"><text>今日</text></view>
    <view class="dim-item {{activeDim === 'week' ? 'active' : ''}}" bindtap="switchDim" data-dim="week"><text>本周</text></view>
    <view class="dim-item {{activeDim === 'month' ? 'active' : ''}}" bindtap="switchDim" data-dim="month"><text>本月</text></view>
  </view>

  <!-- 核心指标卡片 -->
  <view class="kpi-grid">
    <view wx:for="{{kpiCards}}" wx:key="id" class="kpi-card">
      <text class="kpi-icon">{{item.icon}}</text>
      <text class="kpi-value" style="color:{{item.color}}">{{item.value}}</text>
      <text class="kpi-label">{{item.label}}</text>
      <view class="kpi-trend {{item.trend > 0 ? 'up' : item.trend < 0 ? 'down' : 'flat'}}">
        <text>{{item.trend > 0 ? '↑' : item.trend < 0 ? '↓' : '—'}} {{item.trendText}}</text>
      </view>
    </view>
  </view>

  <!-- 工区产量排行 -->
  <view class="section">
    <text class="section-title">工区产量排行</text>
    <view wx:for="{{zoneRanking}}" wx:key="zone_id" class="rank-item">
      <view class="rank-num {{index < 3 ? 'top' : ''}}"><text>{{index + 1}}</text></view>
      <view class="rank-info">
        <text class="rank-name">{{item.zone_name}}</text>
        <view class="rank-bar-bg">
          <view class="rank-bar-fill" style="width:{{item.percent}}%;background:{{item.color}};"></view>
        </view>
      </view>
      <text class="rank-value">{{item.count}} 件</text>
    </view>
  </view>

  <!-- 员工绩效榜 -->
  <view class="section">
    <text class="section-title">员工绩效榜 Top 5</text>
    <view wx:for="{{staffRanking}}" wx:key="staff_id" class="staff-rank-item">
      <view class="staff-avatar-wrap">
        <view class="staff-avatar" style="background:{{item.avatarColor}}">
          <text class="staff-initial">{{item.initial}}</text>
        </view>
        <view wx:if="{{index < 3}}" class="medal">{{index === 0 ? '🥇' : index === 1 ? '🥈' : '🥉'}}</view>
      </view>
      <view class="staff-info">
        <text class="staff-name">{{item.name}}</text>
        <text class="staff-zone">{{item.zone_name}}</text>
      </view>
      <view class="staff-stats">
        <text class="staff-tasks">{{item.done_count}} 任务</text>
        <text class="staff-points">+{{item.points_earned}} 积分</text>
      </view>
    </view>
  </view>

  <!-- 任务完成率 -->
  <view class="section">
    <text class="section-title">任务完成率</text>
    <view class="completion-ring-wrap">
      <view class="completion-ring">
        <text class="completion-pct">{{completionRate}}%</text>
        <text class="completion-label">完成率</text>
      </view>
      <view class="completion-legend">
        <view class="legend-item"><view class="legend-dot green"></view><text>已完成 {{taskStats.done}}</text></view>
        <view class="legend-item"><view class="legend-dot yellow"></view><text>进行中 {{taskStats.running}}</text></view>
        <view class="legend-item"><view class="legend-dot red"></view><text>已驳回 {{taskStats.rejected}}</text></view>
        <view class="legend-item"><view class="legend-dot gray"></view><text>待接单 {{taskStats.pending}}</text></view>
      </view>
    </view>
  </view>
</view>

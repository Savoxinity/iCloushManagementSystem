<!-- 发票详情页 V5.6.7 — 使用 invoice-info-card 组件 -->
<view class="page-container">

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-state">
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:else>
  <!-- 错误状态 -->
  <view wx:if="{{error}}" class="error-state">
    <text class="error-text">{{error}}</text>
    <view class="btn-back" bindtap="goBack">返回</view>
  </view>

  <!-- 发票详情 -->
  <block wx:else>
  <view wx:if="{{invoice}}" class="detail-content">

    <!-- ★ V5.6.7: 使用统一组件渲染全部发票信息 -->
    <invoice-info-card
      invoiceData="{{invoice}}"
      showImage="{{true}}"
      showVerifyActions="{{true}}"
      showVerifyInfo="{{true}}"
      compact="{{false}}"
      bind:autoVerify="onAutoVerify"
      bind:manualVerify="onManualVerify"
    />

    <!-- 底部间距 -->
    <view style="height: 60rpx;"></view>
  </view>
  </block>
  </block>
</view>

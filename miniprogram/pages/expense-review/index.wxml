<!-- 报销审核页 V5.6.7 — 五Tab分类 + 三按钮审核 + 归一化详情弹窗 -->
<view class="page-container">
  <view class="header-bar">
    <text class="page-title">报销审核</text>
    <text class="pending-count">{{expenses.length}} 条记录</text>
  </view>

  <!-- ═══ 五Tab筛选栏 ═══ -->
  <view class="filter-tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab-item {{activeTab === item.key ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="{{item.key}}"
    >
      <text>{{item.label}}</text>
    </view>
  </view>

  <view wx:if="{{loading}}" class="empty-state">
    <text class="empty-text">加载中...</text>
  </view>

  <block wx:else>
  <view wx:if="{{expenses.length === 0}}" class="empty-state">
    <text class="empty-icon">✅</text>
    <text class="empty-text">暂无{{currentTabLabel}}报销单</text>
  </view>

  <!-- 报销单列表 -->
  <view wx:else class="expense-list">
    <view class="expense-card" wx:for="{{expenses}}" wx:key="id">
      <!-- 可点击查看详情 -->
      <view class="card-clickable" bindtap="viewDetail" data-id="{{item.id}}">
        <view class="card-header">
          <text class="emp-name">{{item.user_name || '员工#' + item.user_id}}</text>
          <view class="header-badges">
            <text wx:if="{{item.status === 'approved' && item.points_delta > 0}}" class="status-badge badge-invoice-pass">发票通过</text>
            <text wx:if="{{item.status === 'approved' && item.points_delta < 0}}" class="status-badge badge-receipt-pass">小票通过</text>
            <text wx:if="{{item.status === 'approved' && (item.points_delta === 0 || item.points_delta === undefined)}}" class="status-badge badge-approved">已通过</text>
            <text wx:if="{{item.status === 'rejected'}}" class="status-badge badge-rejected">已驳回</text>
            <text wx:if="{{item.status === 'pending' || item.status === 'manual_review'}}" class="status-badge badge-pending">待审核</text>
            <text class="voucher-badge {{item.voucher_type}}">{{item.voucher_type === 'invoice' ? '有票' : '无票'}}</text>
          </view>
        </view>
        <view class="card-body">
          <view class="info-row">
            <text class="info-label">事由</text>
            <text class="info-value">{{item.purpose}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">金额</text>
            <text class="info-value amount">¥ {{item.claimed_amount}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">提交时间</text>
            <text class="info-value small">{{item.created_at}}</text>
          </view>
          <view wx:if="{{item.points_delta !== 0 && item.points_delta !== undefined}}" class="info-row">
            <text class="info-label">积分变动</text>
            <text class="info-value {{item.points_delta > 0 ? 'points-plus' : 'points-minus'}}">
              {{item.points_delta > 0 ? '+' : ''}}{{item.points_delta}} 分
            </text>
          </view>
        </view>
        <!-- ★ 发票缩略图预览 -->
        <view wx:if="{{item.invoice_info}}" class="invoice-preview">
          <image
            src="{{item.invoice_info.image_url || item.invoice_image_url || ''}}"
            class="inv-thumb"
            mode="aspectFill"
            binderror="onInvThumbError"
            data-idx="{{index}}"
          />
          <view class="inv-preview-info">
            <text class="inv-preview-type">
              <text class="type-mini {{item.invoice_info.invoice_type_code === '专' ? 'mini-special' : 'mini-general'}}">{{item.invoice_info.invoice_type_code || '普'}}</text>
              {{item.invoice_info.seller_name || '发票'}}
            </text>
            <text class="inv-preview-amount">¥{{item.invoice_info.total_amount || '--'}}</text>
          </view>
        </view>
        <view wx:elif="{{item.invoice_image_url || item.receipt_image_url}}" class="invoice-preview">
          <image src="{{item.invoice_image_url || item.receipt_image_url}}" class="inv-thumb" mode="aspectFill" />
          <view class="inv-preview-info">
            <text class="inv-preview-type">已上传票据</text>
            <text class="inv-preview-amount">¥{{item.claimed_amount || '--'}}</text>
          </view>
        </view>
      </view>

      <!-- 审核按钮 -->
      <view wx:if="{{item.status === 'pending' || item.status === 'manual_review'}}" class="card-actions">
        <view class="btn-view-detail" data-id="{{item.id}}" bindtap="viewDetail">查看详情</view>
        <view class="btn-review" data-id="{{item.id}}" bindtap="openReview">审核</view>
      </view>
      <view wx:else class="card-actions">
        <view class="btn-view-detail full-width" data-id="{{item.id}}" bindtap="viewDetail">查看详情</view>
      </view>
    </view>
  </view>
  </block>

  <!-- ═══════════════════════════════════════════
       V5.6.7 归一化详情弹窗
       顶部留白 → 图片预览(上) → 归一化发票详情(中) → 报销基本信息(下)
       ═══════════════════════════════════════════ -->
  <view wx:if="{{showDetailPanel}}" class="review-mask" bindtap="closeDetail">
    <view class="detail-panel-v2" catchtap="stopPropagation">

      <!-- ★ 顶部留白（空气感） -->
      <view class="detail-top-spacer"></view>

      <!-- ═══ 上部：发票/凭证图片预览 ═══ -->
      <view class="detail-section detail-image-section">
        <view wx:if="{{currentExpense.invoice_image_url || (currentExpense.invoice_info && currentExpense.invoice_info.image_url)}}" class="image-preview-box">
          <image
            src="{{currentExpense.invoice_info.image_url || currentExpense.invoice_image_url}}"
            class="detail-main-image"
            mode="aspectFit"
            bindtap="previewVoucher"
            data-url="{{currentExpense.invoice_info.image_url || currentExpense.invoice_image_url}}"
            binderror="onDetailImageError"
          />
          <text class="image-hint">点击查看原图</text>
        </view>
        <view wx:elif="{{currentExpense.receipt_image_url}}" class="image-preview-box">
          <image
            src="{{currentExpense.receipt_image_url}}"
            class="detail-main-image"
            mode="aspectFit"
            bindtap="previewVoucher"
            data-url="{{currentExpense.receipt_image_url}}"
          />
          <text class="image-hint">点击查看原图</text>
        </view>
        <view wx:else class="image-placeholder">
          <text class="placeholder-icon">📄</text>
          <text class="placeholder-text">暂无凭证图片</text>
        </view>
      </view>

      <!-- ═══ 中部：★ V5.6.7 归一化发票详情组件（替代简陋版 OCR 折叠框） ═══ -->
      <view class="detail-section detail-invoice-section">
        <view wx:if="{{currentExpense.invoice_info || currentExpense.ocr_data}}" class="invoice-card-wrapper">
          <view class="invoice-card-header">
            <text class="invoice-card-title">发票识别详情（已入票据池）</text>
          </view>
          <!-- ★ 使用归一化组件，100% 复用"我的发票"详情页的 UI -->
          <invoice-info-card
            invoiceData="{{invoiceCardData}}"
            showImage="{{false}}"
            showVerifyActions="{{false}}"
            showVerifyInfo="{{false}}"
            compact="{{true}}"
          />
        </view>
        <!-- 无发票数据时 -->
        <view wx:elif="{{currentExpense.voucher_type === 'receipt'}}" class="ocr-box ocr-empty">
          <text class="ocr-empty-text">收据报销（无发票数据）</text>
        </view>
        <view wx:else class="ocr-box ocr-empty">
          <text class="ocr-empty-text">暂无发票识别数据</text>
        </view>
      </view>

      <!-- ═══ 下部：报销基本信息 ═══ -->
      <view class="detail-section detail-info-section">
        <view class="info-group">
          <view class="detail-row">
            <text class="detail-label">提交人</text>
            <text class="detail-value">{{currentExpense.user_name || '未知'}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">报销事由</text>
            <text class="detail-value">{{currentExpense.purpose}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">报销金额</text>
            <text class="detail-value amount">¥ {{currentExpense.claimed_amount}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">凭证类型</text>
            <text class="detail-value">{{currentExpense.voucher_type === 'invoice' ? '发票' : '收据'}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">提交时间</text>
            <text class="detail-value small">{{currentExpense.created_at}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">审核状态</text>
            <text class="detail-value">{{currentExpense.status_label || currentExpense.status}}</text>
          </view>
          <!-- 积分变动 -->
          <view wx:if="{{currentExpense.points_delta !== 0 && currentExpense.points_delta !== undefined}}" class="detail-row">
            <text class="detail-label">积分变动</text>
            <text class="detail-value {{currentExpense.points_delta > 0 ? 'points-plus' : 'points-minus'}}">
              {{currentExpense.points_delta > 0 ? '+' : ''}}{{currentExpense.points_delta}} 分
            </text>
          </view>
          <!-- 审核备注 -->
          <view wx:if="{{currentExpense.review_note}}" class="detail-row">
            <text class="detail-label">审核备注</text>
            <text class="detail-value">{{currentExpense.review_note}}</text>
          </view>
          <!-- 成本分类 -->
          <view wx:if="{{currentExpense.category_name}}" class="detail-row">
            <text class="detail-label">成本分类</text>
            <text class="detail-value">{{currentExpense.category_name}}</text>
          </view>
        </view>
      </view>

      <!-- 底部操作按钮 -->
      <view class="panel-actions">
        <view class="btn-close-detail" bindtap="closeDetail">关闭</view>
        <view wx:if="{{currentExpense.status === 'pending' || currentExpense.status === 'manual_review'}}" class="btn-go-review" bindtap="openReviewFromDetail">进入审核</view>
      </view>
    </view>
  </view>

  <!-- ═══ 审核弹窗（三按钮） ═══ -->
  <view wx:if="{{showReviewPanel}}" class="review-mask" bindtap="closeReview">
    <view class="review-panel" catchtap="stopPropagation">
      <view class="panel-title">审核报销单</view>
      <view class="panel-info">
        <text class="panel-purpose">{{currentExpense.purpose}}</text>
        <text class="panel-amount">¥ {{currentExpense.claimed_amount}}</text>
      </view>

      <!-- 积分说明 -->
      <view class="points-hint">
        <view class="hint-row">
          <text class="hint-icon reject-icon">✕</text>
          <text class="hint-text">驳回 — 不产生积分</text>
        </view>
        <view class="hint-row">
          <text class="hint-icon receipt-icon">票</text>
          <text class="hint-text">小票通过 — 扣除 5 积分</text>
        </view>
        <view class="hint-row">
          <text class="hint-icon invoice-icon">发</text>
          <text class="hint-text">发票通过 — 奖励 10 积分</text>
        </view>
      </view>

      <!-- 成本分类选择器 -->
      <view class="form-item">
        <text class="label">成本分类</text>
        <picker mode="selector" range="{{categoryNames}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
          <view class="picker-value">
            {{categoryNames[categoryIndex] || '请选择分类'}} ▾
          </view>
        </picker>
      </view>

      <!-- 审核备注 -->
      <view class="form-item">
        <text class="label">审核备注</text>
        <input class="input" placeholder="可选" value="{{reviewNote}}" bindinput="onNoteInput" />
      </view>

      <!-- 三按钮操作 -->
      <view class="panel-actions-three">
        <view class="btn-reject" bindtap="rejectExpense">驳回</view>
        <view class="btn-receipt-pass" bindtap="receiptPassExpense">小票通过</view>
        <view class="btn-invoice-pass" bindtap="invoicePassExpense">发票通过</view>
      </view>
    </view>
  </view>
</view>

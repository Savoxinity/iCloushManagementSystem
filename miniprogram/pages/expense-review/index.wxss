.page-container { padding: 24rpx; background: #0a0a0a; min-height: 100vh; }
.header-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32rpx; }
.page-title { font-size: 36rpx; color: #fff; font-weight: bold; }
.pending-count { font-size: 26rpx; color: #FBBF24; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #666; }
.expense-card { background: rgba(255,255,255,0.05); border-radius: 12rpx; padding: 24rpx; margin-bottom: 20rpx; }
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.emp-name { font-size: 30rpx; color: #fff; font-weight: bold; }
.voucher-badge { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 6rpx; }
.voucher-badge.invoice { background: rgba(16,185,129,0.15); color: #10B981; }
.voucher-badge.receipt { background: rgba(239,68,68,0.15); color: #EF4444; }
.info-row { display: flex; justify-content: space-between; padding: 8rpx 0; }
.info-label { font-size: 26rpx; color: #888; }
.info-value { font-size: 26rpx; color: #ccc; }
.info-value.amount { color: #C9A84C; font-weight: bold; font-size: 32rpx; }
.card-actions { margin-top: 20rpx; display: flex; justify-content: flex-end; }
.btn-review { font-size: 26rpx; color: #000; background: #C9A84C; padding: 12rpx 40rpx; border-radius: 8rpx; font-weight: bold; }

/* 审核弹窗 */
.review-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); z-index: 100; display: flex; align-items: flex-end; }
.review-panel { width: 100%; background: #1a1a1a; border-radius: 24rpx 24rpx 0 0; padding: 40rpx 32rpx; padding-bottom: calc(40rpx + env(safe-area-inset-bottom)); }
.panel-title { font-size: 32rpx; color: #fff; font-weight: bold; margin-bottom: 24rpx; text-align: center; }
.panel-info { display: flex; justify-content: space-between; align-items: center; padding: 20rpx; background: rgba(255,255,255,0.05); border-radius: 12rpx; margin-bottom: 24rpx; }
.panel-purpose { font-size: 28rpx; color: #ccc; }
.panel-amount { font-size: 36rpx; color: #C9A84C; font-weight: bold; }
.form-item { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.08); }
.label { font-size: 28rpx; color: #aaa; flex-shrink: 0; }
.input { flex: 1; font-size: 28rpx; color: #fff; text-align: right; }
.picker-value { font-size: 28rpx; color: #C9A84C; }
.panel-actions { display: flex; gap: 24rpx; margin-top: 32rpx; }
.btn-reject { flex: 1; height: 88rpx; line-height: 88rpx; text-align: center; font-size: 30rpx; color: #EF4444; border: 2rpx solid #EF4444; border-radius: 12rpx; font-weight: bold; }
.btn-approve { flex: 1; height: 88rpx; line-height: 88rpx; text-align: center; font-size: 30rpx; color: #000; background: #C9A84C; border-radius: 12rpx; font-weight: bold; }

<!-- 管理利润表 — ECharts 可视化 -->
<view class="page-container">
  <!-- 顶部 -->
  <view class="header-bar">
    <text class="page-title">管理利润表</text>
    <picker mode="date" fields="month" value="{{period}}" bindchange="onDateChange">
      <view class="period-picker">{{period}} ▾</view>
    </picker>
  </view>

  <view wx:if="{{loading}}" class="loading-state">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <view wx:elif="{{!statement}}" class="empty-state">
    <text class="empty-text">暂无数据，请先录入成本和营收</text>
  </view>

  <view wx:else class="statement-body">
    <!-- 营收来源标签 -->
    <view class="source-tag">
      <text class="source-label">营收数据来源：{{statement.revenue_source_label}}</text>
    </view>

    <!-- 4 个指标卡 -->
    <view class="metrics-grid">
      <view class="metric-card">
        <text class="mc-label">营业收入</text>
        <text class="mc-value green">¥{{statement.revenue_display}}</text>
      </view>
      <view class="metric-card">
        <text class="mc-label">变动成本</text>
        <text class="mc-value red">¥{{statement.variable_cost_display}}</text>
      </view>
      <view class="metric-card">
        <text class="mc-label">固定成本</text>
        <text class="mc-value red">¥{{statement.fixed_cost_display}}</text>
      </view>
      <view class="metric-card">
        <text class="mc-label">净利润</text>
        <text class="mc-value {{statement.isProfit ? 'green' : 'red'}}">
          {{statement.isProfit ? '' : '-'}}¥{{statement.net_profit_display}}
        </text>
      </view>
    </view>

    <!-- 边际贡献 -->
    <view class="cm-bar">
      <view class="cm-left">
        <text class="cm-label">边际贡献</text>
        <text class="cm-value gold">¥{{statement.contribution_margin_display}}</text>
      </view>
      <view class="cm-right">
        <text class="cm-label">边际贡献率</text>
        <text class="cm-value gold">{{statement.cm_ratio_display}}</text>
      </view>
    </view>

    <!-- 瀑布图 -->
    <view class="chart-section">
      <text class="chart-title">利润瀑布图</text>
      <view class="chart-wrap">
        <ec-canvas id="waterfallChart" canvas-id="waterfallCanvas" ec="{{ecWaterfall}}"></ec-canvas>
      </view>
    </view>

    <!-- 盈亏平衡 -->
    <view class="breakeven-card">
      <view class="be-row">
        <text class="be-label">盈亏平衡点</text>
        <text class="be-value">¥{{statement.breakeven_display}}</text>
      </view>
      <view class="be-bar-track">
        <view class="be-bar-fill" style="width: {{statement.breakeven_revenue > 0 ? (statement.revenue / statement.breakeven_revenue * 100 > 100 ? 100 : statement.revenue / statement.breakeven_revenue * 100) : 0}}%"></view>
      </view>
      <text class="be-hint {{statement.isProfit ? 'hint-green' : 'hint-red'}}">
        {{statement.isProfit ? '✓ 已超过盈亏平衡点' : '✗ 尚未达到盈亏平衡点'}}
      </text>
    </view>

    <!-- 成本分类环形图 -->
    <view wx:if="{{statement.cost_breakdown.length > 0}}" class="chart-section">
      <text class="chart-title">成本分类占比</text>
      <view class="chart-wrap pie-wrap">
        <ec-canvas id="pieChart" canvas-id="pieCanvas" ec="{{ecPie}}"></ec-canvas>
      </view>
    </view>

    <!-- 成本明细列表 -->
    <view wx:if="{{statement.cost_breakdown.length > 0}}" class="breakdown-section">
      <text class="section-title">成本明细</text>
      <view class="breakdown-item" wx:for="{{statement.cost_breakdown}}" wx:key="name">
        <text class="bd-name">{{item.name}}</text>
        <text class="bd-amount">¥ {{item.value}}</text>
      </view>
    </view>
  </view>
</view>

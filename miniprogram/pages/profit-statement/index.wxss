/* 管理利润表 — 品牌黑橙配色 + 纯CSS可视化 */
.page-container {
  padding: 32rpx;
  background: #111111;
  min-height: 100vh;
  box-sizing: border-box;
}

.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.page-title {
  font-size: 40rpx;
  color: #E8A945;
  font-weight: 700;
}

.period-picker {
  font-size: 28rpx;
  color: #E8A945;
  border: 1rpx solid rgba(232, 169, 69, 0.3);
  padding: 10rpx 24rpx;
  border-radius: 8rpx;
}

.loading-state, .empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(232, 169, 69, 0.2);
  border-top-color: #E8A945;
  border-radius: 50%;
  margin: 0 auto 16rpx;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text, .empty-text {
  font-size: 28rpx;
  color: #666;
}

/* 营收来源标签 */
.source-tag {
  margin-bottom: 20rpx;
}

.source-label {
  font-size: 22rpx;
  color: #888;
  background: rgba(232, 169, 69, 0.08);
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}

/* 指标卡 */
.metrics-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.metric-card {
  background: #1E1E1E;
  border-radius: 12rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.mc-label {
  display: block;
  font-size: 22rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.mc-value {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  font-family: 'DIN Alternate', monospace;
}

.mc-value.green { color: #10B981; }
.mc-value.red { color: #EF4444; }
.mc-value.gold { color: #E8A945; }

/* 边际贡献条 */
.cm-bar {
  display: flex;
  justify-content: space-between;
  background: rgba(232, 169, 69, 0.08);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(232, 169, 69, 0.15);
}

.cm-left, .cm-right {
  display: flex;
  flex-direction: column;
}

.cm-label {
  font-size: 22rpx;
  color: #888;
  margin-bottom: 6rpx;
}

.cm-value {
  font-size: 30rpx;
  font-weight: 700;
}

.cm-value.gold { color: #E8A945; }

/* 图表区域 */
.chart-section {
  margin-bottom: 24rpx;
}

.chart-title {
  display: block;
  font-size: 28rpx;
  color: #CCCCCC;
  font-weight: 600;
  margin-bottom: 16rpx;
}

/* ===== 瀑布图（纯CSS） ===== */
.waterfall-chart {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 400rpx;
  background: #1E1E1E;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  padding: 24rpx 16rpx 16rpx;
  box-sizing: border-box;
}

.wf-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  height: 100%;
}

.wf-bar-area {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  flex: 1;
  width: 100%;
}

.wf-val {
  font-size: 18rpx;
  color: #CCCCCC;
  margin-bottom: 4rpx;
  font-family: 'DIN Alternate', monospace;
}

.wf-bar-spacer {
  width: 60%;
  background: transparent;
}

.wf-bar {
  width: 60%;
  border-radius: 4rpx 4rpx 0 0;
  min-height: 4rpx;
  transition: height 0.5s ease;
}

.wf-bar.bar-green { background: linear-gradient(180deg, #10B981, #059669); }
.wf-bar.bar-red { background: linear-gradient(180deg, #EF4444, #DC2626); }
.wf-bar.bar-gold { background: linear-gradient(180deg, #E8A945, #D4942E); }

.wf-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
  white-space: nowrap;
}

/* ===== 水平条形图（替代环形图） ===== */
.donut-chart-area {
  background: #1E1E1E;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  padding: 24rpx;
}

.hbar-item {
  margin-bottom: 20rpx;
}

.hbar-item:last-child {
  margin-bottom: 0;
}

.hbar-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.hbar-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.hbar-name {
  font-size: 24rpx;
  color: #CCCCCC;
  flex: 1;
}

.hbar-pct {
  font-size: 22rpx;
  color: #E8A945;
  font-weight: 600;
  margin-right: 16rpx;
  font-family: 'DIN Alternate', monospace;
}

.hbar-amt {
  font-size: 22rpx;
  color: #999;
  font-family: 'DIN Alternate', monospace;
}

.hbar-track {
  width: 100%;
  height: 12rpx;
  background: #333;
  border-radius: 6rpx;
  overflow: hidden;
}

.hbar-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

/* 盈亏平衡卡片 */
.breakeven-card {
  background: #1E1E1E;
  border-radius: 12rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(232, 169, 69, 0.15);
}

.be-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.be-label {
  font-size: 26rpx;
  color: #888;
}

.be-value {
  font-size: 34rpx;
  color: #E8A945;
  font-weight: 700;
  font-family: 'DIN Alternate', monospace;
}

.be-bar-track {
  width: 100%;
  height: 12rpx;
  background: #333;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.be-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #E8A945, #10B981);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.be-hint {
  font-size: 22rpx;
  display: block;
  text-align: center;
}

.hint-green { color: #10B981; }
.hint-red { color: #EF4444; }

/* 成本明细 */
.breakdown-section {
  margin-top: 8rpx;
}

.section-title {
  font-size: 28rpx;
  color: #CCCCCC;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.breakdown-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #1E1E1E;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.04);
}

.bd-name {
  font-size: 26rpx;
  color: #CCCCCC;
}

.bd-amount {
  font-size: 26rpx;
  color: #E8A945;
  font-weight: 600;
  font-family: 'DIN Alternate', monospace;
}

.page-container { padding: 32rpx; background: #0a0a0a; min-height: 100vh; }
.header-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40rpx; }
.page-title { font-size: 36rpx; color: #fff; font-weight: bold; }
.period-picker { font-size: 28rpx; color: #C9A84C; border: 1rpx solid rgba(201,168,76,0.3); padding: 10rpx 24rpx; border-radius: 8rpx; }
.loading-state, .empty-state { text-align: center; padding: 120rpx 0; }
.loading-text, .empty-text { font-size: 28rpx; color: #666; }
.statement-body { background: rgba(255,255,255,0.03); border-radius: 16rpx; padding: 32rpx; }
.metric-row { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0; }
.metric-row.highlight { padding: 24rpx 0; }
.metric-row.sub { padding: 8rpx 0 20rpx; }
.metric-label { font-size: 28rpx; color: #aaa; }
.metric-row.highlight .metric-label { font-size: 30rpx; color: #fff; font-weight: bold; }
.metric-value { font-size: 30rpx; color: #ccc; }
.metric-value.accent { color: #C9A84C; font-weight: bold; font-size: 34rpx; }
.metric-value.positive { color: #10B981; font-weight: bold; font-size: 36rpx; }
.metric-value.negative { color: #EF4444; }
.divider { height: 1rpx; background: rgba(255,255,255,0.08); margin: 8rpx 0; }
.breakeven-card { margin-top: 24rpx; background: rgba(201,168,76,0.08); border-radius: 12rpx; padding: 28rpx; text-align: center; border: 1rpx solid rgba(201,168,76,0.2); }
.breakeven-title { display: block; font-size: 24rpx; color: #888; margin-bottom: 12rpx; }
.breakeven-value { display: block; font-size: 44rpx; color: #C9A84C; font-weight: bold; margin-bottom: 8rpx; }
.breakeven-hint { display: block; font-size: 22rpx; color: #888; }
.breakdown-section { margin-top: 32rpx; }
.section-title { font-size: 28rpx; color: #888; margin-bottom: 16rpx; }
.breakdown-item { display: flex; justify-content: space-between; padding: 16rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.05); }
.breakdown-item:last-child { border-bottom: none; }
.bd-name { font-size: 26rpx; color: #ccc; }
.bd-amount { font-size: 26rpx; color: #C9A84C; }

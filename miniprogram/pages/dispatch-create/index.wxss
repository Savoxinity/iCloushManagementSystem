/* 创建调度单 — 品牌黑橙配色 */

.page-container {
  min-height: 100vh;
  background: #0a0a0a;
  padding-bottom: 140rpx;
}

.form-section {
  margin: 20rpx 24rpx;
  background: rgba(255,255,255,0.05);
  border-radius: 16rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(201,168,76,0.1);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #C9A84C;
  margin-bottom: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 24rpx;
  color: #888;
  display: block;
  margin-bottom: 8rpx;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 12rpx;
  padding: 0 20rpx;
}

.picker-value {
  font-size: 28rpx;
  color: #fff;
}

.picker-placeholder {
  font-size: 28rpx;
  color: #555;
}

.picker-arrow {
  font-size: 20rpx;
  color: #666;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #fff;
  box-sizing: border-box;
}

/* ── 提交栏 ── */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #111;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.3);
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #C9A84C, #8B7333);
  color: #000;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
}

.btn-submit[disabled] {
  opacity: 0.5;
}

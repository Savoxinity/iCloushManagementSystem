/* 成本分类明细账 — Phase 4.1 PRD 2.3 */

.page-container {
  min-height: 100vh;
  background: #0a0a0a;
  padding-bottom: 40rpx;
}

/* ── 月份选择器 ── */
.period-bar {
  padding: 24rpx 32rpx 16rpx;
}

.period-picker {
  display: inline-flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 12rpx 24rpx;
}

.period-text {
  font-size: 28rpx;
  color: #c8a45a;
  font-weight: 600;
}

.period-arrow {
  font-size: 20rpx;
  color: #c8a45a;
  margin-left: 12rpx;
}

/* ── Tab 栏 ── */
.tab-scroll {
  white-space: nowrap;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

.tab-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 8rpx 0;
}

.tab-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  font-size: 24rpx;
  color: #999;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 8rpx;
  transition: all 0.2s;
}

.tab-active {
  color: #0a0a0a;
  background: #c8a45a;
  border-color: #c8a45a;
  font-weight: 600;
}

/* ── 汇总卡片 ── */
.summary-card {
  margin: 0 32rpx 32rpx;
  background: linear-gradient(135deg, rgba(200, 164, 90, 0.15), rgba(200, 164, 90, 0.05));
  border: 1rpx solid rgba(200, 164, 90, 0.3);
  border-radius: 16rpx;
  padding: 32rpx;
}

.summary-main {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.summary-label {
  font-size: 26rpx;
  color: #c8a45a;
  font-weight: 500;
}

.summary-amount {
  font-size: 48rpx;
  color: #fff;
  font-weight: 700;
  font-family: 'DIN Alternate', 'Helvetica Neue', monospace;
}

.summary-sub {
  margin-top: 12rpx;
}

.summary-count {
  font-size: 24rpx;
  color: #888;
}

/* ── 列表 ── */
.list-section {
  padding: 0 32rpx;
}

.cost-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.cost-item:last-child {
  border-bottom: none;
}

.item-left {
  flex: 1;
  min-width: 0;
}

.item-name {
  font-size: 28rpx;
  color: #e0e0e0;
  font-weight: 500;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.meta-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.tag-category {
  background: rgba(200, 164, 90, 0.15);
  color: #c8a45a;
  border: 1rpx solid rgba(200, 164, 90, 0.3);
}

.tag-invoice {
  background: rgba(76, 175, 80, 0.12);
  color: #66bb6a;
  border: 1rpx solid rgba(76, 175, 80, 0.25);
}

.meta-source {
  font-size: 20rpx;
  color: #666;
}

.item-bottom {
  display: flex;
  align-items: center;
}

.item-date {
  font-size: 22rpx;
  color: #666;
}

.item-creator {
  font-size: 22rpx;
  color: #555;
  margin-left: 4rpx;
}

.item-right {
  text-align: right;
  flex-shrink: 0;
  margin-left: 24rpx;
}

.item-amount {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
  font-family: 'DIN Alternate', 'Helvetica Neue', monospace;
  display: block;
}

.item-behavior {
  font-size: 20rpx;
  color: #888;
  margin-top: 4rpx;
  display: block;
}

/* ── 空状态 ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
}

/* ── 加载状态 ── */
.loading-more, .no-more {
  text-align: center;
  padding: 32rpx 0;
  font-size: 24rpx;
  color: #666;
}

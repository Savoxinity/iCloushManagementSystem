<!--
  成本分类明细账 — Phase 4.1 PRD 2.3
  顶部 Tab 切换（一级细化分类标签） + 动态汇总卡片 + 明细列表
  分类体系：一级标签=具体分类（员工工资、水电能源等），二级=固定/变动（仅利润表汇总用）
-->
<view class="page-container">

  <!-- 月份选择器 -->
  <view class="period-bar">
    <picker mode="date" fields="month" value="{{currentPeriod}}" bindchange="onPeriodChange">
      <view class="period-picker">
        <text class="period-text">{{periodDisplay}}</text>
        <text class="period-arrow">▼</text>
      </view>
    </picker>
  </view>

  <!-- Tab 栏（一级细化分类标签） -->
  <scroll-view scroll-x class="tab-scroll">
    <view class="tab-list">
      <view
        wx:for="{{tabs}}"
        wx:key="code"
        class="tab-item {{activeTab === index ? 'tab-active' : ''}}"
        data-index="{{index}}"
        bindtap="onTabChange"
      >
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <!-- 动态汇总卡片 -->
  <view class="summary-card">
    <view class="summary-main">
      <text class="summary-label">{{tabs[activeTab].name}} · 本月总计</text>
      <text class="summary-amount">¥ {{summary.total_amount}}</text>
    </view>
    <view class="summary-sub">
      <text class="summary-count">共 {{summary.total_count}} 笔</text>
    </view>
  </view>

  <!-- 明细列表 -->
  <view class="list-section">
    <view wx:if="{{items.length === 0 && !loading}}" class="empty-state">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无成本记录</text>
    </view>

    <view wx:for="{{items}}" wx:key="id" class="cost-item">
      <view class="item-left">
        <view class="item-name">{{item.item_name}}</view>
        <view class="item-meta">
          <!-- 一级分类标签（具体分类名） -->
          <text class="meta-tag tag-category">{{item.category_name}}</text>
          <text class="meta-tag tag-invoice">{{item.invoice_status_label}}</text>
          <text class="meta-source">{{item.source_label}}</text>
        </view>
        <view class="item-bottom">
          <text class="item-date">{{item.trade_date}}</text>
          <text class="item-creator" wx:if="{{item.creator_name}}">· {{item.creator_name}}</text>
        </view>
      </view>
      <view class="item-right">
        <text class="item-amount">¥ {{item.post_tax_amount}}</text>
        <!-- 二级分类标签（固定/变动）作为辅助信息 -->
        <text class="item-behavior">{{item.cost_behavior_label}}</text>
      </view>
    </view>

    <!-- 加载更多 -->
    <view wx:if="{{loading}}" class="loading-more">
      <text>加载中...</text>
    </view>
    <view wx:elif="{{!hasMore && items.length > 0}}" class="no-more">
      <text>— 已加载全部 —</text>
    </view>
  </view>
</view>

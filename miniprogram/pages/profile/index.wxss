/* ============================================
   我的页面样式
   ============================================ */

.page-container {
  background: #0A0A0A;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

/* ===== 员工卡牌英雄区 ===== */
.card-hero {
  position: relative;
  background: linear-gradient(135deg, #111111 0%, #1A1208 100%);
  padding: 48rpx 32rpx 32rpx;
  overflow: hidden;
  border-bottom: 1rpx solid #1E1E1E;
}

.card-bg-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(201, 168, 76, 0.03) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(201, 168, 76, 0.03) 1rpx, transparent 1rpx);
  background-size: 32rpx 32rpx;
  pointer-events: none;
}

.card-bg-lines {
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  border: 60rpx solid rgba(201, 168, 76, 0.04);
  pointer-events: none;
}

/* 员工卡牌 */
.staff-card {
  position: relative;
  display: flex;
  align-items: center;
  gap: 24rpx;
  z-index: 1;
}

.card-avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.card-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(201, 168, 76, 0.4);
  box-shadow: 0 0 20rpx rgba(201, 168, 76, 0.2);
}

.card-avatar-initial {
  font-size: 52rpx;
  font-weight: 700;
  color: #000000;
}

.card-online-dot {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #00FF88;
  border: 3rpx solid #111111;
  box-shadow: 0 0 8rpx #00FF88;
}

.card-info {
  flex: 1;
  min-width: 0;
}

.card-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #F0F0F0;
}

.card-role-row {
  display: flex;
  gap: 10rpx;
  margin: 8rpx 0;
}

.card-role-tag {
  background: rgba(201, 168, 76, 0.15);
  border: 1rpx solid rgba(201, 168, 76, 0.3);
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
}

.card-role-tag text {
  font-size: 20rpx;
  color: #C9A84C;
}

.card-multi-tag {
  background: rgba(59, 130, 246, 0.15);
  border: 1rpx solid rgba(59, 130, 246, 0.3);
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
}

.card-multi-tag text {
  font-size: 20rpx;
  color: #3B82F6;
}

.card-mode-tag {
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
}

.card-mode-tag text {
  font-size: 20rpx;
  font-weight: 600;
}

.card-dept {
  font-size: 22rpx;
  color: #666666;
}

.card-points-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.card-points-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #C9A84C;
  font-family: 'Courier New', monospace;
  line-height: 1;
}

.card-points-label {
  font-size: 18rpx;
  color: #888888;
  margin-top: 4rpx;
}

/* 技能标签 */
.skill-tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
  position: relative;
  z-index: 1;
}

.skill-tag {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid #2A2A2A;
  border-radius: 20rpx;
  padding: 6rpx 18rpx;
}

.skill-tag text {
  font-size: 20rpx;
  color: #AAAAAA;
}

/* ===== 今日数据 ===== */
.today-stats-row {
  display: flex;
  padding: 20rpx 24rpx;
  gap: 12rpx;
  background: #0F0F0F;
  border-bottom: 1rpx solid #1A1A1A;
}

.today-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  background: #141414;
  border-radius: 12rpx;
  border: 1rpx solid #1E1E1E;
}

.today-stat-value {
  font-size: 36rpx;
  font-weight: 700;
  font-family: 'Courier New', monospace;
}

.today-stat-label {
  font-size: 18rpx;
  color: #666666;
  margin-top: 6rpx;
}

/* ===== 菜单列表 ===== */
.menu-section {
  padding: 24rpx 24rpx 0;
}

.menu-group {
  margin-bottom: 24rpx;
}

.menu-group-title {
  display: block;
  font-size: 22rpx;
  color: #555555;
  font-family: 'Courier New', monospace;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
  padding-left: 4rpx;
}

.menu-list {
  background: #141414;
  border-radius: 16rpx;
  border: 1rpx solid #1E1E1E;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx;
  border-bottom: 1rpx solid #1A1A1A;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.menu-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-icon {
  font-size: 30rpx;
}

.menu-name {
  font-size: 28rpx;
  color: #F0F0F0;
}

.menu-item-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.menu-badge {
  background: #EF4444;
  color: #fff;
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  font-weight: 700;
}

.menu-arrow {
  font-size: 28rpx;
  color: #444444;
}

/* ===== 退出登录 ===== */
.logout-wrap {
  padding: 24rpx 24rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  background: rgba(239, 68, 68, 0.1);
  color: #EF4444;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: 1rpx solid rgba(239, 68, 68, 0.2);
}

.logout-btn::after { border: none; }

.safe-bottom {
  height: env(safe-area-inset-bottom);
}

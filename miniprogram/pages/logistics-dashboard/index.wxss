/* 物流仪表盘 — Phase 4 机动物流中台 — 品牌黑橙配色 */

.page-container {
  min-height: 100vh;
  background: #0a0a0a;
  padding-bottom: 40rpx;
}

/* ── 顶部 ── */
.dashboard-header {
  background: linear-gradient(135deg, #1a1a1a, #0d0d0d);
  padding: 60rpx 32rpx 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  border-bottom: 1rpx solid rgba(201, 168, 76, 0.2);
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #C9A84C;
}

.header-date {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
}

/* ── 通用区块 ── */
.section {
  margin: 20rpx 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #C9A84C;
  margin-bottom: 16rpx;
}

/* ── 车辆状态概览 ── */
.fleet-overview {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.fleet-card {
  background: rgba(255,255,255,0.05);
  border-radius: 16rpx;
  padding: 24rpx 0;
  text-align: center;
  border: 1rpx solid rgba(201,168,76,0.1);
}

.fleet-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.fleet-label {
  font-size: 22rpx;
  color: #888;
  margin-top: 4rpx;
}

.fleet-card.idle .fleet-num { color: #00FF88; }
.fleet-card.delivering .fleet-num { color: #C9A84C; }
.fleet-card.maintenance .fleet-num { color: #EF4444; }

/* ── KPI 卡片 ── */
.kpi-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.kpi-card {
  background: rgba(255,255,255,0.05);
  border-radius: 16rpx;
  padding: 28rpx;
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(201,168,76,0.1);
}

.kpi-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #C9A84C;
}

.alert-num {
  color: #EF4444;
}

.kpi-label {
  font-size: 24rpx;
  color: #888;
  margin-top: 4rpx;
}

.kpi-icon {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  font-size: 40rpx;
  opacity: 0.3;
}

/* ── 趋势图 ── */
.trend-chart {
  background: rgba(255,255,255,0.05);
  border-radius: 16rpx;
  padding: 24rpx;
  min-height: 300rpx;
  border: 1rpx solid rgba(201,168,76,0.1);
}

.no-data {
  text-align: center;
  color: #666;
  font-size: 26rpx;
  padding: 80rpx 0;
}

.bar-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 240rpx;
  padding-top: 20rpx;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bar-value {
  font-size: 22rpx;
  color: #C9A84C;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.bar {
  width: 40rpx;
  background: linear-gradient(180deg, #C9A84C, #8B7333);
  border-radius: 8rpx 8rpx 0 0;
  min-height: 8rpx;
  transition: height 0.3s;
}

.bar-label {
  font-size: 20rpx;
  color: #666;
  margin-top: 8rpx;
}

/* ── 快捷入口 ── */
.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.quick-item {
  background: rgba(255,255,255,0.05);
  border-radius: 16rpx;
  padding: 28rpx 0;
  text-align: center;
  border: 1rpx solid rgba(201,168,76,0.1);
}

.quick-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.quick-item text {
  font-size: 22rpx;
  color: #ccc;
}

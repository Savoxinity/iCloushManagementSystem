/* 出车调度 — Phase 4 机动物流中台 — 品牌黑橙配色 */

.page-container {
  min-height: 100vh;
  background: #0a0a0a;
  padding-bottom: 120rpx;
}

/* ── 日期栏 ── */
.date-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #111;
  border-bottom: 1rpx solid rgba(201,168,76,0.2);
}

.date-picker {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: #fff;
}

.date-icon { font-size: 32rpx; }
.date-text { font-weight: 600; color: #C9A84C; }
.date-arrow { font-size: 20rpx; color: #666; }

.date-nav {
  display: flex;
  gap: 12rpx;
}

.nav-btn {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: #888;
  background: rgba(255,255,255,0.06);
  border-radius: 8rpx;
}

.today-btn {
  color: #C9A84C;
  background: rgba(201,168,76,0.15);
}

/* ── 统计栏 ── */
.stats-bar {
  display: flex;
  padding: 24rpx;
  background: #111;
  margin-bottom: 16rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}

.stat-pending { color: #F59E0B; }
.stat-delivering { color: #C9A84C; }
.stat-completed { color: #00FF88; }

.stat-label {
  font-size: 22rpx;
  color: #666;
  margin-top: 4rpx;
}

/* ── 加载与空状态 ── */
.loading-box, .empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #666;
  font-size: 28rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(255,255,255,0.1);
  border-top-color: #C9A84C;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.empty-text { color: #666; }

/* ── 调度单卡片 ── */
.dispatch-list {
  padding: 0 24rpx;
}

.dispatch-card {
  background: rgba(255,255,255,0.05);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(201,168,76,0.1);
}

.dispatch-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.dispatch-plate {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.plate {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.route-name {
  font-size: 22rpx;
  color: #888;
  background: rgba(255,255,255,0.06);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.dispatch-status {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.status-pending { background: rgba(245,158,11,0.15); color: #F59E0B; }
.status-delivering { background: rgba(201,168,76,0.15); color: #C9A84C; }
.status-completed { background: rgba(0,255,136,0.1); color: #00FF88; }
.status-cancelled { background: rgba(255,255,255,0.06); color: #666; }

.dispatch-body {
  padding: 16rpx 28rpx;
}

.dispatch-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
}

.row-label {
  font-size: 24rpx;
  color: #666;
}

.row-value {
  font-size: 24rpx;
  color: #ccc;
  font-weight: 500;
}

/* ── 打卡进度 ── */
.checkin-progress {
  padding: 12rpx 28rpx 20rpx;
}

.progress-bar {
  height: 8rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #C9A84C, #00FF88);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 22rpx;
  color: #666;
}

/* ── 操作按钮 ── */
.dispatch-actions {
  padding: 0 28rpx 20rpx;
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
}

.btn-depart {
  background: linear-gradient(135deg, #C9A84C, #8B7333);
  color: #000;
}

.btn-return {
  background: linear-gradient(135deg, #00CC6A, #00FF88);
  color: #000;
}

/* ── 底部操作栏 ── */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #111;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.3);
}

.btn-add {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #C9A84C, #8B7333);
  color: #000;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
}

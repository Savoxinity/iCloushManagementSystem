/* 出车调度 — Phase 4 机动物流中台 */

.page-container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 120rpx;
}

/* ── 日期栏 ── */
.date-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.date-picker {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.date-icon { font-size: 32rpx; }
.date-text { font-weight: 600; }
.date-arrow { font-size: 20rpx; color: #999; }

.date-nav {
  display: flex;
  gap: 12rpx;
}

.nav-btn {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: #666;
  background: #f0f2f5;
  border-radius: 8rpx;
}

.today-btn {
  color: #1a73e8;
  background: #e6f0ff;
}

/* ── 统计栏 ── */
.stats-bar {
  display: flex;
  padding: 24rpx;
  background: #fff;
  margin-bottom: 16rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  display: block;
}

.stat-pending { color: #d97706; }
.stat-delivering { color: #2563eb; }
.stat-completed { color: #16a34a; }

.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* ── 加载与空状态 ── */
.loading-box, .empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #1a73e8;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.empty-text { color: #999; }

/* ── 调度单卡片 ── */
.dispatch-list {
  padding: 0 24rpx;
}

.dispatch-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.dispatch-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.dispatch-plate {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.plate {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.route-name {
  font-size: 22rpx;
  color: #666;
  background: #f0f2f5;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.dispatch-status {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.status-pending { background: #fef3c7; color: #d97706; }
.status-delivering { background: #dbeafe; color: #2563eb; }
.status-completed { background: #dcfce7; color: #16a34a; }
.status-cancelled { background: #f3f4f6; color: #6b7280; }

.dispatch-body {
  padding: 16rpx 28rpx;
}

.dispatch-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
}

.row-label {
  font-size: 24rpx;
  color: #999;
}

.row-value {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

/* ── 打卡进度 ── */
.checkin-progress {
  padding: 12rpx 28rpx 20rpx;
}

.progress-bar {
  height: 8rpx;
  background: #e5e7eb;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #1a73e8, #34d399);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: 22rpx;
  color: #999;
}

/* ── 操作按钮 ── */
.dispatch-actions {
  padding: 0 28rpx 20rpx;
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
}

.btn-depart {
  background: linear-gradient(135deg, #d97706, #f59e0b);
  color: #fff;
}

.btn-return {
  background: linear-gradient(135deg, #16a34a, #34d399);
  color: #fff;
}

/* ── 底部操作栏 ── */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}

.btn-add {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #1a73e8, #4a90d9);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
}

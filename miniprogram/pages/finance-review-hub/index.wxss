/* 报账&发票审核入口页 — BI看板 + 全屏长条卡片 */

.page-container {
  padding: 32rpx 24rpx;
  background: #0a0a0a;
  min-height: 100vh;
}

.page-title {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 32rpx;
}

/* ═══════════════════════════════════════
   BI 看板 — 开票覆盖率
   ═══════════════════════════════════════ */

.bi-dashboard {
  margin-bottom: 32rpx;
  background: linear-gradient(135deg, rgba(201,168,76,0.1), rgba(59,130,246,0.06));
  border: 1rpx solid rgba(201,168,76,0.2);
  border-radius: 20rpx;
  overflow: hidden;
}

.bi-gauge-section {
  padding: 28rpx 28rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bi-title {
  font-size: 24rpx;
  color: #aaa;
  margin-bottom: 20rpx;
}

.bi-gauge-ring {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 12rpx solid rgba(201,168,76,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.bi-gauge-value {
  font-size: 44rpx;
  color: #C9A84C;
  font-weight: 700;
}

.bi-stats {
  width: 100%;
}

.bi-stat-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
}

.bi-stat-label {
  font-size: 24rpx;
  color: #888;
}

.bi-stat-value {
  font-size: 26rpx;
  color: #E0E0E0;
  font-weight: 600;
}

.bi-stat-value.bi-positive {
  color: #10B981;
}

.bi-gap-section {
  background: rgba(239,68,68,0.06);
  border-top: 1rpx solid rgba(239,68,68,0.15);
  padding: 24rpx 28rpx;
  text-align: center;
}

.bi-gap-label {
  font-size: 22rpx;
  color: #aaa;
  display: block;
  margin-bottom: 10rpx;
}

.bi-gap-value {
  font-size: 52rpx;
  color: #EF4444;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.bi-gap-hint {
  font-size: 20rpx;
  color: #666;
  display: block;
}

/* ═══════════════════════════════════════
   横栏列表卡片（与管理会计一致）
   ═══════════════════════════════════════ */

.menu-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.menu-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  background: rgba(255,255,255,0.05);
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  border: 1rpx solid rgba(201,168,76,0.15);
  box-sizing: border-box;
}

.menu-card:active {
  background: rgba(201,168,76,0.08);
}

.card-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
  flex: 1;
}

.menu-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.card-text {
  display: flex;
  flex-direction: column;
}

.menu-title {
  font-size: 32rpx;
  color: #fff;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.4;
}

.card-arrow {
  font-size: 40rpx;
  color: rgba(201,168,76,0.5);
  flex-shrink: 0;
}

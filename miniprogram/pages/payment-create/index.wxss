.page-container { padding: 24rpx; background: #0a0a0a; min-height: 100vh; }
.section-title { font-size: 28rpx; color: #aaa; margin-bottom: 20rpx; display: block; }

/* 类型选择卡片 */
.type-section { margin-bottom: 32rpx; }
.type-cards { display: flex; gap: 16rpx; }
.type-card { flex: 1; background: rgba(255,255,255,0.05); border: 2rpx solid rgba(255,255,255,0.1); border-radius: 16rpx; padding: 24rpx 16rpx; display: flex; flex-direction: column; align-items: center; text-align: center; }
.type-card.active { border-color: #C9A84C; background: rgba(201,168,76,0.1); }
.type-icon { font-size: 48rpx; margin-bottom: 8rpx; }
.type-name { font-size: 28rpx; font-weight: bold; color: #fff; }
.type-desc { font-size: 24rpx; color: #C9A84C; margin-top: 4rpx; }
.type-hint { font-size: 20rpx; color: #666; margin-top: 8rpx; line-height: 1.4; }

/* 表单 */
.form-section { background: rgba(255,255,255,0.05); border-radius: 12rpx; padding: 8rpx 24rpx; margin-bottom: 24rpx; }
.form-item { display: flex; align-items: center; justify-content: space-between; padding: 28rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.08); }
.form-item:last-child { border-bottom: none; }
.label { font-size: 28rpx; color: #aaa; flex-shrink: 0; margin-right: 16rpx; }
.input { flex: 1; font-size: 30rpx; color: #C9A84C; text-align: right; }
.input.placeholder { color: #555; }

/* 上传区域 */
.upload-section { margin: 24rpx 0; }
.upload-area { position: relative; width: 100%; min-height: 300rpx; border: 2rpx dashed rgba(201,168,76,0.4); border-radius: 12rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; overflow: hidden; }
.preview-img { width: 100%; height: 300rpx; }
.upload-hint { font-size: 24rpx; color: #C9A84C; padding: 12rpx 0; }
.upload-icon { font-size: 64rpx; margin-bottom: 12rpx; }
.upload-text { font-size: 28rpx; color: #888; }
.upload-loading { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.6); display: flex; align-items: center; justify-content: center; color: #C9A84C; font-size: 28rpx; }

/* 今天警告 */
.today-warning { background: rgba(239,68,68,0.15); border: 1rpx solid rgba(239,68,68,0.3); border-radius: 12rpx; padding: 20rpx 24rpx; margin: 16rpx 0; }
.warning-text { font-size: 26rpx; color: #EF4444; }

/* 分期明细 */
.installment-section { margin: 24rpx 0; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.add-btn { font-size: 26rpx; color: #C9A84C; padding: 8rpx 20rpx; border: 1rpx solid rgba(201,168,76,0.4); border-radius: 8rpx; }
.installment-item { background: rgba(255,255,255,0.05); border-radius: 12rpx; padding: 8rpx 24rpx; margin-bottom: 16rpx; border-left: 4rpx solid #C9A84C; }
.installment-header { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; }
.installment-label { font-size: 28rpx; color: #C9A84C; font-weight: bold; }
.remove-btn { font-size: 24rpx; color: #EF4444; }
.total-row { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 24rpx; background: rgba(201,168,76,0.08); border-radius: 12rpx; margin-top: 8rpx; }
.total-label { font-size: 28rpx; color: #aaa; }
.total-value { font-size: 34rpx; color: #C9A84C; font-weight: bold; }

/* 提交按钮 */
.btn-area { padding: 16rpx 0 48rpx; }
.btn-submit { width: 100%; height: 96rpx; line-height: 96rpx; background: #C9A84C; color: #000; font-size: 34rpx; font-weight: bold; border-radius: 12rpx; text-align: center; }
.btn-disabled { opacity: 0.4; }

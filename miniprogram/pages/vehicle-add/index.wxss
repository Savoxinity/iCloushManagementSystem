/* 新增/编辑车辆 — 品牌黑橙配色 */

.page-container {
  min-height: 100vh;
  background: #0a0a0a;
  padding: 24rpx;
  padding-bottom: 160rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #F5A623;
  margin-bottom: 32rpx;
}

/* ── 分区 ── */
.section {
  background: #1a1a1a;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(245,166,35,0.15);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #F5A623;
  margin-bottom: 8rpx;
}

.section-hint {
  font-size: 22rpx;
  color: #888;
  margin-bottom: 20rpx;
}

/* ── 表单行 ── */
.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}

.form-row:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  color: #ccc;
  flex-shrink: 0;
  width: 200rpx;
}

.required {
  color: #F5A623;
  margin-left: 4rpx;
}

.form-input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #fff;
}

.form-picker {
  font-size: 28rpx;
  color: #F5A623;
  text-align: right;
}

.form-picker.placeholder {
  color: #666;
}

.capacity-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  justify-content: flex-end;
}

.flex-input {
  width: 160rpx;
  text-align: right;
}

.unit-picker {
  font-size: 26rpx;
  color: #F5A623;
  padding: 8rpx 16rpx;
  background: rgba(245,166,35,0.15);
  border-radius: 8rpx;
}

/* ── 提交按钮 ── */
.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #111;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.3);
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #F5A623, #E8912A);
  color: #000;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
}

.btn-submit.disabled {
  opacity: 0.5;
}

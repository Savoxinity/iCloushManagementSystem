/* 新增/编辑车辆 — Phase 4.1 */

.page-container {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 24rpx;
  padding-bottom: 160rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 32rpx;
}

/* ── 分区 ── */
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}

.section-hint {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 20rpx;
}

/* ── 表单行 ── */
.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-row:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
  width: 200rpx;
}

.required {
  color: #dc2626;
  margin-left: 4rpx;
}

.form-input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #333;
}

.form-picker {
  font-size: 28rpx;
  color: #333;
  text-align: right;
}

.form-picker.placeholder {
  color: #bbb;
}

.capacity-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  justify-content: flex-end;
}

.flex-input {
  width: 160rpx;
  text-align: right;
}

.unit-picker {
  font-size: 26rpx;
  color: #1a73e8;
  padding: 8rpx 16rpx;
  background: #e6f0ff;
  border-radius: 8rpx;
}

/* ── 提交按钮 ── */
.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #1a73e8, #4a90d9);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
}

.btn-submit.disabled {
  opacity: 0.6;
}

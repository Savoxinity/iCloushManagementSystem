<!-- 欠票看板页 -->
<view class="page-container">
  <!-- Tab 切换 -->
  <view class="tab-bar">
    <view class="tab {{activeTab === 'overview' ? 'active' : ''}}" data-tab="overview" bindtap="switchTab">总览</view>
    <view class="tab {{activeTab === 'list' ? 'active' : ''}}" data-tab="list" bindtap="switchTab">明细</view>
  </view>

  <!-- 总览 Tab -->
  <view wx:if="{{activeTab === 'overview'}}">
    <!-- 统计卡片 -->
    <view class="stats-row">
      <view class="stat-card">
        <text class="stat-value">{{summary.total_missing}}</text>
        <text class="stat-label">未补票数</text>
      </view>
      <view class="stat-card">
        <text class="stat-value warn">¥{{summary.total_amount}}</text>
        <text class="stat-label">欠票总额</text>
      </view>
      <view class="stat-card">
        <text class="stat-value danger">{{summary.overdue_count}}</text>
        <text class="stat-label">已逾期</text>
      </view>
    </view>

    <!-- 批量催票 -->
    <view class="action-bar" wx:if="{{summary.overdue_count > 0}}">
      <view class="btn-batch-remind" bindtap="batchRemind">🔔 一键催票（逾期 {{summary.overdue_count}} 人）</view>
    </view>

    <!-- 欠票排行 -->
    <view class="section-title">欠票排行</view>
    <view wx:if="{{ranking.length === 0}}" class="empty-hint">暂无欠票记录</view>
    <view wx:else class="ranking-list">
      <view class="ranking-item" wx:for="{{ranking}}" wx:key="employee_id">
        <view class="rank-left">
          <text class="rank-num">{{index + 1}}</text>
          <text class="rank-name">{{item.employee_name || '员工#' + item.employee_id}}</text>
        </view>
        <view class="rank-right">
          <text class="rank-count">{{item.missing_count}} 张</text>
          <text class="rank-amount">¥{{item.total_amount}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 明细 Tab -->
  <view wx:if="{{activeTab === 'list'}}">
    <view wx:if="{{ledger.length === 0}}" class="empty-hint">暂无欠票明细</view>
    <view wx:else class="ledger-list">
      <view class="ledger-card {{item.isOverdue ? 'overdue' : ''}}" wx:for="{{ledger}}" wx:key="id">
        <view class="ledger-top">
          <text class="ledger-purpose">{{item.purpose || '报销#' + item.expense_id}}</text>
          <text wx:if="{{item.isOverdue}}" class="overdue-badge">逾期 {{item.overdueDays}} 天</text>
        </view>
        <view class="ledger-body">
          <text class="ledger-amount">¥ {{item.amount}}</text>
          <text class="ledger-emp">{{item.employee_name || '员工#' + item.employee_id}}</text>
        </view>
        <view class="ledger-bottom">
          <text class="ledger-date">截止: {{item.deadline || '--'}}</text>
          <view class="btn-remind" data-id="{{item.id}}" bindtap="sendReminder">催票</view>
        </view>
      </view>
    </view>
  </view>
</view>

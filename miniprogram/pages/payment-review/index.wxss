.page-container { padding: 24rpx; background: #0a0a0a; min-height: 100vh; }
.filter-tabs { display: flex; gap: 12rpx; margin-bottom: 24rpx; overflow-x: auto; }
.tab { padding: 12rpx 24rpx; font-size: 26rpx; color: #888; background: rgba(255,255,255,0.05); border-radius: 8rpx; flex-shrink: 0; }
.tab.active { background: #C9A84C; color: #000; font-weight: bold; }
.loading-hint, .empty-hint { text-align: center; color: #666; font-size: 28rpx; padding: 120rpx 0; }

.payment-card { background: rgba(255,255,255,0.05); border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; }
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.type-badge { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 6rpx; font-weight: bold; }
.type-A { background: rgba(16,185,129,0.2); color: #10B981; }
.type-B { background: rgba(59,130,246,0.2); color: #3B82F6; }
.type-C { background: rgba(245,158,11,0.2); color: #F59E0B; }
.status-badge { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 6rpx; }
.status-pending { background: rgba(251,191,36,0.2); color: #FBB024; }
.status-approved { background: rgba(59,130,246,0.2); color: #3B82F6; }
.status-completed { background: rgba(16,185,129,0.2); color: #10B981; }
.status-rejected { background: rgba(239,68,68,0.2); color: #EF4444; }

.card-body { }
.applicant { font-size: 26rpx; color: #aaa; display: block; margin-bottom: 4rpx; }
.supplier { font-size: 30rpx; color: #fff; font-weight: bold; display: block; margin-bottom: 4rpx; }
.purpose { font-size: 26rpx; color: #888; display: block; margin-bottom: 12rpx; }
.card-meta { display: flex; justify-content: space-between; align-items: center; }
.amount { font-size: 36rpx; color: #C9A84C; font-weight: bold; }
.date { font-size: 24rpx; color: #666; }

.installment-detail { margin-top: 12rpx; padding: 12rpx 16rpx; background: rgba(255,255,255,0.03); border-radius: 8rpx; }
.inst-row { font-size: 24rpx; color: #aaa; padding: 4rpx 0; }
.invoice-info { margin-top: 8rpx; font-size: 24rpx; color: #888; }
.invoice-preview { margin-top: 12rpx; }
.invoice-img { width: 100%; height: 240rpx; border-radius: 8rpx; }

.action-bar { display: flex; gap: 16rpx; margin-top: 20rpx; padding-top: 20rpx; border-top: 1rpx solid rgba(255,255,255,0.08); }
.btn-reject { flex: 1; height: 80rpx; line-height: 80rpx; background: rgba(239,68,68,0.15); color: #EF4444; font-size: 28rpx; border-radius: 10rpx; text-align: center; border: none; }
.btn-approve { flex: 1; height: 80rpx; line-height: 80rpx; background: #C9A84C; color: #000; font-size: 28rpx; font-weight: bold; border-radius: 10rpx; text-align: center; border: none; }
.btn-complete { flex: 1; height: 80rpx; line-height: 80rpx; background: rgba(16,185,129,0.2); color: #10B981; font-size: 28rpx; font-weight: bold; border-radius: 10rpx; text-align: center; border: none; }

/* 成本分类标签 */
.cost-category-tag { margin-top: 8rpx; font-size: 24rpx; color: #C9A84C; padding: 6rpx 12rpx; background: rgba(201,168,76,0.1); border-radius: 6rpx; display: inline-block; }

/* 成本分类弹窗 */
.modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); z-index: 999; display: flex; align-items: center; justify-content: center; }
.modal-content { width: 88%; max-width: 640rpx; background: #1A1A1A; border-radius: 20rpx; padding: 36rpx 32rpx; border: 1rpx solid rgba(201,168,76,0.2); }
.modal-title { font-size: 34rpx; color: #F0F0F0; font-weight: 700; display: block; margin-bottom: 8rpx; }
.modal-subtitle { font-size: 24rpx; color: #888; display: block; margin-bottom: 24rpx; }

.cost-category-grid { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 24rpx; }
.cost-cat-item { padding: 14rpx 24rpx; font-size: 26rpx; color: #aaa; background: rgba(255,255,255,0.05); border-radius: 10rpx; border: 1rpx solid transparent; }
.cost-cat-item.selected { background: rgba(201,168,76,0.15); color: #C9A84C; border-color: rgba(201,168,76,0.4); font-weight: 600; }

.owes-invoice-hint { display: flex; align-items: flex-start; gap: 8rpx; padding: 16rpx; background: rgba(245,158,11,0.08); border-radius: 10rpx; margin-bottom: 20rpx; }
.hint-icon { font-size: 28rpx; flex-shrink: 0; }
.hint-text { font-size: 24rpx; color: #F59E0B; line-height: 1.5; }

.modal-actions { display: flex; gap: 16rpx; }
.btn-cancel { flex: 1; height: 80rpx; line-height: 80rpx; background: rgba(255,255,255,0.05); color: #888; font-size: 28rpx; border-radius: 10rpx; text-align: center; border: none; }
.btn-confirm { flex: 1; height: 80rpx; line-height: 80rpx; background: #C9A84C; color: #000; font-size: 28rpx; font-weight: bold; border-radius: 10rpx; text-align: center; border: none; }
.btn-disabled { opacity: 0.4; }

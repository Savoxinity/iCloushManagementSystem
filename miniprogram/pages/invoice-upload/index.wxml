<!-- 发票上传页 — OCR 自动识别 + 可编辑确认 -->
<view class="page-container">
  <!-- 图片区域 -->
  <view class="upload-area" bindtap="{{imageUrl || tempPath ? 'previewImage' : 'chooseInvoice'}}">
    <block wx:if="{{tempPath || imageUrl}}">
      <image src="{{imageUrl || tempPath}}" mode="aspectFit" class="preview-img" />
      <view class="upload-hint" bindtap="chooseInvoice">点击重新选择</view>
    </block>
    <block wx:else>
      <view class="upload-placeholder">
        <text class="upload-icon">🧾</text>
        <text class="upload-text">点击拍照或从相册选择发票</text>
      </view>
    </block>
    <view wx:if="{{uploading}}" class="upload-loading">
      <text>上传中...</text>
    </view>
  </view>

  <!-- OCR 识别状态提示 -->
  <view wx:if="{{ocrLoading}}" class="ocr-status ocr-loading">
    <text class="ocr-icon">🔍</text>
    <text>正在识别发票信息...</text>
  </view>
  <view wx:elif="{{ocrAvailable}}" class="ocr-status ocr-success">
    <text class="ocr-icon">✅</text>
    <text>OCR 识别完成，请确认以下信息</text>
  </view>

  <!-- OCR 结果 / 手动填写区 -->
  <view class="form-section" wx:if="{{imageUrl}}">
    <view class="section-title">发票信息{{ocrAvailable ? '（OCR已识别，可修改）' : '（请手动填写）'}}</view>
    <view wx:for="{{ocrFields}}" wx:key="key" class="form-item">
      <text class="label">{{item.label}}</text>
      <input class="input {{item.value ? 'input-filled' : ''}}"
             placeholder="{{item.label}}"
             value="{{item.value}}"
             data-idx="{{index}}"
             bindinput="onFieldInput" />
    </view>
  </view>

  <!-- 货物/服务明细条目 -->
  <view class="form-section" wx:if="{{ocrItems.length > 0}}">
    <view class="section-title">货物/服务明细（{{ocrItems.length}}项）</view>
    <view class="items-table">
      <!-- 表头 -->
      <view class="item-header">
        <text class="item-col-name">项目名称</text>
        <text class="item-col-spec">规格型号</text>
        <text class="item-col-qty">数量</text>
        <text class="item-col-price">单价</text>
        <text class="item-col-amount">金额</text>
        <text class="item-col-tax">税率</text>
        <text class="item-col-tax-amt">税额</text>
      </view>
      <!-- 明细行 -->
      <view class="item-row" wx:for="{{ocrItems}}" wx:key="index">
        <text class="item-col-name item-name-text">{{item.name || '--'}}</text>
        <text class="item-col-spec">{{item.spec || '--'}}</text>
        <text class="item-col-qty">{{item.quantity || '--'}}</text>
        <text class="item-col-price">{{item.unit_price || '--'}}</text>
        <text class="item-col-amount">{{item.amount_without_tax || '--'}}</text>
        <text class="item-col-tax">{{item.tax_rate || '--'}}</text>
        <text class="item-col-tax-amt">{{item.tax_amount || '--'}}</text>
      </view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="btn-area">
    <button class="btn-submit {{submitDisabled || submitting || ocrLoading ? 'btn-disabled' : ''}}"
            disabled="{{submitDisabled || submitting || ocrLoading}}"
            bindtap="submitInvoice">
      {{submitting ? '提交中...' : '提交发票'}}
    </button>
  </view>
</view>

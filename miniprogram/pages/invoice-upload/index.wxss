.page-container { padding: 24rpx; background: #0a0a0a; min-height: 100vh; }
.upload-area { position: relative; width: 100%; min-height: 400rpx; border: 2rpx dashed rgba(201,168,76,0.4); border-radius: 12rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; margin-bottom: 32rpx; overflow: hidden; }
.preview-img { width: 100%; height: 400rpx; }
.upload-hint { font-size: 24rpx; color: #C9A84C; padding: 16rpx 0; text-align: center; }
.upload-placeholder { display: flex; flex-direction: column; align-items: center; padding: 60rpx 0; }
.upload-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.upload-text { font-size: 28rpx; color: #888; }
.upload-loading { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.6); display: flex; align-items: center; justify-content: center; color: #C9A84C; font-size: 28rpx; }

/* OCR 状态提示 */
.ocr-status { display: flex; align-items: center; padding: 20rpx 24rpx; border-radius: 12rpx; margin-bottom: 24rpx; font-size: 26rpx; }
.ocr-icon { margin-right: 12rpx; font-size: 32rpx; }
.ocr-loading { background: rgba(201,168,76,0.1); color: #C9A84C; }
.ocr-success { background: rgba(76,201,100,0.1); color: #4cc964; }

.form-section { background: rgba(255,255,255,0.05); border-radius: 12rpx; padding: 24rpx; margin-bottom: 32rpx; }
.section-title { font-size: 28rpx; color: #C9A84C; margin-bottom: 24rpx; font-weight: bold; }
.form-item { display: flex; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.08); }
.form-item:last-child { border-bottom: none; }
.label { font-size: 26rpx; color: #aaa; width: 160rpx; flex-shrink: 0; }
.input { flex: 1; font-size: 28rpx; color: #fff; text-align: right; }
.input-filled { color: #C9A84C; }
.btn-area { padding: 32rpx 0; }
.btn-submit { width: 100%; height: 88rpx; line-height: 88rpx; background: #C9A84C; color: #000; font-size: 32rpx; font-weight: bold; border-radius: 12rpx; text-align: center; }
.btn-disabled { opacity: 0.4; }

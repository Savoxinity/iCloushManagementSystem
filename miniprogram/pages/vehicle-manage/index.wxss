/* 车队管理 — Phase 4 机动物流中台 — 品牌黑橙配色 */

.page-container {
  min-height: 100vh;
  background: #0a0a0a;
  padding-bottom: 120rpx;
}

/* ── 标签栏 ── */
.tab-bar {
  display: flex;
  background: #111;
  border-bottom: 1rpx solid rgba(201,168,76,0.2);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #888;
  position: relative;
}

.tab-item.active {
  color: #C9A84C;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 30%;
  width: 40%;
  height: 4rpx;
  background: #C9A84C;
  border-radius: 2rpx;
}

.badge {
  position: absolute;
  top: 12rpx;
  right: 25%;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  background: #EF4444;
  color: #fff;
  font-size: 20rpx;
  border-radius: 16rpx;
  padding: 0 8rpx;
}

/* ── 筛选栏 ── */
.filter-bar {
  display: flex;
  padding: 20rpx 24rpx;
  gap: 16rpx;
  background: #111;
  margin-bottom: 16rpx;
}

.filter-item {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #888;
  background: rgba(255,255,255,0.06);
  border-radius: 24rpx;
}

.filter-item.active {
  background: rgba(201,168,76,0.2);
  color: #C9A84C;
  font-weight: 500;
}

/* ── 加载与空状态 ── */
.loading-box, .empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #666;
  font-size: 28rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(255,255,255,0.1);
  border-top-color: #C9A84C;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

/* ── 车辆卡片 ── */
.vehicle-list {
  padding: 0 24rpx;
}

.vehicle-card {
  background: rgba(255,255,255,0.05);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(201,168,76,0.1);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.plate-number {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.plate-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.vehicle-type {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  color: #fff;
}

.type-large { background: #7c3aed; }
.type-medium { background: #C9A84C; }
.type-small { background: #059669; }

.status-tag {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.status-idle { background: rgba(0,255,136,0.1); color: #00FF88; }
.status-delivering { background: rgba(201,168,76,0.15); color: #C9A84C; }
.status-maintenance { background: rgba(239,68,68,0.15); color: #EF4444; }

.card-body {
  padding: 20rpx 28rpx;
  display: flex;
  gap: 20rpx;
}

.info-row {
  flex: 1;
}

.info-label {
  font-size: 22rpx;
  color: #666;
  display: block;
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 26rpx;
  color: #ccc;
  font-weight: 500;
}

/* ── 预警条 ── */
.alert-strip {
  padding: 12rpx 28rpx 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.alert-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.alert-expired { background: rgba(239,68,68,0.15); color: #EF4444; }
.alert-urgent { background: rgba(245,158,11,0.15); color: #F59E0B; }
.alert-warning { background: rgba(59,130,246,0.15); color: #60A5FA; }

/* ── 预警中心 ── */
.alerts-section {
  padding: 0 24rpx;
}

.alert-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
}

.alert-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #C9A84C;
}

.days-picker {
  font-size: 24rpx;
  color: #C9A84C;
  padding: 8rpx 16rpx;
  background: rgba(201,168,76,0.15);
  border-radius: 8rpx;
}

.alert-card {
  background: rgba(255,255,255,0.05);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(201,168,76,0.1);
}

.alert-card-header {
  padding: 20rpx 28rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.alert-plate {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.alert-brand {
  font-size: 24rpx;
  color: #666;
}

.alert-items {
  padding: 12rpx 28rpx 20rpx;
}

.alert-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.04);
}

.alert-item:last-child {
  border-bottom: none;
}

.alert-icon {
  width: 48rpx;
  font-size: 28rpx;
}

.alert-info {
  flex: 1;
}

.alert-name {
  font-size: 26rpx;
  color: #ccc;
  display: block;
}

.alert-date {
  font-size: 22rpx;
  color: #666;
}

.alert-days {
  font-size: 24rpx;
  font-weight: 600;
  text-align: right;
}

.alert-days.expired { color: #EF4444; }
.alert-days.urgent { color: #F59E0B; }
.alert-days.warning { color: #60A5FA; }

/* ── 底部操作栏 ── */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #111;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.3);
}

.btn-add {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #C9A84C, #8B7333);
  color: #000;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
}

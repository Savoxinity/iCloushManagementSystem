/* 车队管理 — Phase 4 机动物流中台 */

.page-container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 120rpx;
}

/* ── 标签栏 ── */
.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #1a73e8;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 30%;
  width: 40%;
  height: 4rpx;
  background: #1a73e8;
  border-radius: 2rpx;
}

.badge {
  position: absolute;
  top: 12rpx;
  right: 25%;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  background: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  border-radius: 16rpx;
  padding: 0 8rpx;
}

/* ── 筛选栏 ── */
.filter-bar {
  display: flex;
  padding: 20rpx 24rpx;
  gap: 16rpx;
  background: #fff;
  margin-bottom: 16rpx;
}

.filter-item {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #666;
  background: #f0f2f5;
  border-radius: 24rpx;
}

.filter-item.active {
  background: #e6f0ff;
  color: #1a73e8;
  font-weight: 500;
}

/* ── 加载与空状态 ── */
.loading-box, .empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #1a73e8;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

/* ── 车辆卡片 ── */
.vehicle-list {
  padding: 0 24rpx;
}

.vehicle-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.plate-number {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.plate-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  letter-spacing: 2rpx;
}

.vehicle-type {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  color: #fff;
}

.type-large { background: #7c3aed; }
.type-medium { background: #2563eb; }
.type-small { background: #059669; }

.status-tag {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.status-idle { background: #e6f7e6; color: #16a34a; }
.status-delivering { background: #fff7e6; color: #d97706; }
.status-maintenance { background: #fee2e2; color: #dc2626; }

.card-body {
  padding: 20rpx 28rpx;
  display: flex;
  gap: 20rpx;
}

.info-row {
  flex: 1;
}

.info-label {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

/* ── 预警条 ── */
.alert-strip {
  padding: 12rpx 28rpx 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.alert-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.alert-expired { background: #fee2e2; color: #dc2626; }
.alert-urgent { background: #fef3c7; color: #d97706; }
.alert-warning { background: #e0f2fe; color: #0284c7; }

/* ── 预警中心 ── */
.alerts-section {
  padding: 0 24rpx;
}

.alert-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
}

.alert-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.days-picker {
  font-size: 24rpx;
  color: #1a73e8;
  padding: 8rpx 16rpx;
  background: #e6f0ff;
  border-radius: 8rpx;
}

.alert-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.alert-card-header {
  padding: 20rpx 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.alert-plate {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.alert-brand {
  font-size: 24rpx;
  color: #999;
}

.alert-items {
  padding: 12rpx 28rpx 20rpx;
}

.alert-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.alert-item:last-child {
  border-bottom: none;
}

.alert-icon {
  width: 48rpx;
  font-size: 28rpx;
}

.alert-info {
  flex: 1;
}

.alert-name {
  font-size: 26rpx;
  color: #333;
  display: block;
}

.alert-date {
  font-size: 22rpx;
  color: #999;
}

.alert-days {
  font-size: 24rpx;
  font-weight: 600;
  text-align: right;
}

.alert-days.expired { color: #dc2626; }
.alert-days.urgent { color: #d97706; }
.alert-days.warning { color: #0284c7; }

/* ── 底部操作栏 ── */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}

.btn-add {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #1a73e8, #4a90d9);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
}

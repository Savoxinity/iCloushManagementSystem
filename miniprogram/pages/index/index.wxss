/* ============================================
   总览页样式 — 工业暗黑科技风
   ============================================ */

.page-container {
  background: #0A0A0A;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

/* ===== 顶部导航栏 ===== */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx 16rpx;
  background: linear-gradient(180deg, #111111 0%, #0A0A0A 100%);
  border-bottom: 1rpx solid #1E1E1E;
}

.top-bar-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.logo {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
}

.brand-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #C9A84C;
  letter-spacing: 2rpx;
}

.date-text {
  display: block;
  font-size: 20rpx;
  color: #666666;
  margin-top: 2rpx;
}

.alert-badge {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #1A1A1A;
  border: 1rpx solid #2A2A2A;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.alert-badge.has-alert {
  border-color: rgba(239, 68, 68, 0.5);
  background: rgba(239, 68, 68, 0.1);
}

.alert-icon {
  font-size: 28rpx;
  color: #888888;
}

.has-alert .alert-icon {
  color: #EF4444;
}

.alert-num {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  background: #EF4444;
  color: #fff;
  font-size: 18rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
}

/* ===== 今日数据大盘 ===== */
.stats-row {
  display: flex;
  padding: 20rpx 24rpx;
  gap: 8rpx;
  background: #0F0F0F;
  border-bottom: 1rpx solid #1A1A1A;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 8rpx;
  background: #141414;
  border-radius: 12rpx;
  border: 1rpx solid #1E1E1E;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  font-family: 'Courier New', monospace;
  line-height: 1;
}

.stat-value.gold { color: #C9A84C; }
.stat-value.green { color: #00FF88; }
.stat-value.blue { color: #3B82F6; }
.stat-value.orange { color: #F59E0B; }
.stat-value.red { color: #EF4444; }

.stat-label {
  font-size: 18rpx;
  color: #666666;
  margin-top: 6rpx;
  text-align: center;
}

/* ===== 通用 Section ===== */
.factory-section,
.schedule-section,
.task-section {
  margin: 20rpx 24rpx 0;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #F0F0F0;
  letter-spacing: 1rpx;
}

.section-action {
  padding: 8rpx 0;
}

.action-text {
  font-size: 24rpx;
  color: #C9A84C;
}

/* ===== 楼层切换 ===== */
.floor-tabs {
  display: flex;
  background: #141414;
  border-radius: 20rpx;
  padding: 4rpx;
  border: 1rpx solid #1E1E1E;
}

.floor-tab {
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #666666;
  transition: all 0.2s;
}

.floor-tab.active {
  background: #C9A84C;
  color: #000000;
  font-weight: 600;
}

/* ===== 2.5D 工厂沙盘（底图 + 热区叠加） ===== */
.factory-map-25d {
  position: relative;
  width: 100%;
  border-radius: 16rpx;
  border: 1rpx solid #1E1E1E;
  overflow: hidden;
  background: #0A0E14;
}

.factory-scroll-25d {
  width: 100%;
  height: 480rpx;
}

.factory-canvas-25d {
  position: relative;
}

.factory-bg-img {
  display: block;
}

/* 楼层标签 */
.floor-label-25d {
  position: absolute;
  top: 12rpx;
  left: 16rpx;
  background: rgba(10, 14, 20, 0.85);
  border: 1rpx solid rgba(201, 168, 76, 0.3);
  border-radius: 20rpx;
  padding: 6rpx 16rpx;
  z-index: 10;
}

.floor-label-text {
  font-size: 20rpx;
  color: #C9A84C;
  font-family: 'Courier New', monospace;
}

/* 缩放提示 */
.pinch-hint {
  position: absolute;
  bottom: 16rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(10, 14, 20, 0.85);
  border: 1rpx solid rgba(201, 168, 76, 0.2);
  border-radius: 20rpx;
  padding: 8rpx 24rpx;
  z-index: 10;
}

.pinch-hint-text {
  font-size: 20rpx;
  color: rgba(201, 168, 76, 0.6);
  font-family: 'Courier New', monospace;
}

/* 工区热区（叠加在底图上） */
.zone-hotspot-25d {
  position: absolute;
  border: 2rpx solid;
  border-radius: 8rpx;
  background: rgba(0, 0, 0, 0.25);
  z-index: 5;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  /* 防误触：内边距确保点击区域不会贴边 */
  padding: 4rpx;
  box-sizing: border-box;
}

/* 点击高亮反馈 */
.zone-hotspot-25d.zone-tapped {
  background: rgba(201, 168, 76, 0.25) !important;
  border-width: 3rpx;
  box-shadow: 0 0 20rpx rgba(201, 168, 76, 0.4);
}

/* 热区名称标签（工区左上角） */
.zone-label-25d {
  display: inline-flex;
  align-items: center;
  padding: 3rpx 10rpx;
  border-radius: 6rpx;
  align-self: flex-start;
}

.zone-label-name {
  font-size: 18rpx;
  color: #FFFFFF;
  font-weight: 700;
  text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.5);
}

/* 人员摘要徽章 */
.zone-info-25d {
  display: flex;
  align-self: flex-end;
}

.zone-staff-badge {
  font-size: 18rpx;
  color: #F0F0F0;
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
  border: 1rpx solid;
  font-family: 'Courier New', monospace;
}

/* 告警闪烁 */
.zone-alert-25d {
  border-color: #EF4444 !important;
}

.alert-overlay-25d {
  position: absolute;
  inset: 0;
  background: rgba(239, 68, 68, 0.15);
  border-radius: 8rpx;
  pointer-events: none;
}

@keyframes alertPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.15; }
}

.alert-pulse {
  animation: alertPulse 1.5s ease-in-out infinite;
}

.factory-empty-25d {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #444444;
  font-size: 26rpx;
}

/* ===== 排班沙盘 ===== */
.unassigned-pool {
  background: #141414;
  border-radius: 12rpx;
  border: 1rpx solid #1E1E1E;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.pool-label {
  font-size: 22rpx;
  color: #888888;
  margin-bottom: 12rpx;
  display: block;
}

.pool-scroll {
  white-space: nowrap;
}

.pool-inner {
  display: flex;
  gap: 16rpx;
  padding-bottom: 4rpx;
}

.staff-card-mini {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 16rpx;
  background: #1A1A1A;
  border-radius: 12rpx;
  border: 1rpx solid #2A2A2A;
  min-width: 100rpx;
}

.avatar-circle {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-initial {
  font-size: 28rpx;
  font-weight: 700;
  color: #000000;
}

.staff-name-mini {
  font-size: 20rpx;
  color: #CCCCCC;
  text-align: center;
}

.skill-dots {
  display: flex;
  gap: 4rpx;
}

.skill-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #C9A84C;
  opacity: 0.6;
}

.pool-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 200rpx;
  color: #555555;
  font-size: 24rpx;
}

/* 工区排班格 */
.zone-slots {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.zone-slot-card {
  background: #141414;
  border-radius: 12rpx;
  border: 1rpx solid #1E1E1E;
  padding: 16rpx;
}

.slot-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.slot-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.slot-zone-name {
  flex: 1;
  font-size: 24rpx;
  color: #F0F0F0;
  font-weight: 600;
}

.slot-count {
  font-size: 20rpx;
  color: #888888;
  font-family: 'Courier New', monospace;
}

.slot-staff-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.slot-staff-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #1A1A1A;
  border-radius: 30rpx;
  padding: 8rpx 16rpx 8rpx 8rpx;
  border: 1rpx solid #2A2A2A;
}

.chip-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chip-initial {
  font-size: 18rpx;
  font-weight: 700;
  color: #000000;
}

.chip-name {
  font-size: 22rpx;
  color: #CCCCCC;
}

.slot-empty-hint {
  font-size: 20rpx;
  color: #444444;
  padding: 8rpx 0;
}

/* ===== 任务快览 ===== */
.task-progress-bar-wrap {
  background: #141414;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid #1E1E1E;
}

.task-progress-labels {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.progress-label {
  font-size: 22rpx;
  color: #888888;
}

.progress-value {
  font-size: 22rpx;
  color: #C9A84C;
  font-family: 'Courier New', monospace;
}

.task-progress-track {
  height: 8rpx;
  background: #1E1E1E;
  border-radius: 4rpx;
  overflow: hidden;
}

.task-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #C9A84C, #F0C060);
  border-radius: 4rpx;
  transition: width 0.5s ease;
}

.task-status-row {
  display: flex;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.task-status-chip {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 8rpx;
  border-radius: 10rpx;
  border: 1rpx solid;
}

.chip-pending  { background: rgba(107, 114, 128, 0.1); border-color: rgba(107, 114, 128, 0.2); }
.chip-running  { background: rgba(59, 130, 246, 0.1);  border-color: rgba(59, 130, 246, 0.2);  }
.chip-reviewing{ background: rgba(245, 158, 11, 0.1);  border-color: rgba(245, 158, 11, 0.2);  }
.chip-done     { background: rgba(0, 255, 136, 0.1);   border-color: rgba(0, 255, 136, 0.2);   }

.chip-num {
  font-size: 32rpx;
  font-weight: 700;
  font-family: 'Courier New', monospace;
}

.chip-pending  .chip-num { color: #9CA3AF; }
.chip-running  .chip-num { color: #3B82F6; }
.chip-reviewing .chip-num { color: #F59E0B; }
.chip-done     .chip-num { color: #00FF88; }

.chip-txt {
  font-size: 18rpx;
  color: #666666;
  margin-top: 4rpx;
}

/* 任务列表项 */
.task-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #141414;
  border-radius: 12rpx;
  border: 1rpx solid #1E1E1E;
  padding: 16rpx;
  margin-bottom: 10rpx;
}

.task-item-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.task-priority-bar {
  width: 6rpx;
  height: 60rpx;
  border-radius: 3rpx;
  flex-shrink: 0;
}

.priority-1 { background: #6B7280; }
.priority-2 { background: #3B82F6; }
.priority-3 { background: #F59E0B; }
.priority-4 { background: #EF4444; }

.task-info {
  flex: 1;
  min-width: 0;
}

.task-title {
  display: block;
  font-size: 26rpx;
  color: #F0F0F0;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-meta {
  display: flex;
  gap: 12rpx;
  margin-top: 6rpx;
}

.task-zone {
  font-size: 20rpx;
  color: #888888;
}

.task-deadline {
  font-size: 20rpx;
  color: #F59E0B;
}

.task-item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  flex-shrink: 0;
}

.task-status-tag {
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-size: 18rpx;
}

.status-0 { background: rgba(107, 114, 128, 0.15); color: #9CA3AF; }
.status-1 { background: rgba(59, 130, 246, 0.15);  color: #3B82F6; }
.status-2 { background: rgba(59, 130, 246, 0.15);  color: #3B82F6; }
.status-3 { background: rgba(245, 158, 11, 0.15);  color: #F59E0B; }
.status-4 { background: rgba(0, 255, 136, 0.15);   color: #00FF88; }
.status-5 { background: rgba(239, 68, 68, 0.15);   color: #EF4444; }

.task-points {
  font-size: 20rpx;
  color: #C9A84C;
  font-family: 'Courier New', monospace;
}

/* ===== 工区半屏浮窗 ===== */
.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 100;
}

.zone-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #111111;
  border-radius: 24rpx 24rpx 0 0;
  border-top: 1rpx solid #2A2A2A;
  z-index: 101;
  padding: 0 0 env(safe-area-inset-bottom);
  transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
}

.sheet-show { transform: translateY(0); }
.sheet-hide { transform: translateY(100%); }

.sheet-handle {
  width: 60rpx;
  height: 6rpx;
  background: #333333;
  border-radius: 3rpx;
  margin: 16rpx auto 0;
  flex-shrink: 0;
}

.sheet-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 32rpx 16rpx;
  flex-shrink: 0;
}

.sheet-zone-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.sheet-title-group {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.sheet-zone-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #F0F0F0;
}

.sheet-status-tag {
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
}

.tag-running  { background: rgba(0, 255, 136, 0.15); color: #00FF88; }
.tag-idle     { background: rgba(107, 114, 128, 0.15); color: #9CA3AF; }
.tag-alert    { background: rgba(239, 68, 68, 0.15); color: #EF4444; }
.tag-offline  { background: rgba(85, 85, 85, 0.15); color: #555555; }

.sheet-close {
  font-size: 28rpx;
  color: #666666;
  padding: 8rpx;
}

.sheet-stats {
  display: flex;
  padding: 0 32rpx 16rpx;
  gap: 0;
  flex-shrink: 0;
}

.sheet-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
  border-right: 1rpx solid #1E1E1E;
}

.sheet-stat:last-child {
  border-right: none;
}

.sheet-stat-value {
  font-size: 40rpx;
  font-weight: 700;
  font-family: 'Courier New', monospace;
}

.sheet-stat-label {
  font-size: 20rpx;
  color: #666666;
  margin-top: 4rpx;
}

.sheet-divider {
  height: 1rpx;
  background: #1E1E1E;
  margin: 0 32rpx;
  flex-shrink: 0;
}

.sheet-list {
  flex: 1;
  padding: 16rpx 20rpx;
  max-height: 360rpx;
  box-sizing: border-box;
  width: 100%;
}

.sheet-item-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 12rpx;
  background: #141414;
  border-radius: 12rpx;
  border: 1rpx solid #1E1E1E;
  margin-bottom: 10rpx;
  overflow: hidden;
  box-sizing: border-box;
  width: 100%;
  gap: 8rpx;
}

.sheet-item-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: 1 1 0;
  min-width: 0;
  overflow: hidden;
  max-width: calc(100% - 180rpx);
}

.sheet-item-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.sheet-item-icon {
  font-size: 28rpx;
}

.sheet-item-info {
  flex: 1;
  min-width: 0;
}

.sheet-item-name {
  display: block;
  font-size: 26rpx;
  color: #F0F0F0;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sheet-item-sub {
  display: block;
  font-size: 20rpx;
  color: #888888;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sheet-item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
  flex-shrink: 0;
  min-width: 120rpx;
  max-width: 170rpx;
}

.sheet-item-status {
  padding: 4rpx 10rpx;
  border-radius: 20rpx;
  font-size: 18rpx;
  white-space: nowrap;
}

.sheet-item-value {
  font-size: 20rpx;
  color: #C9A84C;
  font-family: 'Courier New', monospace;
  white-space: nowrap;
}

.sheet-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
  color: #444444;
  font-size: 26rpx;
}

.sheet-footer {
  padding: 16rpx 32rpx 24rpx;
  flex-shrink: 0;
}

.sheet-detail-btn {
  width: 100%;
  height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  background: #C9A84C;
  color: #000000;
  border-radius: 16rpx;
  border: none;
}

.sheet-detail-btn::after { border: none; }

/* ===== 员工分配弹窗 ===== */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 200;
}

.assign-modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: #141414;
  border-radius: 20rpx;
  border: 1rpx solid #2A2A2A;
  padding: 32rpx;
  z-index: 201;
}

.modal-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #F0F0F0;
  margin-bottom: 24rpx;
  text-align: center;
}

.modal-zone-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.modal-zone-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  background: #1A1A1A;
  border-radius: 12rpx;
  border: 1rpx solid #2A2A2A;
}

.modal-zone-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.modal-zone-name {
  flex: 1;
  font-size: 26rpx;
  color: #F0F0F0;
}

.modal-zone-count {
  font-size: 22rpx;
  color: #888888;
  font-family: 'Courier New', monospace;
}

.modal-cancel {
  width: 100%;
  height: 80rpx;
  background: #1A1A1A;
  color: #888888;
  border-radius: 12rpx;
  font-size: 26rpx;
  border: 1rpx solid #2A2A2A;
}

.modal-cancel::after { border: none; }

.safe-bottom {
  height: env(safe-area-inset-bottom);
}


/* ===== ★ 移动工区选择弹窗（长按触发） ===== */
.move-modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.75);
  z-index: 300;
  display: flex;
  align-items: flex-end;
}

.move-modal-box {
  width: 100%;
  background: #141414;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 24rpx;
  max-height: 70vh;
  overflow-y: auto;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.move-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.move-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #F0F0F0;
}

.move-close-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #1A1A1A;
  display: flex;
  align-items: center;
  justify-content: center;
}

.move-close-btn text {
  font-size: 28rpx;
  color: #888888;
}

.move-zone-list {
  max-height: 50vh;
}

.move-option {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 16rpx;
  margin-bottom: 8rpx;
  background: #1A1A1A;
  border-radius: 14rpx;
  border: 1rpx solid #252525;
  transition: all 0.15s;
}

.move-option:active {
  background: rgba(201, 168, 76, 0.12);
  border-color: rgba(201, 168, 76, 0.4);
}

.move-option.current {
  opacity: 0.4;
  border-color: #333333;
}

.move-option.full {
  opacity: 0.35;
}

.move-option-unassign {
  background: rgba(239, 68, 68, 0.08);
  border: 1rpx solid rgba(239, 68, 68, 0.2);
  margin-bottom: 16rpx;
}

.move-option-unassign:active {
  background: rgba(239, 68, 68, 0.15);
}

.move-opt-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.unassign-icon {
  background: rgba(239, 68, 68, 0.15);
  color: #EF4444;
}

.move-opt-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.move-opt-info {
  flex: 1;
}

.move-opt-name {
  display: block;
  font-size: 28rpx;
  color: #F0F0F0;
}

.move-opt-count {
  display: block;
  font-size: 20rpx;
  color: #888888;
  margin-top: 4rpx;
}

.move-opt-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.current-badge {
  background: rgba(107, 114, 128, 0.15);
  color: #9CA3AF;
}

.full-badge {
  background: rgba(239, 68, 68, 0.1);
  color: #EF4444;
}

.move-opt-arrow {
  font-size: 32rpx;
  color: #C9A84C;
}

/* ===== V7 员工版样式 ===== */
.staff-mode-badge {
  background: rgba(59,130,246,0.15);
  border: 1rpx solid rgba(59,130,246,0.3);
  border-radius: 16rpx;
  padding: 4rpx 16rpx;
}
.staff-mode-text {
  font-size: 20rpx;
  color: #3B82F6;
  font-weight: 600;
}

/* 我的今日排班 */
.my-schedule-section {
  margin: 20rpx 24rpx 0;
}
.my-schedule-card {
  display: flex;
  background: #141414;
  border-radius: 16rpx;
  border: 1rpx solid #1E1E1E;
  overflow: hidden;
  margin-top: 12rpx;
}
.my-zone-indicator {
  width: 8rpx;
  flex-shrink: 0;
}
.my-zone-info {
  flex: 1;
  padding: 20rpx 24rpx;
}
.my-zone-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #F0F0F0;
  display: block;
  margin-bottom: 12rpx;
}
.my-coworkers {
  margin-top: 8rpx;
}
.coworker-label {
  font-size: 22rpx;
  color: #888;
  display: block;
  margin-bottom: 8rpx;
}
.coworker-avatars {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.coworker-chip {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: #1A1A1A;
  border-radius: 20rpx;
  padding: 6rpx 12rpx 6rpx 6rpx;
}
.coworker-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.coworker-initial {
  font-size: 18rpx;
  font-weight: 700;
  color: #fff;
}
.coworker-name {
  font-size: 22rpx;
  color: #CCC;
}
.no-coworker-hint {
  font-size: 22rpx;
  color: #555;
  margin-top: 4rpx;
}

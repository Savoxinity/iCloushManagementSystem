/* 车辆详情 — Phase 4.1 */

.page-container {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 24rpx;
  padding-bottom: 60rpx;
}

/* ── 加载 ── */
.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #1a73e8;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin { to { transform: rotate(360deg); } }

/* ── 头部卡片 ── */
.hero-card {
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  color: #fff;
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.plate-big {
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
}

.status-tag {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  font-weight: 500;
}

.status-idle { background: rgba(22,163,74,0.2); color: #4ade80; }
.status-delivering { background: rgba(217,119,6,0.2); color: #fbbf24; }
.status-maintenance { background: rgba(220,38,38,0.2); color: #f87171; }
.status-retired { background: rgba(107,114,128,0.2); color: #9ca3af; }

.change-hint {
  font-size: 20rpx;
  opacity: 0.7;
}

.hero-sub {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.type-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  color: #fff;
}

.type-large { background: #7c3aed; }
.type-medium { background: #2563eb; }
.type-small { background: #059669; }

.brand-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
}

/* ── 信息分区 ── */
.info-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 20rpx;
}

.info-grid {
  display: flex;
  gap: 16rpx;
}

.info-cell {
  flex: 1;
  background: #f8f9fc;
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
  text-align: center;
}

.cell-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.cell-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

/* ── 四险一金 ── */
.empty-hint {
  font-size: 26rpx;
  color: #bbb;
  text-align: center;
  padding: 40rpx 0;
}

.insurance-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.insurance-row:last-child {
  border-bottom: none;
}

.ins-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.ins-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.ins-dot-expired { background: #dc2626; }
.ins-dot-urgent { background: #d97706; }
.ins-dot-warning { background: #0284c7; }
.ins-dot-safe { background: #16a34a; }

.ins-label {
  display: block;
  font-size: 28rpx;
  color: #333;
}

.ins-date {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.ins-days {
  font-size: 24rpx;
  font-weight: 600;
}

.ins-days-expired { color: #dc2626; }
.ins-days-urgent { color: #d97706; }
.ins-days-warning { color: #0284c7; }
.ins-days-safe { color: #16a34a; }

/* ── 操作按钮 ── */
.action-section {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
}

.btn-edit {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #1a73e8, #4a90d9);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
}

.btn-delete {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #dc2626;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: 2rpx solid #dc2626;
}

/* 车辆详情 — 品牌黑橙配色 + 日历 */

.page-container {
  min-height: 100vh;
  background: #0a0a0a;
  padding: 24rpx;
  padding-bottom: 200rpx;
}

/* ── 加载 ── */
.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #666;
  font-size: 28rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(255,255,255,0.1);
  border-top-color: #C9A84C;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}
.loading-text { color: #888; font-size: 26rpx; }

@keyframes spin { to { transform: rotate(360deg); } }

/* ── 头部卡片 ── */
.hero-card {
  background: linear-gradient(135deg, #1a1a1a, #111);
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  color: #fff;
  border: 1rpx solid rgba(201,168,76,0.2);
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.plate-big {
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  color: #C9A84C;
}

.status-tag {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  font-weight: 500;
}

.status-idle { background: rgba(0,255,136,0.1); color: #00FF88; }
.status-delivering { background: rgba(201,168,76,0.15); color: #C9A84C; }
.status-maintenance { background: rgba(220,38,38,0.15); color: #f87171; }
.status-retired { background: rgba(107,114,128,0.15); color: #9ca3af; }

.change-hint { font-size: 20rpx; opacity: 0.7; }

.hero-sub {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.type-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  color: #fff;
}

.type-large { background: rgba(201,168,76,0.3); color: #C9A84C; }
.type-medium { background: rgba(59,130,246,0.3); color: #60A5FA; }
.type-small { background: rgba(0,255,136,0.2); color: #00FF88; }

.brand-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
}

/* ── 信息分区 ── */
.info-section {
  background: rgba(255,255,255,0.05);
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(201,168,76,0.1);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #C9A84C;
  margin-bottom: 20rpx;
}

.info-grid {
  display: flex;
  gap: 16rpx;
}

.info-cell {
  flex: 1;
  background: rgba(255,255,255,0.04);
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
  text-align: center;
}

.cell-label {
  display: block;
  font-size: 22rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.cell-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

/* ── 四险一金 ── */
.empty-hint {
  font-size: 26rpx;
  color: #555;
  text-align: center;
  padding: 40rpx 0;
}

.insurance-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.insurance-row:last-child { border-bottom: none; }

.ins-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.ins-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.ins-dot-expired { background: #dc2626; }
.ins-dot-urgent { background: #F59E0B; }
.ins-dot-warning { background: #C9A84C; }
.ins-dot-safe { background: #00FF88; }

.ins-label { display: block; font-size: 28rpx; color: #ccc; }
.ins-date { display: block; font-size: 22rpx; color: #666; }
.ins-days { font-size: 24rpx; font-weight: 600; }
.ins-days-expired { color: #dc2626; }
.ins-days-urgent { color: #F59E0B; }
.ins-days-warning { color: #C9A84C; }
.ins-days-safe { color: #00FF88; }

/* ── 日历 ── */
.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.cal-arrow {
  font-size: 28rpx;
  color: #C9A84C;
  padding: 8rpx 20rpx;
}
.cal-month {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}
.cal-weekdays {
  display: flex;
  margin-bottom: 8rpx;
}
.cal-wd {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: #888;
  padding: 8rpx 0;
}
.cal-grid {
  display: flex;
  flex-wrap: wrap;
}
.cal-day {
  width: calc(100% / 7);
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: #ccc;
  border-radius: 8rpx;
  box-sizing: border-box;
}
.cal-day.empty { color: transparent; }
.cal-day.selected {
  background: #C9A84C;
  color: #000;
  font-weight: 700;
}

/* ── 日期详情 ── */
.day-detail {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.08);
}
.day-detail-title {
  font-size: 26rpx;
  color: #C9A84C;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.day-detail-loading { text-align: center; color: #888; font-size: 24rpx; padding: 20rpx; }
.day-detail-empty { text-align: center; color: #666; font-size: 24rpx; padding: 20rpx; }
.dispatch-list { display: flex; flex-direction: column; gap: 16rpx; }
.dispatch-item {
  background: rgba(255,255,255,0.04);
  border-radius: 12rpx;
  padding: 16rpx;
}
.dispatch-row {
  display: flex;
  justify-content: space-between;
  padding: 6rpx 0;
}
.dispatch-label { font-size: 24rpx; color: #888; }
.dispatch-value { font-size: 24rpx; color: #ddd; }
.dispatch-status-pending { color: #C9A84C; }
.dispatch-status-departed { color: #3B82F6; }
.dispatch-status-completed { color: #00FF88; }
.dispatch-status-cancelled { color: #EF4444; }

/* ── 操作按钮 ── */
.action-section {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
}

.btn-edit {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #C9A84C, #8B7333);
  color: #000;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
}

.btn-delete {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: rgba(255,255,255,0.05);
  color: #EF4444;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: 2rpx solid rgba(239,68,68,0.3);
}

<!-- ============================================
     功能金刚区页面 V5.4.1 — 折叠集成卡片入口
     ============================================ -->
<view class="page-container">

  <!-- 页面标题 -->
  <view class="page-header">
    <view>
      <text class="page-title">功能中心</text>
      <text class="page-subtitle">选择功能模块进入操作</text>
    </view>
    <view class="header-badge">
      <text class="badge-role">{{userRoleLabel}}</text>
    </view>
  </view>

  <!-- ═══ 折叠集成卡片区域 ═══ -->
  <view class="group-section">
    <view wx:for="{{groupCards}}" wx:key="id" class="group-card-wrapper">

      <!-- 非折叠卡片（如"我的发票"直接跳转） -->
      <view wx:if="{{!item.isGroup}}" class="group-card group-card-single"
            bindtap="onGroupCardTap" data-card="{{item}}">
        <view class="group-card-header">
          <view class="group-icon-wrap" style="background:{{item.iconBg}};">
            <text class="group-icon">{{item.icon}}</text>
          </view>
          <view class="group-card-text">
            <text class="group-card-name">{{item.name}}</text>
            <text class="group-card-sub">{{item.sub}}</text>
          </view>
          <text class="group-arrow">›</text>
        </view>
      </view>

      <!-- 折叠卡片（如"快捷报账"、"报账&发票审核"） -->
      <view wx:else class="group-card {{expandedGroups[item.id] ? 'expanded' : ''}}">
        <view class="group-card-header" bindtap="toggleGroup" data-group-id="{{item.id}}">
          <view class="group-icon-wrap" style="background:{{item.iconBg}};">
            <text class="group-icon">{{item.icon}}</text>
          </view>
          <view class="group-card-text">
            <text class="group-card-name">{{item.name}}</text>
            <text class="group-card-sub">{{item.sub}}</text>
          </view>
          <text class="group-expand-icon {{expandedGroups[item.id] ? 'rotated' : ''}}">▾</text>
        </view>

        <!-- 展开的子功能列表 -->
        <view wx:if="{{expandedGroups[item.id]}}" class="group-children">

          <!-- ★ BI 看板（仅报账&发票审核卡片展示） -->
          <view wx:if="{{item.id === 'admin_review' && coverageData}}" class="bi-dashboard">
            <view class="bi-gauge-section">
              <text class="bi-title">本月开票覆盖率</text>
              <view class="bi-gauge-ring">
                <text class="bi-gauge-value">{{coverageData.rate}}%</text>
              </view>
              <view class="bi-stats">
                <view class="bi-stat-row">
                  <text class="bi-stat-label">已核验发票总额</text>
                  <text class="bi-stat-value bi-positive">¥{{coverageData.invoiceTotal}}</text>
                </view>
                <view class="bi-stat-row">
                  <text class="bi-stat-label">实际总成本</text>
                  <text class="bi-stat-value">¥{{coverageData.costTotal}}</text>
                </view>
              </view>
            </view>
            <view class="bi-gap-section">
              <text class="bi-gap-label">价税现金差额</text>
              <text class="bi-gap-value">¥{{coverageData.taxGap}}</text>
              <text class="bi-gap-hint">未取得发票的成本金额（税务敞口）</text>
            </view>
          </view>

          <view class="child-item" wx:for="{{item.children}}" wx:for-item="child" wx:key="id"
                bindtap="onChildTap" data-url="{{child.url}}">
            <text class="child-icon">{{child.icon}}</text>
            <view class="child-text">
              <text class="child-name">{{child.name}}</text>
              <text class="child-sub">{{child.sub}}</text>
            </view>
            <text class="child-arrow">›</text>
          </view>
        </view>
      </view>

    </view>
  </view>

  <!-- ═══ 独立功能卡片网格 ═══ -->
  <view class="grid-container">
    <view
      wx:for="{{standaloneFeatures}}"
      wx:key="id"
      class="grid-item {{item.disabled ? 'disabled' : ''}} {{item.hasAlert ? 'has-alert' : ''}}"
      bindtap="onFeatureTap"
      data-feature="{{item}}"
    >
      <!-- 告警角标 -->
      <view wx:if="{{item.alertNum > 0}}" class="grid-alert-badge">
        <text>{{item.alertNum}}</text>
      </view>

      <!-- 图标区域 -->
      <view class="grid-icon-wrap" style="background:{{item.iconBg}};">
        <text class="grid-icon">{{item.icon}}</text>
      </view>

      <!-- 文字 -->
      <text class="grid-name">{{item.name}}</text>
      <text class="grid-sub">{{item.sub}}</text>

      <!-- 即将上线标签 -->
      <view wx:if="{{item.comingSoon}}" class="coming-soon-tag">
        <text>即将上线</text>
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text class="version-text">iCloush 智慧工厂 v5.4.1</text>
  </view>

  <view class="safe-bottom" />
</view>

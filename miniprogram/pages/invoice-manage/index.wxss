/* 管理员发票管理页 — 华通APP风格 */
.page-container { padding: 24rpx; background: #0a0a0a; min-height: 100vh; }

/* 顶部标题栏 */
.header-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.page-title { font-size: 36rpx; color: #fff; font-weight: bold; }
.header-actions { display: flex; gap: 16rpx; }
.btn-filter {
  display: flex; align-items: center; gap: 6rpx;
  font-size: 24rpx; color: #C9A84C;
  border: 1rpx solid rgba(201, 168, 76, 0.4);
  padding: 8rpx 20rpx; border-radius: 8rpx;
  background: rgba(201, 168, 76, 0.08);
}
.filter-icon { font-size: 28rpx; }
.filter-text { font-size: 24rpx; }

/* 搜索栏 */
.search-bar {
  display: flex; gap: 16rpx; margin-bottom: 16rpx;
}
.search-input {
  flex: 1;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 8rpx;
  padding: 14rpx 20rpx;
  font-size: 26rpx;
  color: #ddd;
}
.btn-search {
  font-size: 26rpx; color: #000; background: #C9A84C;
  padding: 14rpx 28rpx; border-radius: 8rpx; font-weight: bold;
  flex-shrink: 0;
}

/* 日期筛选面板 */
.date-filter-panel {
  background: rgba(255,255,255,0.05);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
}
.date-row {
  display: flex; align-items: center; gap: 16rpx;
  margin-bottom: 16rpx;
}
.date-label { font-size: 26rpx; color: #888; width: 140rpx; }
.date-picker {
  flex: 1;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 8rpx;
  padding: 12rpx 20rpx;
  font-size: 26rpx;
  color: #ddd;
}
.btn-apply {
  text-align: center;
  font-size: 28rpx; color: #000; background: #C9A84C;
  padding: 16rpx; border-radius: 8rpx; font-weight: bold;
  margin-top: 8rpx;
}

/* 统计信息 */
.stats-bar {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 16rpx; padding: 0 4rpx;
}
.stats-text { font-size: 24rpx; color: #888; }
.stats-date { font-size: 22rpx; color: #555; }

/* 筛选 Tab 栏 */
.filter-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
  overflow-x: auto;
  white-space: nowrap;
}
.tab-item {
  font-size: 26rpx;
  color: #888;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.05);
  flex-shrink: 0;
}
.tab-item.active {
  color: #000;
  background: #C9A84C;
  font-weight: bold;
}

/* 空状态 */
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-icon-text { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #666; margin-bottom: 32rpx; }

/* 发票卡片 */
.invoice-card {
  background: rgba(255,255,255,0.05);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-left: 4rpx solid transparent;
}
.invoice-card:active {
  background: rgba(255,255,255,0.08);
}

/* 第一行：类型图标 + 信息 */
.card-row-main {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

/* 专/普 圆形图标 */
.type-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}
.type-special {
  background: rgba(239, 68, 68, 0.15);
  border: 2rpx solid rgba(239, 68, 68, 0.4);
}
.type-general {
  background: rgba(59, 130, 246, 0.15);
  border: 2rpx solid rgba(59, 130, 246, 0.4);
}
.type-badge-text {
  font-size: 28rpx;
  font-weight: bold;
}
.type-special .type-badge-text { color: #EF4444; }
.type-general .type-badge-text { color: #3B82F6; }

/* 卡片信息区 */
.card-info { flex: 1; min-width: 0; }
.card-title-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 8rpx;
}
.inv-title {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 350rpx;
}
.inv-amount {
  font-size: 32rpx;
  color: #C9A84C;
  font-weight: bold;
  flex-shrink: 0;
}
.card-sub-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.inv-seller {
  font-size: 24rpx;
  color: #888;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 300rpx;
}
.inv-date { font-size: 22rpx; color: #555; flex-shrink: 0; }

/* 员工姓名行 */
.card-user-row {
  margin-top: 8rpx;
}
.inv-user {
  font-size: 22rpx;
  color: #C9A84C;
  opacity: 0.8;
}

/* 状态标签栏 */
.card-tags {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

/* 通用标签 */
.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}
.tag-text { font-size: 22rpx; font-weight: 500; }

/* 验证通过 — 绿色 */
.tag-verified {
  background: rgba(16, 185, 129, 0.15);
  border: 1rpx solid rgba(16, 185, 129, 0.3);
}
.tag-verified .tag-text { color: #10B981; }

/* 待核验 — 黄色 */
.tag-pending {
  background: rgba(251, 191, 36, 0.15);
  border: 1rpx solid rgba(251, 191, 36, 0.3);
}
.tag-pending .tag-text { color: #FBBF24; }

/* 核验失败 — 红色 */
.tag-failed {
  background: rgba(239, 68, 68, 0.15);
  border: 1rpx solid rgba(239, 68, 68, 0.3);
}
.tag-failed .tag-text { color: #EF4444; }

/* 重复发票 — 橙色 */
.tag-duplicate {
  background: rgba(249, 115, 22, 0.15);
  border: 1rpx solid rgba(249, 115, 22, 0.3);
}
.tag-duplicate .tag-text { color: #F97316; }

/* 发票号码标签 */
.inv-number-tag {
  font-size: 20rpx;
  color: #555;
  margin-left: auto;
}

/* 加载更多 */
.load-end { text-align: center; padding: 32rpx 0; }
.load-end-text { font-size: 24rpx; color: #444; }

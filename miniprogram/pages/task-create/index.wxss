/* ============================================
   任务发布控制台 — Task Command Console
   ============================================ */

.form-scroll {
  height: calc(100vh - 180rpx);
  padding: 0 32rpx;
}

/* 表单区块 */
.form-section {
  margin-bottom: 36rpx;
}

.section-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.label-icon {
  font-size: 20rpx;
  color: var(--color-gold);
}

.label-text {
  font-family: var(--font-mono);
  font-size: 20rpx;
  color: var(--color-text-secondary);
  letter-spacing: 2rpx;
}

.label-required {
  color: var(--color-danger);
  font-size: 24rpx;
  margin-left: 4rpx;
}

/* 输入框 */
.input-box {
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
}

.text-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  background: transparent;
}

.input-suffix {
  font-family: var(--font-mono);
  font-size: 22rpx;
  color: var(--color-gold);
  margin-left: 12rpx;
}

.input-placeholder {
  color: var(--color-text-muted);
}

.char-count {
  display: block;
  text-align: right;
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
}

/* 文本域 */
.textarea-box {
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.text-area {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  background: transparent;
}

/* 任务类型卡片 */
.type-grid {
  display: flex;
  gap: 16rpx;
}

.type-card {
  flex: 1;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
  text-align: center;
  transition: all 0.2s;
}

.type-card.active {
  border-color: var(--color-gold);
  background: var(--color-gold-dim);
}

.type-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.type-card.active .type-label {
  color: var(--color-gold);
}

.type-desc {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-muted);
}

/* 优先级 */
.priority-row {
  display: flex;
  gap: 16rpx;
}

.priority-chip {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 0;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.priority-chip.active {
  background: rgba(255, 255, 255, 0.05);
}

.priority-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

/* 选择器 */
.picker-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.picker-value {
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.picker-value.placeholder {
  color: var(--color-text-muted);
}

.picker-arrow {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* 间隔周期 */
.interval-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.interval-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  white-space: nowrap;
}

.interval-input {
  width: 160rpx;
  flex: none;
}

.interval-presets {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.preset-chip {
  padding: 12rpx 24rpx;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: 40rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.preset-chip.active {
  border-color: var(--color-gold);
  color: var(--color-gold);
  background: var(--color-gold-dim);
}

.interval-hint {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

/* 行组合 */
.row-group {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.flex-1 {
  flex: 1;
}

.unit-picker {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--color-gold);
  min-width: 140rpx;
  justify-content: center;
}

/* 已选员工 */
.selected-staff {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.staff-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--color-bg-elevated);
  border: 1rpx solid var(--color-border-light);
  border-radius: 40rpx;
  padding: 8rpx 16rpx 8rpx 8rpx;
}

.chip-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #000;
  font-weight: 600;
}

.chip-name {
  font-size: 24rpx;
  color: var(--color-text-primary);
}

.chip-remove {
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-left: 4rpx;
  padding: 4rpx;
}

.add-staff-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx;
  border: 1rpx dashed var(--color-border-light);
  border-radius: 12rpx;
  color: var(--color-text-secondary);
  font-size: 26rpx;
}

.add-icon {
  font-size: 32rpx;
  color: var(--color-gold);
}

/* 底部提交栏 */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(transparent, var(--color-bg) 30%);
  z-index: 100;
}

.submit-btn {
  display: flex !important;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  height: 96rpx;
  background: var(--color-gold) !important;
  color: #000000 !important;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  padding: 0;
  line-height: 96rpx;
}

.submit-btn::after { border: none; }

.submit-btn[disabled] {
  opacity: 0.5;
}

.btn-icon {
  font-size: 24rpx;
}

/* 员工选择弹窗 */
.staff-picker-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 200;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.staff-picker-mask.visible {
  opacity: 1;
  pointer-events: auto;
}

.staff-picker-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  max-height: 70vh;
  background: var(--color-bg);
  border-top: 1rpx solid var(--color-gold-border);
  border-radius: 24rpx 24rpx 0 0;
  z-index: 201;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
}

.staff-picker-panel.visible {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.picker-close {
  font-size: 28rpx;
  color: var(--color-gold);
  font-weight: 500;
}

.picker-search {
  padding: 16rpx 32rpx;
}

.search-input {
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  width: 100%;
  box-sizing: border-box;
}

.picker-list {
  flex: 1;
  max-height: 50vh;
  padding: 0 32rpx;
}

.staff-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.staff-item.selected {
  background: var(--color-gold-dim);
  margin: 0 -32rpx;
  padding: 20rpx 32rpx;
}

.staff-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #000;
  font-weight: 700;
  flex-shrink: 0;
}

.staff-info {
  flex: 1;
  min-width: 0;
}

.staff-name {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.staff-role {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.staff-skills {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.skill-tag {
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  background: var(--color-bg-elevated);
  border-radius: 20rpx;
  color: var(--color-text-secondary);
}

.check-box {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid var(--color-border-light);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.check-box.checked {
  background: var(--color-gold);
  border-color: var(--color-gold);
  color: #000;
  font-size: 24rpx;
  font-weight: 700;
}

/* ═══ V5.6.1: 必须拍照取证开关 ═══ */
.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  background: rgba(255,255,255,0.03);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 12rpx;
}

.switch-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.switch-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #F0F0F0;
}

.switch-desc {
  font-size: 20rpx;
  color: #888888;
  line-height: 1.5;
}

/* ═══ V5.7.3: 示范照片上传 ═══ */
.example-photo-row {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.06);
}

.example-photo-header {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.example-photo-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #F0F0F0;
}

.example-photo-hint {
  font-size: 20rpx;
  color: #888888;
}

.example-photo-preview {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  border: 2rpx solid rgba(201,168,76,0.3);
}

.example-preview-img {
  width: 100%;
  height: 100%;
}

.example-remove-btn {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.7);
  display: flex;
  align-items: center;
  justify-content: center;
}

.example-remove-btn text {
  font-size: 24rpx;
  color: #fff;
}

.example-uploading-mask {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.example-uploading-mask text {
  font-size: 22rpx;
  color: #C9A84C;
}

.example-add-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  border: 2rpx dashed rgba(201,168,76,0.4);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: rgba(201,168,76,0.05);
}

.example-add-icon {
  font-size: 48rpx;
  color: #C9A84C;
}

.example-add-text {
  font-size: 20rpx;
  color: #888888;
}

/* 营收直录 — 品牌黑橙配色 */
.page-container {
  min-height: 100vh;
  background: #111111;
  padding: 32rpx;
  box-sizing: border-box;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #E8A945;
  margin-bottom: 32rpx;
}

.form-section {
  background: #1E1E1E;
  border-radius: 16rpx;
  padding: 8rpx 24rpx;
  border: 1rpx solid rgba(232, 169, 69, 0.15);
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #CCCCCC;
  flex-shrink: 0;
}

.required {
  color: #E8A945;
  margin-left: 4rpx;
}

.input {
  text-align: right;
  font-size: 28rpx;
  color: #FFFFFF;
  flex: 1;
  margin-left: 20rpx;
}

.picker-value {
  font-size: 28rpx;
  color: #E8A945;
}

.btn-area {
  margin-top: 40rpx;
  display: flex;
  justify-content: center;
}

.btn-submit {
  width: 60%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: linear-gradient(135deg, #E8A945, #D4942E);
  color: #111111;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 40rpx;
  border: none;
}

.btn-disabled {
  opacity: 0.4;
}

.recent-section {
  margin-top: 48rpx;
}

.section-title {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.recent-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #1E1E1E;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid rgba(232, 169, 69, 0.08);
}

.recent-left {
  display: flex;
  flex-direction: column;
}

.recent-cat {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.recent-desc {
  font-size: 22rpx;
  color: #888888;
  margin-top: 4rpx;
}

.recent-amount {
  font-size: 32rpx;
  font-weight: 700;
  color: #4CAF50;
  font-family: 'DIN Alternate', monospace;
}

.empty-hint {
  text-align: center;
  color: #666666;
  font-size: 26rpx;
  margin-top: 80rpx;
}

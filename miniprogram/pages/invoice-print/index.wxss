.page-container { padding: 24rpx; background: #0a0a0a; min-height: 100vh; }

/* 覆盖率看板 */
.coverage-card { background: linear-gradient(135deg, rgba(201,168,76,0.12), rgba(59,130,246,0.08)); border: 1rpx solid rgba(201,168,76,0.2); border-radius: 20rpx; padding: 32rpx; margin-bottom: 28rpx; }
.card-title { font-size: 28rpx; color: #aaa; display: block; margin-bottom: 24rpx; }
.gauge-container { display: flex; justify-content: center; margin-bottom: 24rpx; }
.gauge-ring { width: 200rpx; height: 200rpx; border-radius: 50%; border: 12rpx solid rgba(201,168,76,0.3); display: flex; align-items: center; justify-content: center; position: relative; }
.gauge-value { font-size: 48rpx; color: #C9A84C; font-weight: bold; }
.coverage-detail { }
.detail-item { display: flex; justify-content: space-between; align-items: center; padding: 12rpx 0; }
.detail-item.highlight { padding-top: 16rpx; margin-top: 8rpx; border-top: 1rpx solid rgba(255,255,255,0.1); }
.detail-label { font-size: 26rpx; color: #888; }
.detail-value { font-size: 28rpx; color: #fff; font-weight: bold; }
.detail-value.positive { color: #10B981; }
.detail-value.negative { color: #EF4444; font-size: 34rpx; }

/* 筛选 */
.filter-tabs { display: flex; gap: 12rpx; margin-bottom: 24rpx; }
.tab { padding: 12rpx 24rpx; font-size: 26rpx; color: #888; background: rgba(255,255,255,0.05); border-radius: 8rpx; }
.tab.active { background: #C9A84C; color: #000; font-weight: bold; }
.loading-hint, .empty-hint { text-align: center; color: #666; font-size: 28rpx; padding: 80rpx 0; }

/* 发票卡片 */
.invoice-card { background: rgba(255,255,255,0.05); border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; }
.card-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12rpx; }
.header-left { flex: 1; overflow: hidden; }
.invoice-seller { font-size: 28rpx; color: #fff; font-weight: bold; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.invoice-code { font-size: 22rpx; color: #666; display: block; margin-top: 4rpx; }
.print-badge { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 6rpx; }
.print-badge.printed { background: rgba(16,185,129,0.2); color: #10B981; }
.print-badge.unprinted { background: rgba(245,158,11,0.2); color: #F59E0B; }
.card-body { }
.invoice-amount { font-size: 34rpx; color: #C9A84C; font-weight: bold; display: block; margin-bottom: 4rpx; }
.invoice-date { font-size: 24rpx; color: #666; display: block; margin-bottom: 4rpx; }
.invoice-uploader { font-size: 24rpx; color: #888; display: block; }

.action-bar { margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid rgba(255,255,255,0.08); }
.btn-print { width: 100%; height: 72rpx; line-height: 72rpx; background: rgba(201,168,76,0.15); color: #C9A84C; font-size: 28rpx; border-radius: 10rpx; text-align: center; border: none; }
.btn-unprint { width: 100%; height: 72rpx; line-height: 72rpx; background: rgba(255,255,255,0.05); color: #888; font-size: 28rpx; border-radius: 10rpx; text-align: center; border: none; }

.page-container{background:#0A0A0A;min-height:100vh;padding-bottom:120rpx;}
.task-hero{padding:24rpx 24rpx 20rpx;background:#111111;border-bottom:1rpx solid #1A1A1A;}
.hero-tags{display:flex;gap:10rpx;margin-bottom:12rpx;}
.type-tag,.priority-tag{padding:4rpx 14rpx;border-radius:20rpx;font-size:20rpx;}
.type-routine{background:rgba(59,130,246,0.15);color:#3B82F6;}
.type-periodic{background:rgba(139,92,246,0.15);color:#8B5CF6;}
.type-specific{background:rgba(245,158,11,0.15);color:#F59E0B;}
.priority-1{background:rgba(107,114,128,0.15);color:#9CA3AF;}
.priority-2{background:rgba(59,130,246,0.15);color:#3B82F6;}
.priority-3{background:rgba(245,158,11,0.15);color:#F59E0B;}
.priority-4{background:rgba(239,68,68,0.15);color:#EF4444;}
.hero-title{display:block;font-size:34rpx;font-weight:700;color:#F0F0F0;margin-bottom:14rpx;line-height:1.4;}
.hero-meta{display:flex;flex-direction:column;gap:8rpx;margin-bottom:14rpx;}
.meta-row{display:flex;align-items:center;gap:8rpx;}
.meta-icon{font-size:22rpx;}
.meta-text{font-size:24rpx;color:#888888;}
.meta-text.deadline{color:#F59E0B;}
.meta-text.gold{color:#C9A84C;}
.meta-text.recurring{color:#8B5CF6;}
.status-badge{display:inline-flex;align-items:center;gap:8rpx;padding:6rpx 16rpx;border-radius:20rpx;font-size:22rpx;}
.status-dot{width:10rpx;height:10rpx;border-radius:50%;background:currentColor;}
.status-0{background:rgba(107,114,128,0.15);color:#9CA3AF;}
.status-2{background:rgba(59,130,246,0.15);color:#3B82F6;}
.status-3{background:rgba(245,158,11,0.15);color:#F59E0B;}
.status-4{background:rgba(0,255,136,0.15);color:#00FF88;}
.status-5{background:rgba(239,68,68,0.15);color:#EF4444;}
.progress-section{padding:20rpx 24rpx;background:#0F0F0F;border-bottom:1rpx solid #1A1A1A;}
.progress-header{display:flex;justify-content:space-between;margin-bottom:10rpx;}
.progress-label{font-size:22rpx;color:#888888;}
.progress-value{font-size:22rpx;color:#C9A84C;font-family:'Courier New',monospace;}
.progress-track{height:8rpx;background:#1E1E1E;border-radius:4rpx;margin-bottom:6rpx;}
.progress-fill{height:100%;background:linear-gradient(90deg,#C9A84C,#F0C060);border-radius:4rpx;}
.progress-pct{font-size:20rpx;color:#888888;}
.section-title{display:block;font-size:24rpx;color:#888888;font-family:'Courier New',monospace;letter-spacing:2rpx;margin-bottom:14rpx;}
.desc-section,.action-section,.ai-review-section,.timeline-section{padding:20rpx 24rpx;border-bottom:1rpx solid #1A1A1A;}
.desc-text{font-size:26rpx;color:#CCCCCC;line-height:1.6;}
.count-input-row{display:flex;align-items:center;gap:12rpx;margin-bottom:20rpx;}
.count-btn{width:64rpx;height:64rpx;background:#1E1E1E;border-radius:12rpx;display:flex;align-items:center;justify-content:center;}
.count-btn text{font-size:32rpx;color:#F0F0F0;}
.count-display{flex:1;display:flex;align-items:baseline;justify-content:center;gap:6rpx;}
.count-value{font-size:48rpx;font-weight:700;color:#C9A84C;font-family:'Courier New',monospace;}
.count-unit{font-size:22rpx;color:#888888;}
.count-submit-btn{height:64rpx;background:rgba(201,168,76,0.15);color:#C9A84C;border-radius:12rpx;font-size:24rpx;border:1rpx solid rgba(201,168,76,0.3);}
.count-submit-btn::after{border:none;}
.photo-section{margin-bottom:20rpx;}
.photo-header{display:flex;align-items:center;gap:10rpx;margin-bottom:12rpx;}
.photo-label{font-size:26rpx;color:#F0F0F0;font-weight:500;}
.photo-required{font-size:20rpx;color:#EF4444;background:rgba(239,68,68,0.1);padding:2rpx 10rpx;border-radius:20rpx;}
.photo-optional{font-size:20rpx;color:#888888;}
.photo-grid{display:flex;flex-wrap:wrap;gap:10rpx;}
.photo-thumb{position:relative;width:160rpx;height:160rpx;border-radius:12rpx;overflow:hidden;border:1rpx solid #1E1E1E;}
.thumb-img{width:100%;height:100%;}
.thumb-remove{position:absolute;top:4rpx;right:4rpx;width:32rpx;height:32rpx;border-radius:50%;background:rgba(0,0,0,0.6);display:flex;align-items:center;justify-content:center;}
.thumb-remove text{font-size:20rpx;color:#fff;}
.ai-overlay{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;}
.ai-pass{background:rgba(0,255,136,0.3);}
.ai-fail{background:rgba(239,68,68,0.3);}
.ai-pending{background:rgba(245,158,11,0.2);}
.ai-overlay-text{font-size:40rpx;font-weight:700;color:#fff;}
.photo-add-btn{width:160rpx;height:160rpx;border-radius:12rpx;border:2rpx dashed #2A2A2A;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8rpx;}
.add-icon{font-size:40rpx;}
.add-text{font-size:20rpx;color:#666666;}
.submit-task-btn{width:100%;height:88rpx;background:#C9A84C;color:#000;border-radius:14rpx;font-size:28rpx;font-weight:700;border:none;}
.submit-task-btn.loading{background:#888888;}
.submit-task-btn::after{border:none;}
.ai-review-card{border-radius:14rpx;border:1rpx solid;padding:20rpx;}
.ai-card-pass{background:rgba(0,255,136,0.05);border-color:rgba(0,255,136,0.2);}
.ai-card-fail{background:rgba(239,68,68,0.05);border-color:rgba(239,68,68,0.2);}
.ai-card-pending{background:rgba(245,158,11,0.05);border-color:rgba(245,158,11,0.2);}
.ai-review-header{display:flex;align-items:center;gap:10rpx;margin-bottom:10rpx;}
.ai-result-icon{font-size:32rpx;}
.ai-result-label{flex:1;font-size:26rpx;font-weight:600;color:#F0F0F0;}
.ai-review-time{font-size:20rpx;color:#666666;}
.ai-review-comment{font-size:24rpx;color:#AAAAAA;line-height:1.5;}
.manual-review-row{display:flex;gap:12rpx;margin-top:16rpx;}
.manual-btn{flex:1;height:72rpx;border-radius:12rpx;font-size:24rpx;border:none;}
.manual-btn.approve{background:rgba(0,255,136,0.15);color:#00FF88;}
.manual-btn.reject{background:rgba(239,68,68,0.15);color:#EF4444;}
.manual-btn::after{border:none;}
.timeline{display:flex;flex-direction:column;gap:0;}
.timeline-item{display:flex;gap:16rpx;padding-bottom:20rpx;}
.timeline-dot{width:16rpx;height:16rpx;border-radius:50%;flex-shrink:0;margin-top:6rpx;}
.dot-start{background:#3B82F6;}.dot-count{background:#C9A84C;}.dot-photo{background:#00FF88;}.dot-submit{background:#F59E0B;}.dot-pass{background:#00FF88;}.dot-fail{background:#EF4444;}
.timeline-content{flex:1;min-width:0;}
.timeline-header{display:flex;justify-content:space-between;margin-bottom:6rpx;}
.timeline-action{font-size:24rpx;color:#F0F0F0;font-weight:500;}
.timeline-time{font-size:20rpx;color:#666666;}
.timeline-note{display:block;font-size:22rpx;color:#888888;margin-bottom:8rpx;}
.timeline-photos{display:flex;gap:8rpx;flex-wrap:wrap;margin-bottom:8rpx;}
.timeline-photo{width:100rpx;height:100rpx;border-radius:8rpx;}
.timeline-count{background:rgba(201,168,76,0.1);border-radius:20rpx;padding:4rpx 14rpx;display:inline-flex;}
.timeline-count text{font-size:20rpx;color:#C9A84C;}
.timeline-empty{padding:40rpx;text-align:center;font-size:24rpx;color:#444444;}
.safe-bottom{height:env(safe-area-inset-bottom);}

/* ★ V9 新增样式 */

/* 驳回警告横幅 */
.reject-banner{display:flex;align-items:flex-start;gap:12rpx;padding:20rpx 24rpx;background:rgba(239,68,68,0.08);border-bottom:2rpx solid rgba(239,68,68,0.3);}
.reject-banner-icon{font-size:28rpx;flex-shrink:0;margin-top:4rpx;}
.reject-banner-body{flex:1;min-width:0;}
.reject-banner-title{display:block;font-size:26rpx;font-weight:700;color:#EF4444;margin-bottom:6rpx;}
.reject-banner-reason{display:block;font-size:22rpx;color:#F87171;line-height:1.5;}

/* 驳回状态下的 hero 红框 */
.hero-rejected{border-left:6rpx solid #EF4444;}

/* 重新提交按钮 */
.submit-task-btn.resubmit{background:#EF4444;color:#fff;}

/* 负责人内联样式 */
.assignee-inline{display:flex;align-items:center;gap:8rpx;}
.assignee-avatar-mini{width:32rpx;height:32rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.assignee-avatar-mini text{font-size:16rpx;color:#fff;font-weight:600;}

/* 管理审核工作台 */
.review-workstation{padding:20rpx 24rpx;border-bottom:1rpx solid #1A1A1A;background:#0F0F0F;}
.review-actions{display:flex;gap:16rpx;margin-bottom:12rpx;}
.review-btn{flex:1;height:88rpx;border-radius:14rpx;font-size:28rpx;font-weight:700;display:flex;align-items:center;justify-content:center;gap:8rpx;border:none;}
.review-btn::after{border:none;}
.review-btn-icon{font-size:32rpx;}
.approve-btn{background:rgba(0,255,136,0.15);color:#00FF88;border:1rpx solid rgba(0,255,136,0.3);}
.reject-btn{background:rgba(239,68,68,0.15);color:#EF4444;border:1rpx solid rgba(239,68,68,0.3);}
.review-btn.loading{opacity:0.5;}
.review-hint{display:block;font-size:20rpx;color:#666666;text-align:center;}

/* ★ V10 接单网关样式 */
.accept-gateway{padding:32rpx 24rpx;background:#111111;border-bottom:1rpx solid #1A1A1A;text-align:center;}
.accept-gateway-info{display:flex;flex-direction:column;align-items:center;gap:12rpx;margin-bottom:24rpx;}
.accept-icon{font-size:60rpx;}
.accept-title{font-size:30rpx;font-weight:700;color:#F0F0F0;}
.accept-desc{font-size:22rpx;color:#888888;line-height:1.6;max-width:500rpx;}
.accept-btn{width:100%;height:96rpx;background:linear-gradient(135deg,#3B82F6,#2563EB);color:#fff;border-radius:14rpx;font-size:30rpx;font-weight:700;border:none;letter-spacing:4rpx;}
.accept-btn.loading{background:#555555;}
.accept-btn::after{border:none;}

/* ★ 管理员编辑入口 */
.edit-entry-section{padding:20rpx 24rpx;}
.edit-task-btn{display:flex!important;align-items:center;justify-content:center;gap:12rpx;width:100%;height:80rpx;background:transparent!important;border:1rpx solid rgba(59,130,246,0.4)!important;border-radius:12rpx;color:#3B82F6!important;font-size:28rpx;font-weight:500;padding:0;line-height:80rpx;}
.edit-task-btn::after{border:none;}
.edit-btn-icon{font-size:28rpx;}

/* ═══ V5.6.1 新增样式 ═══ */
.meta-text.photo-required-tag{color:#EF4444;font-weight:600;}
.photo-notice{display:flex;align-items:flex-start;gap:8rpx;padding:12rpx 16rpx;margin-bottom:16rpx;background:rgba(239,68,68,0.08);border-radius:8rpx;border:1rpx solid rgba(239,68,68,0.2);}
.notice-icon{font-size:24rpx;flex-shrink:0;margin-top:2rpx;}
.notice-text{font-size:22rpx;color:#EF4444;line-height:1.5;}

/* ═══ V5.7.3 新增样式 ═══ */

/* ★ 示范照片区域 */
.example-photo-section{padding:20rpx 24rpx;border-bottom:1rpx solid #1A1A1A;}
.example-photo-card{position:relative;border-radius:14rpx;overflow:hidden;border:1rpx solid rgba(201,168,76,0.3);background:#111111;}
.example-photo-img{width:100%;height:360rpx;}
.example-photo-label{display:flex;align-items:center;gap:8rpx;padding:12rpx 16rpx;background:rgba(201,168,76,0.08);}
.example-label-icon{font-size:24rpx;}
.example-label-text{font-size:22rpx;color:#C9A84C;font-weight:500;}

/* ★ 取证照片回溯区域 */
.proof-photos-section{padding:20rpx 24rpx;border-bottom:1rpx solid #1A1A1A;}
.proof-photo-grid{display:flex;flex-wrap:wrap;gap:10rpx;margin-bottom:10rpx;}
.proof-photo-thumb{width:160rpx;height:160rpx;border-radius:12rpx;overflow:hidden;border:1rpx solid rgba(201,168,76,0.2);}
.proof-thumb-img{width:100%;height:100%;}
.proof-photo-hint{display:block;font-size:20rpx;color:#666666;margin-top:6rpx;}

/* ★ 管理员审核取证照片展示 */
.review-evidence{margin-bottom:20rpx;}
.review-evidence-title{display:block;font-size:24rpx;color:#C9A84C;font-weight:600;margin-bottom:12rpx;}
.review-evidence-grid{display:flex;flex-wrap:wrap;gap:10rpx;}
.review-evidence-thumb{width:200rpx;height:200rpx;border-radius:12rpx;overflow:hidden;border:2rpx solid rgba(201,168,76,0.3);}
.review-evidence-img{width:100%;height:100%;}
.review-no-evidence{padding:20rpx;background:rgba(245,158,11,0.08);border-radius:12rpx;margin-bottom:16rpx;text-align:center;}
.review-no-evidence-text{font-size:24rpx;color:#F59E0B;}

/* ★ 上传中动画 */
.ai-uploading{background:rgba(59,130,246,0.3);}

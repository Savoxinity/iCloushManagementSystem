<!-- 报销列表页 -->
<view class="page-container">
  <view class="header-bar">
    <text class="page-title">报销记录</text>
    <view class="btn-create" bindtap="goCreate">+ 新建报销</view>
  </view>

  <!-- 状态筛选 -->
  <view class="filter-bar">
    <view wx:for="{{statusOptions}}" wx:key="value"
          class="filter-item {{statusFilter === item.value ? 'active' : ''}}"
          data-status="{{item.value}}" bindtap="switchFilter">
      {{item.label}}
    </view>
  </view>

  <view wx:if="{{loading}}" class="empty-state">
    <text class="empty-text">加载中...</text>
  </view>

  <view wx:elif="{{expenses.length === 0}}" class="empty-state">
    <text class="empty-icon">📋</text>
    <text class="empty-text">暂无报销记录</text>
    <view class="btn-action" bindtap="goCreate">去创建报销单</view>
  </view>

  <view wx:else class="expense-list">
    <view class="expense-card" wx:for="{{expenses}}" wx:key="id">
      <view class="card-top">
        <text class="exp-purpose">{{item.purpose}}</text>
        <text class="exp-status {{item.statusClass}}">{{item.statusLabel}}</text>
      </view>
      <view class="card-body">
        <text class="exp-amount">¥ {{item.claimed_amount}}</text>
        <text class="exp-type">{{item.voucher_type === 'invoice' ? '发票' : '收据'}}</text>
      </view>
      <view class="card-bottom">
        <text class="exp-date">{{item.created_at}}</text>
        <text wx:if="{{item.points_delta}}" class="exp-points {{item.points_delta > 0 ? 'positive' : 'negative'}}">
          积分 {{item.points_delta > 0 ? '+' : ''}}{{item.points_delta}}
        </text>
      </view>
    </view>
  </view>
</view>

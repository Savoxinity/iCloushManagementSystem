/* 报销记录页 V5.4.1 */
.page-container { padding: 24rpx; background: #0a0a0a; min-height: 100vh; }
.header-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.page-title { font-size: 36rpx; color: #fff; font-weight: bold; }
.header-actions { display: flex; gap: 12rpx; }
.btn-create { font-size: 24rpx; color: #000; background: #C9A84C; padding: 10rpx 24rpx; border-radius: 8rpx; font-weight: bold; }
.btn-create-alt { background: rgba(201,168,76,0.15); color: #C9A84C; border: 1rpx solid rgba(201,168,76,0.3); }

/* Tab 筛选 */
.filter-bar { display: flex; gap: 12rpx; margin-bottom: 28rpx; flex-wrap: wrap; }
.filter-item { font-size: 24rpx; color: #888; padding: 10rpx 20rpx; border-radius: 24rpx; background: rgba(255,255,255,0.05); }
.filter-item.active { background: #C9A84C; color: #000; font-weight: bold; }

/* 空状态 */
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #666; }

/* 记录卡片 */
.record-list { }
.record-card { background: rgba(255,255,255,0.05); border-radius: 12rpx; padding: 24rpx; margin-bottom: 20rpx; }
.card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.card-top-left { display: flex; align-items: center; gap: 12rpx; flex: 1; overflow: hidden; }
.record-type-tag { font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 6rpx; flex-shrink: 0; }
.tag-expense { background: rgba(59,130,246,0.15); color: #3B82F6; }
.tag-payment { background: rgba(201,168,76,0.15); color: #C9A84C; }
.record-reason { font-size: 28rpx; color: #fff; font-weight: bold; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.exp-status { font-size: 22rpx; padding: 4rpx 14rpx; border-radius: 6rpx; flex-shrink: 0; }
.status-pending { background: rgba(251,191,36,0.15); color: #FBBF24; }
.status-approved { background: rgba(16,185,129,0.15); color: #10B981; }
.status-rejected { background: rgba(239,68,68,0.15); color: #EF4444; }
.card-body { display: flex; align-items: baseline; gap: 16rpx; margin-bottom: 12rpx; }
.exp-amount { font-size: 38rpx; color: #C9A84C; font-weight: bold; }
.exp-type { font-size: 22rpx; color: #666; }
.card-bottom { display: flex; justify-content: space-between; }
.exp-date { font-size: 22rpx; color: #555; }
.exp-points { font-size: 24rpx; font-weight: bold; }
.exp-points.positive { color: #10B981; }
.exp-points.negative { color: #EF4444; }

/* ═══ 详情弹窗 ═══ */
.detail-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); z-index: 999; display: flex; align-items: flex-end; justify-content: center; }
.detail-panel { width: 100%; max-height: 80vh; background: #1A1A1A; border-radius: 24rpx 24rpx 0 0; padding: 40rpx 32rpx; overflow-y: auto; }
.detail-title { display: block; font-size: 34rpx; color: #fff; font-weight: 700; text-align: center; margin-bottom: 32rpx; }
.detail-row { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.06); }
.detail-label { font-size: 26rpx; color: #888; flex-shrink: 0; }
.detail-value { font-size: 26rpx; color: #E0E0E0; text-align: right; flex: 1; margin-left: 24rpx; }
.detail-value.amount-value { color: #C9A84C; font-weight: 700; font-size: 30rpx; }
.detail-voucher { margin-top: 24rpx; }
.voucher-label { display: block; font-size: 26rpx; color: #C9A84C; margin-bottom: 16rpx; font-weight: 600; }
.voucher-img { width: 100%; max-height: 400rpx; border-radius: 12rpx; }
.detail-actions { display: flex; gap: 20rpx; margin-top: 32rpx; }
.btn-close { flex: 1; text-align: center; padding: 24rpx; background: rgba(255,255,255,0.08); border-radius: 12rpx; color: #aaa; font-size: 30rpx; }
.btn-edit { flex: 1; text-align: center; padding: 24rpx; background: #C9A84C; border-radius: 12rpx; color: #000; font-size: 30rpx; font-weight: 700; }

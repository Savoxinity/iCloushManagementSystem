/* 报销记录页 V5.6.3 — 三段式详情弹窗 */
.page-container { padding: 24rpx; background: #0a0a0a; min-height: 100vh; }
.header-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.page-title { font-size: 36rpx; color: #fff; font-weight: bold; }
.header-actions { display: flex; gap: 12rpx; }
.btn-create { font-size: 24rpx; color: #000; background: #C9A84C; padding: 10rpx 24rpx; border-radius: 8rpx; font-weight: bold; }
.btn-create-alt { background: rgba(201,168,76,0.15); color: #C9A84C; border: 1rpx solid rgba(201,168,76,0.3); }

/* Tab 筛选 */
.filter-bar { display: flex; gap: 12rpx; margin-bottom: 28rpx; flex-wrap: wrap; }
.filter-item { font-size: 24rpx; color: #888; padding: 10rpx 20rpx; border-radius: 24rpx; background: rgba(255,255,255,0.05); }
.filter-item.active { background: #C9A84C; color: #000; font-weight: bold; }

/* 空状态 */
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #666; }

/* 记录卡片 */
.record-list { }
.record-card { background: rgba(255,255,255,0.05); border-radius: 12rpx; padding: 24rpx; margin-bottom: 20rpx; }
.card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.card-top-left { display: flex; align-items: center; gap: 12rpx; flex: 1; overflow: hidden; }
.record-type-tag { font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 6rpx; flex-shrink: 0; }
.tag-expense { background: rgba(59,130,246,0.15); color: #3B82F6; }
.tag-payment { background: rgba(201,168,76,0.15); color: #C9A84C; }
.record-reason { font-size: 28rpx; color: #fff; font-weight: bold; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.exp-status { font-size: 22rpx; padding: 4rpx 14rpx; border-radius: 6rpx; flex-shrink: 0; }
.status-pending { background: rgba(251,191,36,0.15); color: #FBBF24; }
.status-approved { background: rgba(16,185,129,0.15); color: #10B981; }
.status-rejected { background: rgba(239,68,68,0.15); color: #EF4444; }
.card-body { display: flex; align-items: baseline; gap: 16rpx; margin-bottom: 12rpx; }
.exp-amount { font-size: 38rpx; color: #C9A84C; font-weight: bold; }
.exp-type { font-size: 22rpx; color: #666; }
.card-bottom { display: flex; justify-content: space-between; }
.exp-date { font-size: 22rpx; color: #555; }
.exp-points { font-size: 24rpx; font-weight: bold; }
.exp-points.positive { color: #10B981; }
.exp-points.negative { color: #EF4444; }

/* ═══ V5.6.3 三段式详情弹窗 ═══ */
.detail-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.75); z-index: 999; display: flex; flex-direction: column; align-items: center; }

/* 弹窗面板 — 距顶部 2bar 留白 */
.detail-panel-v2 {
  width: 100%;
  margin-top: 180rpx;  /* ★ 2bar 顶部留白空气感 */
  max-height: calc(100vh - 180rpx);
  background: #1A1A1A;
  border-radius: 24rpx 24rpx 0 0;
  padding: 0 32rpx 40rpx;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* 顶部留白 + 标题行 */
.detail-top-spacer { height: 40rpx; }
.detail-header-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.detail-title-v2 { font-size: 34rpx; color: #fff; font-weight: 700; }
.detail-close-x { font-size: 36rpx; color: #666; padding: 8rpx 16rpx; }

/* ── 上 1/3：图片预览 ── */
.detail-section-img {
  background: rgba(255,255,255,0.03);
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}
.detail-preview-img {
  width: 100%;
  height: 380rpx;
  background: #111;
}
.detail-no-img {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  height: 240rpx; color: #555;
}
.no-img-icon { font-size: 64rpx; margin-bottom: 12rpx; }
.no-img-text { font-size: 24rpx; }

/* ── 中 1/3：OCR 详情折叠框 ── */
.detail-section-ocr {
  background: rgba(255,255,255,0.04);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(201,168,76,0.15);
}
.ocr-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.ocr-header-title { font-size: 28rpx; color: #C9A84C; font-weight: 600; }
.ocr-toggle-btn { font-size: 22rpx; color: #C9A84C; padding: 8rpx 16rpx; background: rgba(201,168,76,0.1); border-radius: 8rpx; }

/* OCR 摘要（始终显示） */
.ocr-summary { }
.ocr-summary-row { display: flex; justify-content: space-between; align-items: center; padding: 10rpx 0; }
.ocr-s-label { font-size: 24rpx; color: #888; flex-shrink: 0; width: 100rpx; }
.ocr-s-value { font-size: 24rpx; color: #E0E0E0; text-align: right; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ocr-s-amount { color: #C9A84C; font-weight: 600; }

/* OCR 展开详情 */
.ocr-full-detail { margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid rgba(255,255,255,0.06); }
.ocr-detail-row { display: flex; justify-content: space-between; align-items: flex-start; padding: 8rpx 0; }
.ocr-d-label { font-size: 22rpx; color: #777; flex-shrink: 0; width: 140rpx; }
.ocr-d-value { font-size: 22rpx; color: #ccc; text-align: right; flex: 1; word-break: break-all; }

/* ── 下 1/3：基本信息 ── */
.detail-section-info {
  background: rgba(255,255,255,0.04);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.detail-row-v2 { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.04); }
.detail-row-v2:last-child { border-bottom: none; }
.detail-label-v2 { font-size: 26rpx; color: #888; flex-shrink: 0; }
.detail-value-v2 { font-size: 26rpx; color: #E0E0E0; text-align: right; flex: 1; margin-left: 24rpx; }
.amount-highlight { color: #C9A84C; font-weight: 700; font-size: 30rpx; }
.positive { color: #10B981; }
.negative { color: #EF4444; }

/* 操作按钮 */
.detail-actions-v2 { display: flex; gap: 20rpx; }
.btn-close-v2 { flex: 1; text-align: center; padding: 24rpx; background: rgba(255,255,255,0.08); border-radius: 12rpx; color: #aaa; font-size: 30rpx; }
.btn-edit-v2 { flex: 1; text-align: center; padding: 24rpx; background: #C9A84C; border-radius: 12rpx; color: #000; font-size: 30rpx; font-weight: 700; }

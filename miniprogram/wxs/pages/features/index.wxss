/* ============================================
   功能金刚区样式
   ============================================ */

.page-container {
  background: #0A0A0A;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.page-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 32rpx 32rpx 24rpx;
  background: linear-gradient(180deg, #111111 0%, #0A0A0A 100%);
  border-bottom: 1rpx solid #1A1A1A;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #F0F0F0;
}

.page-subtitle {
  display: block;
  font-size: 22rpx;
  color: #666666;
  margin-top: 6rpx;
}

.header-badge {
  background: rgba(201, 168, 76, 0.1);
  border: 1rpx solid rgba(201, 168, 76, 0.3);
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
  margin-top: 4rpx;
}

.badge-role {
  font-size: 22rpx;
  color: #C9A84C;
}

/* ===== 2×4 网格 ===== */
.grid-container {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 32rpx 24rpx;
}

.grid-item {
  position: relative;
  background: #141414;
  border-radius: 20rpx;
  border: 1rpx solid #1E1E1E;
  padding: 32rpx 24rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 10rpx;
  overflow: hidden;
  /* 轻微投影 */
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.4);
}

.grid-item.disabled {
  opacity: 0.5;
}

.grid-item.has-alert {
  border-color: rgba(239, 68, 68, 0.3);
}

/* 告警角标 */
.grid-alert-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: #EF4444;
  color: #fff;
  font-size: 18rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  font-weight: 700;
}

/* 图标 */
.grid-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4rpx;
}

.grid-icon {
  font-size: 44rpx;
}

/* 文字 */
.grid-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #F0F0F0;
  line-height: 1.2;
}

.grid-sub {
  font-size: 20rpx;
  color: #888888;
  line-height: 1.3;
}

/* 即将上线 */
.coming-soon-tag {
  position: absolute;
  bottom: 0;
  right: 0;
  background: rgba(107, 114, 128, 0.2);
  border-radius: 12rpx 0 20rpx 0;
  padding: 6rpx 14rpx;
}

.coming-soon-tag text {
  font-size: 18rpx;
  color: #666666;
}

/* 版本信息 */
.version-info {
  display: flex;
  justify-content: center;
  padding: 24rpx;
}

.version-text {
  font-size: 20rpx;
  color: #333333;
  font-family: 'Courier New', monospace;
}

.safe-bottom {
  height: env(safe-area-inset-bottom);
}

// ============================================
// 排班拖拽 WXS 模块
// 全部逻辑在渲染层执行，不触发 setData，安卓不卡顿
// ============================================

var dragState = {
  dragging: false,
  staffId: null,
  startX: 0,
  startY: 0,
  currentX: 0,
  currentY: 0,
  ghostEl: null,
  sourceZoneId: null,
};

// 拖拽开始
function onDragStart(event, ownerInstance) {
  var touch = event.touches[0];
  var dataset = event.currentTarget.dataset;

  dragState.dragging = true;
  dragState.staffId = dataset.staffId;
  dragState.sourceZoneId = dataset.zoneId || null;
  dragState.startX = touch.clientX;
  dragState.startY = touch.clientY;
  dragState.currentX = touch.clientX;
  dragState.currentY = touch.clientY;

  // 通知逻辑层：拖拽开始
  ownerInstance.callMethod('onWxsDragStart', {
    staffId: dragState.staffId,
    sourceZoneId: dragState.sourceZoneId,
  });

  return false;
}

// 拖拽移动（渲染层直接操作 ghost 元素位置，不走 JS 层）
function onDragMove(event, ownerInstance) {
  if (!dragState.dragging) return false;

  var touch = event.touches[0];
  var deltaX = touch.clientX - dragState.startX;
  var deltaY = touch.clientY - dragState.startY;

  dragState.currentX = touch.clientX;
  dragState.currentY = touch.clientY;

  // 更新 ghost 卡片位置（直接操作 DOM，不经过 setData）
  var ghostEl = ownerInstance.selectComponent('#drag-ghost');
  if (ghostEl) {
    ghostEl.setStyle({
      display: 'flex',
      transform: 'translate(' + deltaX + 'px, ' + deltaY + 'px) scale(1.08)',
      opacity: '0.9',
    });
  }

  // 高亮命中的目标工区
  var zoneEls = ownerInstance.selectAllComponents('.schedule-slot');
  if (zoneEls) {
    for (var i = 0; i < zoneEls.length; i++) {
      var rect = zoneEls[i].getBoundingClientRect();
      var hit = (
        touch.clientX >= rect.left &&
        touch.clientX <= rect.right &&
        touch.clientY >= rect.top &&
        touch.clientY <= rect.bottom
      );
      zoneEls[i].setStyle({
        borderColor: hit ? '#C9A84C' : '#1E1E1E',
        background: hit ? 'rgba(201,168,76,0.08)' : '#141414',
      });
    }
  }

  return false;
}

// 拖拽结束
function onDragEnd(event, ownerInstance) {
  if (!dragState.dragging) return false;

  dragState.dragging = false;

  // 隐藏 ghost
  var ghostEl = ownerInstance.selectComponent('#drag-ghost');
  if (ghostEl) {
    ghostEl.setStyle({ display: 'none', transform: 'none' });
  }

  // 清除所有工区高亮
  var zoneEls = ownerInstance.selectAllComponents('.schedule-slot');
  if (zoneEls) {
    for (var i = 0; i < zoneEls.length; i++) {
      zoneEls[i].setStyle({ borderColor: '#1E1E1E', background: '#141414' });
    }
  }

  // 找出命中的目标工区
  var touch = event.changedTouches[0];
  var targetZoneId = null;

  if (zoneEls) {
    for (var j = 0; j < zoneEls.length; j++) {
      var rect2 = zoneEls[j].getBoundingClientRect();
      if (
        touch.clientX >= rect2.left &&
        touch.clientX <= rect2.right &&
        touch.clientY >= rect2.top &&
        touch.clientY <= rect2.bottom
      ) {
        targetZoneId = zoneEls[j].dataset.zoneId;
        break;
      }
    }
  }

  // 通知逻辑层：拖拽结束，携带目标工区
  ownerInstance.callMethod('onWxsDragEnd', {
    staffId: dragState.staffId,
    sourceZoneId: dragState.sourceZoneId,
    targetZoneId: targetZoneId,
  });

  return false;
}

module.exports = {
  onDragStart: onDragStart,
  onDragMove: onDragMove,
  onDragEnd: onDragEnd,
};

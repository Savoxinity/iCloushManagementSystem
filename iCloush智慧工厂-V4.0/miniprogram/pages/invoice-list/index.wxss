.page-container { padding: 24rpx; background: #0a0a0a; min-height: 100vh; }
.header-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32rpx; }
.page-title { font-size: 36rpx; color: #fff; font-weight: bold; }
.btn-upload { font-size: 26rpx; color: #000; background: #C9A84C; padding: 12rpx 28rpx; border-radius: 8rpx; font-weight: bold; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #666; margin-bottom: 32rpx; }
.btn-action { font-size: 28rpx; color: #C9A84C; border: 1rpx solid #C9A84C; padding: 16rpx 48rpx; border-radius: 8rpx; }
.invoice-card { background: rgba(255,255,255,0.05); border-radius: 12rpx; padding: 24rpx; margin-bottom: 20rpx; position: relative; }
.card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.inv-type { font-size: 26rpx; color: #aaa; }
.inv-status { font-size: 24rpx; padding: 4rpx 16rpx; border-radius: 6rpx; }
.inv-status.pending { background: rgba(251,191,36,0.15); color: #FBBF24; }
.inv-status.verified { background: rgba(16,185,129,0.15); color: #10B981; }
.inv-status.failed { background: rgba(239,68,68,0.15); color: #EF4444; }
.card-body { margin-bottom: 12rpx; }
.inv-amount { font-size: 40rpx; color: #C9A84C; font-weight: bold; margin-right: 16rpx; }
.inv-seller { font-size: 26rpx; color: #888; }
.card-bottom { display: flex; justify-content: space-between; }
.inv-number { font-size: 22rpx; color: #555; }
.inv-date { font-size: 22rpx; color: #555; }
.inv-thumb { position: absolute; right: 24rpx; top: 50%; transform: translateY(-50%); width: 80rpx; height: 80rpx; border-radius: 8rpx; opacity: 0.6; }

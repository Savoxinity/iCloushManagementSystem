<!-- ============================================
     排班管理页 V6
     交互：长按员工卡 → 弹出工区选择器 → 点击目标工区完成移动
     ============================================ -->
<view class="page-container">

  <!-- 日期选择栏 -->
  <view class="date-bar">
    <view class="date-nav-btn" bindtap="prevDay"><text class="date-nav-icon">‹</text></view>
    <view class="date-center" bindtap="showDatePicker">
      <text class="date-main">{{selectedDateStr}}</text>
      <text class="date-sub">{{selectedWeekday}} · 点击切换日期</text>
    </view>
    <view class="date-nav-btn" bindtap="nextDay"><text class="date-nav-icon">›</text></view>
    <view class="today-btn" bindtap="goToday"><text>今天</text></view>
  </view>

  <!-- 统计摘要 -->
  <view class="summary-row">
    <view class="summary-item"><text class="summary-value">{{summary.total}}</text><text class="summary-label">总人数</text></view>
    <view class="summary-item"><text class="summary-value green">{{summary.assigned}}</text><text class="summary-label">已排班</text></view>
    <view class="summary-item"><text class="summary-value gold">{{summary.unassigned}}</text><text class="summary-label">待分配</text></view>
    <view class="summary-item"><text class="summary-value red">{{summary.leave}}</text><text class="summary-label">请假</text></view>
  </view>

  <!-- 主体：左侧待分配员工池 + 右侧工区格 -->
  <view class="board-container">

    <!-- 左侧：待分配员工池 -->
    <view class="staff-pool">
      <text class="pool-title">待分配</text>
      <scroll-view class="pool-scroll" scroll-y>
        <!-- ★ 长按触发移动弹窗 -->
        <view
          wx:for="{{unassignedStaff}}"
          wx:key="id"
          class="staff-chip"
          bindlongpress="onStaffLongPress"
          data-staff-id="{{item.id}}"
          data-source-zone=""
        >
          <view class="chip-avatar" style="background:{{item.avatarColor}};"><text class="chip-initial">{{item.nameInitial}}</text></view>
          <view class="chip-info">
            <text class="chip-name">{{item.name}}</text>
            <text class="chip-role">{{item.roleLabel}}</text>
          </view>
          <view wx:if="{{item.is_multi_post}}" class="multi-badge"><text>多</text></view>
        </view>

        <!-- 请假员工（不可操作） -->
        <view wx:for="{{leaveStaff}}" wx:key="id" class="staff-chip leave">
          <view class="chip-avatar leave-avatar"><text class="chip-initial">{{item.nameInitial}}</text></view>
          <view class="chip-info">
            <text class="chip-name">{{item.name}}</text>
            <text class="chip-role leave-label">请假</text>
          </view>
        </view>

        <view wx:if="{{unassignedStaff.length === 0 && leaveStaff.length === 0}}" class="pool-empty"><text>✓ 全部已排班</text></view>
      </scroll-view>
    </view>

    <!-- 右侧：工区排班格 -->
    <scroll-view class="slots-scroll" scroll-y>
      <view class="slots-container">
        <view
          wx:for="{{scheduleSlots}}"
          wx:key="zone_id"
          class="schedule-slot"
          id="slot-{{item.zone_id}}"
        >
          <view class="slot-header" style="border-left-color:{{item.color}};">
            <view>
              <text class="slot-name">{{item.zone_name}}</text>
              <text class="slot-capacity">{{item.assigned.length}}/{{item.capacity}}人</text>
            </view>
            <view class="slot-shift-tags">
              <view class="shift-tag morning">早</view>
              <view class="shift-tag evening">晚</view>
            </view>
          </view>

          <!-- 已分配员工：长按触发移动/移除 -->
          <view class="slot-staff-row">
            <view
              wx:for="{{item.assigned}}"
              wx:key="id"
              wx:for-item="staff"
              class="slot-staff-chip"
              bindlongpress="onStaffLongPress"
              data-staff-id="{{staff.id}}"
              data-source-zone="{{item.zone_id}}"
            >
              <view class="slot-chip-avatar" style="background:{{staff.avatarColor}};"><text class="slot-chip-initial">{{staff.nameInitial}}</text></view>
              <text class="slot-chip-name">{{staff.name}}</text>
              <!-- 快捷移除按钮 -->
              <view class="slot-chip-remove" catchtap="onRemoveStaff" data-staff-id="{{staff.id}}" data-zone-id="{{item.zone_id}}"><text>×</text></view>
            </view>

            <view wx:if="{{item.assigned.length === 0}}" class="slot-empty-hint"><text>长按员工卡移入此工区</text></view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- ★ 工区选择弹窗（长按后弹出） -->
  <view wx:if="{{showMoveModal}}" class="modal-overlay" catchtap="closeMoveModal">
    <view class="modal-box modal-move-box" catchtap="stopPropagation">
      <view class="move-modal-header">
        <text class="modal-title">移动「{{moveStaffName}}」到…</text>
        <view class="move-close-btn" bindtap="closeMoveModal"><text>✕</text></view>
      </view>

      <!-- 移回待分配（仅当员工已在某工区时显示） -->
      <view wx:if="{{moveSourceZone}}" class="move-option move-option-unassign" bindtap="onMoveToUnassigned">
        <view class="move-opt-icon unassign-icon"><text>↩</text></view>
        <text class="move-opt-name">移回待分配池</text>
      </view>

      <!-- 工区列表 -->
      <scroll-view class="move-zone-list" scroll-y>
        <view
          wx:for="{{scheduleSlots}}"
          wx:key="zone_id"
          class="move-option {{item.zone_id === moveSourceZoneId ? 'current' : ''}} {{item.assigned.length >= item.capacity ? 'full' : ''}}"
          bindtap="{{item.zone_id === moveSourceZoneId || item.assigned.length >= item.capacity ? '' : 'onMoveToZone'}}"
          data-zone-id="{{item.zone_id}}"
        >
          <view class="move-opt-dot" style="background:{{item.color}};"></view>
          <view class="move-opt-info">
            <text class="move-opt-name">{{item.zone_name}}</text>
            <text class="move-opt-count">{{item.assigned.length}}/{{item.capacity}}人</text>
          </view>
          <text wx:if="{{item.zone_id === moveSourceZoneId}}" class="move-opt-badge current-badge">当前</text>
          <text wx:elif="{{item.assigned.length >= item.capacity}}" class="move-opt-badge full-badge">已满</text>
          <text wx:else class="move-opt-arrow">›</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <button class="btn-leave" bindtap="showLeaveModal">请假申\n请</button>
    <button class="btn-save" bindtap="saveSchedule">保存排班</button>
    <button class="btn-copy" bindtap="copyYesterday">复制昨\n日</button>
  </view>

  <!-- 请假申请弹窗 -->
  <view wx:if="{{showLeaveModal}}" class="modal-overlay" catchtap="closeLeaveModal">
    <view class="modal-box" catchtap="stopPropagation">
      <text class="modal-title">请假申请</text>
      <text class="form-label">选择员工</text>
      <scroll-view class="leave-staff-list" scroll-y>
        <view wx:for="{{allStaff}}" wx:key="id" class="leave-staff-item {{selectedLeaveStaffId === item.id ? 'selected' : ''}}" bindtap="selectLeaveStaff" data-id="{{item.id}}">
          <view class="leave-avatar" style="background:{{item.avatarColor}};"><text>{{item.nameInitial}}</text></view>
          <text class="leave-name">{{item.name}}</text>
          <view wx:if="{{selectedLeaveStaffId === item.id}}" class="leave-check">✓</view>
        </view>
      </scroll-view>
      <text class="form-label">请假类型</text>
      <view class="leave-type-row">
        <view wx:for="{{leaveTypes}}" wx:key="value" class="leave-type-chip {{selectedLeaveType === item.value ? 'active' : ''}}" bindtap="selectLeaveType" data-value="{{item.value}}"><text>{{item.label}}</text></view>
      </view>
      <text class="form-label">备注（可选）</text>
      <textarea class="leave-remark" placeholder="请输入请假原因..." placeholder-class="placeholder-style" bindinput="onLeaveRemarkInput" value="{{leaveRemark}}" maxlength="100" />
      <view class="modal-btns">
        <button class="modal-btn-cancel" bindtap="closeLeaveModal">取消</button>
        <button class="modal-btn-confirm" bindtap="submitLeave">提交申请</button>
      </view>
    </view>
  </view>

  <view class="safe-bottom" />
</view>

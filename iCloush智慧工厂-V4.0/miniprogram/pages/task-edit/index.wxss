/* ============================================
   任务编辑控制台 — Task Edit Console
   复用 task-create 样式 + 编辑专属样式
   ============================================ */

/* 编辑状态徽章 */
.edit-status-badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-family: var(--font-mono);
  letter-spacing: 1rpx;
  margin-top: 8rpx;
}

.edit-status-badge.status-0 {
  background: rgba(59, 130, 246, 0.15);
  color: #3B82F6;
  border: 1rpx solid rgba(59, 130, 246, 0.3);
}

.edit-status-badge.status-1 {
  background: rgba(245, 158, 11, 0.15);
  color: #F59E0B;
  border: 1rpx solid rgba(245, 158, 11, 0.3);
}

.edit-status-badge.status-2 {
  background: rgba(16, 185, 129, 0.15);
  color: #10B981;
  border: 1rpx solid rgba(16, 185, 129, 0.3);
}

.edit-status-badge.status-3 {
  background: rgba(168, 85, 247, 0.15);
  color: #A855F7;
  border: 1rpx solid rgba(168, 85, 247, 0.3);
}

.edit-status-badge.status-4 {
  background: rgba(107, 114, 128, 0.15);
  color: #6B7280;
  border: 1rpx solid rgba(107, 114, 128, 0.3);
}

/* 提示文字 */
.label-hint {
  font-size: 18rpx;
  color: var(--color-text-muted);
  margin-left: 8rpx;
}

/* 编辑按钮（蓝色主题区分创建的金色） */
.edit-btn {
  background: #3B82F6 !important;
  color: #FFFFFF !important;
}

/* ── 以下复用 task-create 样式 ── */

.form-scroll {
  height: calc(100vh - 180rpx);
  padding: 0 32rpx;
}

.form-section { margin-bottom: 36rpx; }

.section-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.label-icon { font-size: 20rpx; color: var(--color-gold); }

.label-text {
  font-family: var(--font-mono);
  font-size: 20rpx;
  color: var(--color-text-secondary);
  letter-spacing: 2rpx;
}

.label-required { color: var(--color-danger); font-size: 24rpx; margin-left: 4rpx; }

.input-box {
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
}

.text-input { flex: 1; font-size: 28rpx; color: var(--color-text-primary); background: transparent; }
.input-suffix { font-family: var(--font-mono); font-size: 22rpx; color: var(--color-gold); margin-left: 12rpx; }
.input-placeholder { color: var(--color-text-muted); }
.char-count { display: block; text-align: right; font-size: 20rpx; color: var(--color-text-muted); margin-top: 8rpx; }

.textarea-box {
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.text-area { width: 100%; min-height: 120rpx; font-size: 28rpx; color: var(--color-text-primary); background: transparent; }

.type-grid { display: flex; gap: 16rpx; }

.type-card {
  flex: 1;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
  text-align: center;
}

.type-card.active { border-color: var(--color-gold); background: var(--color-gold-dim); }
.type-label { display: block; font-size: 26rpx; font-weight: 600; color: var(--color-text-primary); margin-bottom: 4rpx; }
.type-card.active .type-label { color: var(--color-gold); }
.type-desc { display: block; font-size: 20rpx; color: var(--color-text-muted); }

.priority-row { display: flex; gap: 16rpx; }

.priority-chip {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 0;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.priority-chip.active { background: rgba(255, 255, 255, 0.05); }
.priority-dot { width: 12rpx; height: 12rpx; border-radius: 50%; }

.picker-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.picker-value { font-size: 28rpx; color: var(--color-text-primary); }
.picker-value.placeholder { color: var(--color-text-muted); }
.picker-arrow { font-size: 24rpx; color: var(--color-text-muted); }

.row-group { display: flex; gap: 16rpx; align-items: center; }
.flex-1 { flex: 1; }

.unit-picker {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--color-gold);
  min-width: 140rpx;
  justify-content: center;
}

.selected-staff { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 16rpx; }

.staff-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--color-bg-elevated);
  border: 1rpx solid var(--color-border-light);
  border-radius: 40rpx;
  padding: 8rpx 16rpx 8rpx 8rpx;
}

.chip-avatar {
  width: 40rpx; height: 40rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 20rpx; color: #000; font-weight: 600;
}

.chip-name { font-size: 24rpx; color: var(--color-text-primary); }
.chip-remove { font-size: 20rpx; color: var(--color-text-muted); margin-left: 4rpx; padding: 4rpx; }

.add-staff-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx;
  border: 1rpx dashed var(--color-border-light);
  border-radius: 12rpx;
  color: var(--color-text-secondary);
  font-size: 26rpx;
}

.add-icon { font-size: 32rpx; color: var(--color-gold); }

.submit-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(transparent, var(--color-bg) 30%);
  z-index: 100;
}

.submit-btn {
  display: flex !important;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  height: 96rpx;
  background: var(--color-gold) !important;
  color: #000000 !important;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  padding: 0;
  line-height: 96rpx;
}

.submit-btn::after { border: none; }
.submit-btn[disabled] { opacity: 0.5; }
.btn-icon { font-size: 24rpx; }

/* 员工选择弹窗 */
.staff-picker-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 200;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.staff-picker-mask.visible { opacity: 1; pointer-events: auto; }

.staff-picker-panel {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  max-height: 70vh;
  background: var(--color-bg);
  border-top: 1rpx solid var(--color-gold-border);
  border-radius: 24rpx 24rpx 0 0;
  z-index: 201;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
}

.staff-picker-panel.visible { transform: translateY(0); }

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.picker-title { font-size: 32rpx; font-weight: 600; color: var(--color-text-primary); }
.picker-close { font-size: 28rpx; color: var(--color-gold); font-weight: 500; }

.picker-search { padding: 16rpx 32rpx; }

.search-input {
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  width: 100%;
  box-sizing: border-box;
}

.picker-list { flex: 1; max-height: 50vh; padding: 0 32rpx; }

.staff-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.staff-item.selected {
  background: var(--color-gold-dim);
  margin: 0 -32rpx;
  padding: 20rpx 32rpx;
}

.staff-avatar {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: #000; font-weight: 700; flex-shrink: 0;
}

.staff-info { flex: 1; min-width: 0; }
.staff-name { display: block; font-size: 28rpx; color: var(--color-text-primary); font-weight: 500; }
.staff-role { display: block; font-size: 22rpx; color: var(--color-text-secondary); margin-top: 4rpx; }

.staff-skills { display: flex; flex-wrap: wrap; gap: 6rpx; }
.skill-tag { font-size: 18rpx; padding: 2rpx 10rpx; background: var(--color-bg-elevated); border-radius: 20rpx; color: var(--color-text-secondary); }

.check-box {
  width: 40rpx; height: 40rpx;
  border: 2rpx solid var(--color-border-light);
  border-radius: 8rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}

.check-box.checked {
  background: var(--color-gold);
  border-color: var(--color-gold);
  color: #000;
  font-size: 24rpx;
  font-weight: 700;
}

.empty-state {
  padding: 60rpx 0;
  text-align: center;
  color: var(--color-text-muted);
  font-size: 26rpx;
}

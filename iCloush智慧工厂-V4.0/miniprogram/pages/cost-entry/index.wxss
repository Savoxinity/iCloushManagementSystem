.page-container { padding: 32rpx; background: #0a0a0a; min-height: 100vh; }
.page-title { font-size: 40rpx; color: #fff; font-weight: bold; margin-bottom: 40rpx; }
.form-section { background: rgba(255,255,255,0.05); border-radius: 12rpx; padding: 8rpx 24rpx; margin-bottom: 32rpx; }
.form-item { display: flex; align-items: center; justify-content: space-between; padding: 28rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.08); }
.form-item:last-child { border-bottom: none; }
.label { font-size: 28rpx; color: #aaa; flex-shrink: 0; }
.input { flex: 1; font-size: 28rpx; color: #C9A84C; text-align: right; }
.picker-value { font-size: 28rpx; color: #C9A84C; }
.btn-area { margin-bottom: 48rpx; }
.btn-submit { width: 100%; height: 96rpx; line-height: 96rpx; background: #C9A84C; color: #000; font-size: 34rpx; font-weight: bold; border-radius: 12rpx; text-align: center; }
.btn-disabled { opacity: 0.4; }
.recent-section { margin-top: 16rpx; }
.section-title { font-size: 28rpx; color: #888; margin-bottom: 16rpx; }
.recent-item { display: flex; justify-content: space-between; align-items: center; padding: 20rpx; background: rgba(255,255,255,0.03); border-radius: 8rpx; margin-bottom: 12rpx; }
.recent-left { display: flex; flex-direction: column; }
.recent-cat { font-size: 26rpx; color: #ccc; }
.recent-desc { font-size: 22rpx; color: #666; margin-top: 4rpx; }
.recent-amount { font-size: 30rpx; color: #C9A84C; font-weight: bold; }

.page-container { background: var(--color-bg); min-height: 100vh; padding-bottom: 120rpx; }
.points-hero { margin: 24rpx; padding: 40rpx; background: linear-gradient(135deg, #1a1200 0%, #2a1e00 100%); border: 1rpx solid var(--color-gold); border-radius: 20rpx; display: flex; flex-direction: row; justify-content: space-between; align-items: center; }
.points-label { display: block; font-size: 24rpx; color: var(--color-text-muted); letter-spacing: 2rpx; }
.points-value { display: block; font-size: 72rpx; font-weight: 700; color: var(--color-gold); line-height: 1.1; }
.points-sub { display: block; font-size: 22rpx; color: var(--color-text-muted); margin-top: 8rpx; }
.points-icon { font-size: 80rpx; }
.tab-bar { display: flex; flex-direction: row; margin: 0 24rpx 24rpx; background: var(--color-surface); border-radius: 16rpx; padding: 6rpx; }
.tab-item { flex: 1; text-align: center; padding: 16rpx 0; font-size: 26rpx; color: var(--color-text-muted); border-radius: 12rpx; }
.tab-item.active { background: var(--color-gold); color: #000; font-weight: 600; }
.mall-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; padding: 0 24rpx; }
.mall-card { background: var(--color-surface); border: 1rpx solid var(--color-border); border-radius: 20rpx; padding: 28rpx 20rpx 20rpx; position: relative; overflow: hidden; }
.mall-card-icon { font-size: 56rpx; text-align: center; margin-bottom: 12rpx; }
.mall-card-name { display: block; font-size: 28rpx; font-weight: 600; color: var(--color-text); text-align: center; margin-bottom: 10rpx; }
.mall-card-desc { display: block; font-size: 22rpx; color: var(--color-text-muted); text-align: center; line-height: 1.5; margin-bottom: 16rpx; min-height: 66rpx; }
.mall-card-footer { display: flex; flex-direction: row; justify-content: space-between; align-items: center; }
.mall-card-cost { display: flex; flex-direction: row; align-items: center; gap: 4rpx; }
.cost-icon { font-size: 22rpx; }
.cost-value { font-size: 28rpx; font-weight: 700; color: var(--color-gold); }
.cost-unit { font-size: 20rpx; color: var(--color-text-muted); }
.mall-card-stock { font-size: 20rpx; color: var(--color-text-muted); }
.mall-card-stock.low { color: var(--color-alert); }
.insufficient-mask { position: absolute; inset: 0; background: rgba(0,0,0,0.6); border-radius: 20rpx; display: flex; align-items: center; justify-content: center; }
.insufficient-text { font-size: 26rpx; color: var(--color-text-muted); }
.ledger-list, .exchange-list { padding: 0 24rpx; }
.ledger-item { display: flex; flex-direction: row; justify-content: space-between; align-items: center; padding: 28rpx 0; border-bottom: 1rpx solid var(--color-border); }
.ledger-reason { display: block; font-size: 28rpx; color: var(--color-text); margin-bottom: 8rpx; }
.ledger-time { display: block; font-size: 22rpx; color: var(--color-text-muted); }
.ledger-delta { font-size: 32rpx; font-weight: 700; }
.ledger-delta.positive { color: var(--color-success); }
.ledger-delta.negative { color: var(--color-alert); }
.exchange-item { display: flex; flex-direction: row; align-items: center; padding: 24rpx 0; border-bottom: 1rpx solid var(--color-border); gap: 20rpx; }
.exchange-icon { font-size: 48rpx; }
.exchange-info { flex: 1; }
.exchange-name { display: block; font-size: 28rpx; color: var(--color-text); margin-bottom: 6rpx; }
.exchange-time { display: block; font-size: 22rpx; color: var(--color-text-muted); }
.exchange-right { text-align: right; }
.exchange-cost { display: block; font-size: 28rpx; font-weight: 700; color: var(--color-alert); margin-bottom: 8rpx; }
.exchange-status { display: inline-block; padding: 4rpx 16rpx; border-radius: 20rpx; font-size: 20rpx; }
.exchange-status.pending { background: rgba(245,158,11,0.2); color: #F59E0B; }
.exchange-status.completed { background: rgba(0,255,136,0.15); color: var(--color-success); }
.exchange-status.cancelled { background: rgba(107,114,128,0.2); color: var(--color-text-muted); }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: var(--color-text-muted); }
.modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); display: flex; align-items: flex-end; z-index: 100; }
.item-modal { background: var(--color-surface); border-radius: 32rpx 32rpx 0 0; padding: 40rpx 32rpx 60rpx; width: 100%; }
.item-modal-header { display: flex; flex-direction: row; align-items: center; gap: 20rpx; margin-bottom: 24rpx; }
.item-modal-icon { font-size: 56rpx; }
.item-modal-title { font-size: 36rpx; font-weight: 700; color: var(--color-text); }
.item-modal-desc { display: block; font-size: 26rpx; color: var(--color-text-muted); line-height: 1.6; margin-bottom: 32rpx; }
.item-modal-info { background: var(--color-bg); border-radius: 16rpx; padding: 24rpx; margin-bottom: 32rpx; }
.info-row { display: flex; flex-direction: row; justify-content: space-between; padding: 12rpx 0; border-bottom: 1rpx solid var(--color-border); }
.info-row:last-child { border-bottom: none; }
.info-label { font-size: 26rpx; color: var(--color-text-muted); }
.info-value { font-size: 26rpx; color: var(--color-text); font-weight: 600; }
.info-value.gold { color: var(--color-gold); }
.info-value.green { color: var(--color-success); }
.info-value.red { color: var(--color-alert); }
.item-modal-actions { display: flex; flex-direction: row; gap: 20rpx; }
.btn-cancel { flex: 1; background: var(--color-bg); color: var(--color-text-muted); border: 1rpx solid var(--color-border); border-radius: 16rpx; height: 88rpx; font-size: 28rpx; }
.btn-exchange { flex: 2; background: var(--color-gold); color: #000; border: none; border-radius: 16rpx; height: 88rpx; font-size: 28rpx; font-weight: 700; }
.btn-exchange.disabled { background: var(--color-border); color: var(--color-text-muted); }

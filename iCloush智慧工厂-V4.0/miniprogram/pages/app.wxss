/* CSS 变量 */
page {
  --color-bg: #0A0A0A;
  --color-bg-card: #141414;
  --color-bg-elevated: #1A1A1A;
  --color-bg-input: #1E1E1E;

  --color-gold: #C9A84C;
  --color-gold-dim: rgba(201, 168, 76, 0.15);
  --color-gold-border: rgba(201, 168, 76, 0.3);

  --color-success: #00FF88;
  --color-success-dim: rgba(0, 255, 136, 0.12);
  --color-danger: #EF4444;
  --color-danger-dim: rgba(239, 68, 68, 0.12);
  --color-warning: #F59E0B;
  --color-warning-dim: rgba(245, 158, 11, 0.12);
  --color-info: #3B82F6;
  --color-info-dim: rgba(59, 130, 246, 0.12);

  --color-text-primary: #F0F0F0;
  --color-text-secondary: #888888;
  --color-text-muted: #555555;
  --color-text-gold: #C9A84C;

  --color-border: #1E1E1E;
  --color-border-light: #2A2A2A;

  --radius-card: 16rpx;
  --radius-btn: 12rpx;
  --radius-tag: 40rpx;

  --font-mono: 'Courier New', Courier, monospace;

  background-color: var(--color-bg);
  color: var(--color-text-primary);
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

/* 通用卡片 */
.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  border: 1rpx solid var(--color-border);
  padding: 24rpx;
}

.card-elevated {
  background: var(--color-bg-elevated);
  border-radius: var(--radius-card);
  border: 1rpx solid var(--color-border-light);
  padding: 24rpx;
}

/* 通用标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-tag);
  font-size: 20rpx;
  font-weight: 500;
}

.tag-success { background: var(--color-success-dim); color: var(--color-success); }
.tag-danger  { background: var(--color-danger-dim);  color: var(--color-danger);  }
.tag-warning { background: var(--color-warning-dim); color: var(--color-warning); }
.tag-info    { background: var(--color-info-dim);    color: var(--color-info);    }
.tag-gold    { background: var(--color-gold-dim);    color: var(--color-gold);    }
.tag-muted   { background: #1E1E1E;                  color: var(--color-text-secondary); }

/* 通用按钮 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-btn);
  font-size: 28rpx;
  font-weight: 500;
  padding: 20rpx 32rpx;
  border: none;
  line-height: 1;
}

.btn::after { border: none; }

.btn-primary {
  background: var(--color-gold);
  color: #000000;
}

.btn-outline {
  background: transparent;
  border: 1rpx solid var(--color-gold-border);
  color: var(--color-gold);
}

.btn-ghost {
  background: var(--color-bg-elevated);
  color: var(--color-text-primary);
}

.btn-danger {
  background: var(--color-danger-dim);
  color: var(--color-danger);
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background: var(--color-border);
  margin: 24rpx 0;
}

/* 等宽数字字体 */
.mono {
  font-family: var(--font-mono);
}

/* 文字截断 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 状态指示灯 */
.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  display: inline-block;
  margin-right: 8rpx;
}
.dot-success { background: var(--color-success); box-shadow: 0 0 6rpx var(--color-success); }
.dot-danger  { background: var(--color-danger);  box-shadow: 0 0 6rpx var(--color-danger);  }
.dot-warning { background: var(--color-warning); box-shadow: 0 0 6rpx var(--color-warning); }
.dot-muted   { background: var(--color-text-muted); }

/* 报警呼吸动画 */
@keyframes alertPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.alert-pulse {
  animation: alertPulse 1.5s ease-in-out infinite;
}

/* 页面容器 */
.page-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 120rpx;
}

/* 页面标题栏 */
.page-header {
  padding: 24rpx 32rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.page-subtitle {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  color: var(--color-text-muted);
  font-size: 26rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
  color: var(--color-text-secondary);
  font-size: 26rpx;
}

/* 底部安全区 */
.safe-bottom {
  height: env(safe-area-inset-bottom);
}

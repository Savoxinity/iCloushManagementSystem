/* ============================================
   个人排班日历样式 — 工业暗黑科技风
   ============================================ */

.page-container {
  background: #0A0A0A;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* 页面头部 */
.page-header {
  padding: 24rpx 32rpx 12rpx;
}

.page-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #F0F0F0;
}

/* 月份切换 */
.month-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 32rpx;
}

.month-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #141414;
  border-radius: 50%;
  border: 1rpx solid #2A2A2A;
}

.month-arrow {
  font-size: 36rpx;
  color: #C9A84C;
  font-weight: 700;
}

.month-center {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.month-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #F0F0F0;
  font-family: 'Courier New', monospace;
}

.today-hint {
  font-size: 18rpx;
  color: #666;
  margin-top: 2rpx;
}

/* 月度统计 */
.month-stats-row {
  display: flex;
  padding: 16rpx 24rpx;
  gap: 12rpx;
}

.month-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  background: #141414;
  border-radius: 12rpx;
  border: 1rpx solid #1E1E1E;
}

.stat-num {
  font-size: 32rpx;
  font-weight: 700;
  font-family: 'Courier New', monospace;
}

.stat-num.green { color: #00FF88; }
.stat-num.gold { color: #C9A84C; }
.stat-num.blue { color: #3B82F6; font-size: 20rpx; }

.stat-txt {
  font-size: 20rpx;
  color: #666;
  margin-top: 4rpx;
}

/* 日历网格 */
.calendar-wrap {
  margin: 12rpx 24rpx;
  background: #111111;
  border-radius: 16rpx;
  border: 1rpx solid #1E1E1E;
  padding: 16rpx;
}

.week-header {
  display: flex;
}

.week-cell {
  flex: 1;
  text-align: center;
  padding: 8rpx 0;
}

.week-text {
  font-size: 22rpx;
  color: #666;
  font-weight: 600;
}

.week-text.weekend {
  color: #C9A84C;
}

.days-grid {
  display: flex;
  flex-wrap: wrap;
}

.day-cell {
  width: 14.2857%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0;
  position: relative;
  min-height: 72rpx;
}

.day-cell.empty {
  visibility: hidden;
}

.day-num {
  font-size: 26rpx;
  color: #CCCCCC;
  font-family: 'Courier New', monospace;
}

.day-cell.today .day-num {
  color: #C9A84C;
  font-weight: 700;
}

.day-cell.selected {
  background: rgba(201, 168, 76, 0.12);
  border-radius: 12rpx;
}

.day-cell.selected .day-num {
  color: #C9A84C;
  font-weight: 700;
}

/* 排班标记点 */
.schedule-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  margin-top: 4rpx;
}

/* 今天标记 */
.today-tag {
  position: absolute;
  top: 2rpx;
  right: 8rpx;
  font-size: 16rpx;
  color: #C9A84C;
  font-weight: 700;
}

/* 选中日期详情 */
.detail-section {
  margin: 20rpx 24rpx 0;
}

.detail-header {
  margin-bottom: 12rpx;
}

.detail-date {
  font-size: 26rpx;
  font-weight: 700;
  color: #F0F0F0;
}

.detail-card {
  display: flex;
  background: #141414;
  border-radius: 16rpx;
  border: 1rpx solid #1E1E1E;
  overflow: hidden;
}

.detail-zone-bar {
  width: 8rpx;
  flex-shrink: 0;
}

.detail-info {
  flex: 1;
  padding: 20rpx 24rpx;
}

.detail-zone-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #F0F0F0;
  display: block;
  margin-bottom: 10rpx;
}

.detail-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.shift-tag {
  border: 1rpx solid;
  border-radius: 16rpx;
  padding: 4rpx 16rpx;
}

.shift-tag text {
  font-size: 22rpx;
  font-weight: 600;
}

.detail-time {
  font-size: 22rpx;
  color: #888;
  font-family: 'Courier New', monospace;
}

/* 空状态 */
.detail-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  background: #141414;
  border-radius: 16rpx;
  border: 1rpx solid #1E1E1E;
}

.empty-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.empty-text {
  font-size: 24rpx;
  color: #555;
}

/* 图例 */
.legend-row {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-top: 24rpx;
  padding: 0 24rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.legend-dot.empty-dot {
  background: transparent;
  border: 1rpx solid #555;
}

.legend-text {
  font-size: 20rpx;
  color: #888;
}

.safe-bottom {
  height: 60rpx;
}

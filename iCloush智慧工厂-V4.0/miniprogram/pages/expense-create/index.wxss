.page-container { padding: 24rpx; background: #0a0a0a; min-height: 100vh; }
.voucher-tabs { display: flex; margin-bottom: 32rpx; border-radius: 12rpx; overflow: hidden; border: 1rpx solid rgba(201,168,76,0.3); }
.tab { flex: 1; text-align: center; padding: 20rpx 0; font-size: 28rpx; color: #888; background: rgba(255,255,255,0.03); }
.tab.active { background: #C9A84C; color: #000; font-weight: bold; }
.upload-area { position: relative; width: 100%; min-height: 360rpx; border: 2rpx dashed rgba(201,168,76,0.4); border-radius: 12rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; margin-bottom: 32rpx; overflow: hidden; }
.preview-img { width: 100%; height: 360rpx; }
.upload-hint { font-size: 24rpx; color: #C9A84C; padding: 16rpx 0; text-align: center; }
.upload-placeholder { display: flex; flex-direction: column; align-items: center; padding: 60rpx 0; }
.upload-icon { font-size: 64rpx; margin-bottom: 16rpx; }
.upload-text { font-size: 28rpx; color: #888; }
.upload-loading { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.6); display: flex; align-items: center; justify-content: center; color: #C9A84C; font-size: 28rpx; }
.form-section { background: rgba(255,255,255,0.05); border-radius: 12rpx; padding: 8rpx 24rpx; margin-bottom: 24rpx; }
.form-item { display: flex; align-items: center; justify-content: space-between; padding: 28rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.08); }
.form-item:last-child { border-bottom: none; }
.label { font-size: 28rpx; color: #aaa; flex-shrink: 0; }
.input { flex: 1; font-size: 30rpx; color: #C9A84C; text-align: right; }
.points-hint { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 24rpx; background: rgba(255,255,255,0.03); border-radius: 12rpx; margin-bottom: 48rpx; }
.hint-label { font-size: 26rpx; color: #666; }
.hint-value { font-size: 28rpx; font-weight: bold; }
.hint-value.positive { color: #10B981; }
.hint-value.negative { color: #EF4444; }
.btn-area { padding: 16rpx 0 48rpx; }
.btn-submit { width: 100%; height: 96rpx; line-height: 96rpx; background: #C9A84C; color: #000; font-size: 34rpx; font-weight: bold; border-radius: 12rpx; text-align: center; }
.btn-disabled { opacity: 0.4; }

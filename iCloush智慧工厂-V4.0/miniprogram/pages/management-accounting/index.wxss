.page-container { padding: 32rpx; background: #0a0a0a; min-height: 100vh; }
.page-title { font-size: 40rpx; color: #fff; font-weight: bold; margin-bottom: 40rpx; }
.menu-grid { display: flex; flex-wrap: wrap; gap: 24rpx; }
.menu-card { width: calc(50% - 12rpx); background: rgba(255,255,255,0.05); border-radius: 16rpx; padding: 32rpx 24rpx; display: flex; flex-direction: column; border: 1rpx solid rgba(201,168,76,0.15); }
.menu-icon { font-size: 48rpx; margin-bottom: 16rpx; }
.menu-title { font-size: 30rpx; color: #fff; font-weight: bold; margin-bottom: 8rpx; }
.menu-desc { font-size: 22rpx; color: #888; line-height: 1.4; }

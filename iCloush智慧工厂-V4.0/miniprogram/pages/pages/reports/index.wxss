.page-container { background: var(--color-bg); min-height: 100vh; padding-bottom: 120rpx; }
.dim-bar { display: flex; flex-direction: row; margin: 24rpx; background: var(--color-surface); border-radius: 16rpx; padding: 6rpx; }
.dim-item { flex: 1; text-align: center; padding: 16rpx 0; font-size: 26rpx; color: var(--color-text-muted); border-radius: 12rpx; }
.dim-item.active { background: var(--color-gold); color: #000; font-weight: 600; }
.kpi-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; padding: 0 24rpx 24rpx; }
.kpi-card { background: var(--color-surface); border: 1rpx solid var(--color-border); border-radius: 20rpx; padding: 28rpx 20rpx; display: flex; flex-direction: column; align-items: center; }
.kpi-icon { font-size: 40rpx; margin-bottom: 12rpx; }
.kpi-value { font-size: 48rpx; font-weight: 700; margin-bottom: 8rpx; }
.kpi-label { font-size: 22rpx; color: var(--color-text-muted); margin-bottom: 10rpx; }
.kpi-trend { font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 20rpx; }
.kpi-trend.up { background: rgba(0,255,136,0.15); color: var(--color-success); }
.kpi-trend.down { background: rgba(239,68,68,0.15); color: var(--color-alert); }
.kpi-trend.flat { background: rgba(107,114,128,0.15); color: var(--color-text-muted); }
.section { margin: 0 24rpx 32rpx; background: var(--color-surface); border-radius: 20rpx; padding: 28rpx; }
.section-title { display: block; font-size: 28rpx; font-weight: 600; color: var(--color-text); margin-bottom: 24rpx; }
.rank-item { display: flex; flex-direction: row; align-items: center; gap: 16rpx; padding: 16rpx 0; border-bottom: 1rpx solid var(--color-border); }
.rank-item:last-child { border-bottom: none; }
.rank-num { width: 48rpx; height: 48rpx; border-radius: 50%; background: var(--color-bg); display: flex; align-items: center; justify-content: center; font-size: 24rpx; color: var(--color-text-muted); }
.rank-num.top { background: var(--color-gold); color: #000; font-weight: 700; }
.rank-info { flex: 1; }
.rank-name { display: block; font-size: 26rpx; color: var(--color-text); margin-bottom: 8rpx; }
.rank-bar-bg { height: 8rpx; background: var(--color-border); border-radius: 4rpx; overflow: hidden; }
.rank-bar-fill { height: 100%; border-radius: 4rpx; }
.rank-value { font-size: 24rpx; color: var(--color-text-muted); white-space: nowrap; }
.staff-rank-item { display: flex; flex-direction: row; align-items: center; gap: 20rpx; padding: 16rpx 0; border-bottom: 1rpx solid var(--color-border); }
.staff-rank-item:last-child { border-bottom: none; }
.staff-avatar-wrap { position: relative; }
.staff-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.staff-initial { font-size: 28rpx; font-weight: 700; color: #fff; }
.medal { position: absolute; top: -8rpx; right: -8rpx; font-size: 24rpx; }
.staff-info { flex: 1; }
.staff-name { display: block; font-size: 28rpx; color: var(--color-text); margin-bottom: 4rpx; }
.staff-zone { display: block; font-size: 22rpx; color: var(--color-text-muted); }
.staff-stats { text-align: right; }
.staff-tasks { display: block; font-size: 24rpx; color: var(--color-text); }
.staff-points { display: block; font-size: 22rpx; color: var(--color-gold); }
.completion-ring-wrap { display: flex; flex-direction: row; align-items: center; gap: 40rpx; }
.completion-ring { width: 160rpx; height: 160rpx; border-radius: 50%; background: conic-gradient(var(--color-success) 0% var(--completionDeg, 75%), var(--color-border) var(--completionDeg, 75%) 100%); display: flex; flex-direction: column; align-items: center; justify-content: center; flex-shrink: 0; }
.completion-pct { font-size: 36rpx; font-weight: 700; color: var(--color-text); }
.completion-label { font-size: 20rpx; color: var(--color-text-muted); }
.completion-legend { flex: 1; }
.legend-item { display: flex; flex-direction: row; align-items: center; gap: 12rpx; margin-bottom: 16rpx; font-size: 24rpx; color: var(--color-text); }
.legend-dot { width: 16rpx; height: 16rpx; border-radius: 50%; }
.legend-dot.green { background: var(--color-success); }
.legend-dot.yellow { background: #F59E0B; }
.legend-dot.red { background: var(--color-alert); }
.legend-dot.gray { background: var(--color-text-muted); }

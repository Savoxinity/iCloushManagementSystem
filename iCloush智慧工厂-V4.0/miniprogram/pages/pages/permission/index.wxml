<!-- 权限管理页面 -->
<view class="page-container">
  <!-- 角色权限矩阵说明 -->
  <view class="section">
    <text class="section-title">角色权限矩阵</text>
    <view class="matrix-header">
      <view class="matrix-feature-col"><text class="matrix-th">功能模块</text></view>
      <view wx:for="{{roles}}" wx:key="key" class="matrix-role-col">
        <view class="role-badge" style="background:{{item.color}}20;border-color:{{item.color}}">
          <text style="color:{{item.color}}">{{item.label}}</text>
        </view>
      </view>
    </view>
    <view wx:for="{{permMatrix}}" wx:key="module" class="matrix-row">
      <view class="matrix-feature-col">
        <text class="feature-icon">{{item.icon}}</text>
        <text class="feature-name">{{item.name}}</text>
      </view>
      <view wx:for="{{roles}}" wx:key="key" wx:for-item="role" class="matrix-role-col">
        <text class="perm-icon">{{item.perms[role.key] ? '✅' : '—'}}</text>
      </view>
    </view>
  </view>

  <!-- 账号列表 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">账号管理</text>
      <view class="btn-add" bindtap="showAddModal"><text>+ 新建</text></view>
    </view>
    <!-- 角色筛选（数据在JS层合并，避免 WXML 展开运算符）-->
    <view class="role-filter">
      <view
        wx:for="{{roleFilters}}"
        wx:key="key"
        class="role-filter-item {{activeRoleFilter === item.key ? 'active' : ''}}"
        bindtap="filterByRole"
        data-role="{{item.key}}"
      >
        <text>{{item.label}}</text>
      </view>
    </view>
    <!-- 员工列表 -->
    <view wx:for="{{filteredStaff}}" wx:key="id" class="staff-item">
      <view class="staff-avatar" style="background:{{item.avatarColor}}">
        <text class="staff-initial">{{item.initial}}</text>
      </view>
      <view class="staff-info">
        <text class="staff-name">{{item.name}}</text>
        <text class="staff-zone">{{item.zone_name || '未分配工区'}}</text>
      </view>
      <view class="role-badge-sm" style="background:{{item.roleColor}}20;border-color:{{item.roleColor}}">
        <text style="color:{{item.roleColor}}">{{item.roleLabel}}</text>
      </view>
      <view class="staff-actions">
        <view class="action-btn" bindtap="editRole" data-staff="{{item}}"><text>调整</text></view>
      </view>
    </view>
  </view>
</view>

<!-- 调整角色弹窗 -->
<view wx:if="{{showEditModal}}" class="modal-overlay" bindtap="closeModal">
  <view class="edit-modal" catchtap="">
    <text class="modal-title">调整角色权限</text>
    <view class="modal-staff-info">
      <view class="staff-avatar" style="background:{{editTarget.avatarColor}}">
        <text class="staff-initial">{{editTarget.initial}}</text>
      </view>
      <view>
        <text class="modal-staff-name">{{editTarget.name}}</text>
        <text class="modal-staff-zone">{{editTarget.zone_name}}</text>
      </view>
    </view>
    <text class="modal-label">选择角色</text>
    <view class="role-options">
      <view
        wx:for="{{roles}}"
        wx:key="key"
        class="role-option {{selectedRole === item.key ? 'selected' : ''}}"
        bindtap="selectRole"
        data-role="{{item.key}}"
        style="border-color:{{selectedRole === item.key ? item.color : 'transparent'}}"
      >
        <text class="role-option-label" style="color:{{item.color}}">{{item.label}}</text>
        <text class="role-option-desc">{{item.desc}}</text>
      </view>
    </view>
    <view class="modal-actions">
      <button class="btn-cancel" bindtap="closeModal">取消</button>
      <button class="btn-confirm" bindtap="confirmEditRole">确认修改</button>
    </view>
  </view>
</view>

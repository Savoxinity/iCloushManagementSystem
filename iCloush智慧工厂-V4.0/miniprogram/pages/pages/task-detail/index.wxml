<!-- 任务详情页：水印相机 + 执行记录 + AI审核 -->
<view class="page-container">
  <view class="task-hero">
    <view class="hero-tags">
      <view class="type-tag type-{{task.task_type}}"><text>{{task.typeLabel}}</text></view>
      <view class="priority-tag priority-{{task.priority}}"><text>P{{task.priority}} {{task.priorityLabel}}</text></view>
    </view>
    <text class="hero-title">{{task.title}}</text>
    <view class="hero-meta">
      <view class="meta-row"><text class="meta-icon">📍</text><text class="meta-text">{{task.zone_name}}</text></view>
      <view class="meta-row" wx:if="{{task.deadline}}"><text class="meta-icon">⏰</text><text class="meta-text deadline">{{task.deadlineText}}</text></view>
      <view class="meta-row"><text class="meta-icon">🏆</text><text class="meta-text gold">+{{task.points_reward}} 积分</text></view>
    </view>
    <view class="status-badge status-{{task.status}}">
      <view class="status-dot" /><text>{{task.statusLabel}}</text>
    </view>
  </view>
  <view wx:if="{{task.task_type === 'routine'}}" class="progress-section">
    <view class="progress-header">
      <text class="progress-label">今日进度</text>
      <text class="progress-value">{{task.progress}} / {{task.target}} {{task.unit}}</text>
    </view>
    <view class="progress-track"><view class="progress-fill" style="width:{{task.progressPct}}%;" /></view>
    <text class="progress-pct">{{task.progressPct}}%</text>
  </view>
  <view wx:if="{{task.description}}" class="desc-section">
    <text class="section-title">任务说明</text>
    <text class="desc-text">{{task.description}}</text>
  </view>
  <view wx:if="{{canExecute}}" class="action-section">
    <text class="section-title">执行操作</text>
    <view wx:if="{{task.task_type === 'routine'}}" class="count-input-row">
      <view class="count-btn" bindtap="decreaseCount"><text>－</text></view>
      <view class="count-display">
        <text class="count-value">{{inputCount}}</text>
        <text class="count-unit">{{task.unit}}</text>
      </view>
      <view class="count-btn" bindtap="increaseCount"><text>＋</text></view>
      <button class="count-submit-btn" bindtap="submitCount">提交计件</button>
    </view>
    <view class="photo-section">
      <view class="photo-header">
        <text class="photo-label">拍照取证</text>
        <text wx:if="{{task.requires_photo}}" class="photo-required">必填</text>
        <text wx:else class="photo-optional">选填</text>
      </view>
      <view class="photo-grid">
        <view wx:for="{{uploadedPhotos}}" wx:key="id" class="photo-thumb" bindtap="previewPhoto" data-url="{{item.url}}">
          <image class="thumb-img" src="{{item.url}}" mode="aspectFill" />
          <view class="thumb-remove" catchtap="removePhoto" data-id="{{item.id}}"><text>×</text></view>
          <view wx:if="{{item.ai_status}}" class="ai-overlay ai-{{item.ai_status}}">
            <text class="ai-overlay-text">{{item.ai_status === 'pass' ? '✓' : item.ai_status === 'fail' ? '✗' : '…'}}</text>
          </view>
        </view>
        <view wx:if="{{uploadedPhotos.length < 6}}" class="photo-add-btn" bindtap="takePhoto">
          <text class="add-icon">📷</text><text class="add-text">拍照</text>
        </view>
      </view>
    </view>
    <button class="submit-task-btn {{submitting ? 'loading' : ''}}" bindtap="submitTask" disabled="{{submitting}}">
      <text wx:if="{{!submitting}}">提交任务 → 待审核</text>
      <text wx:else>提交中...</text>
    </button>
  </view>
  <view wx:if="{{task.status >= 3}}" class="ai-review-section">
    <text class="section-title">AI 审核结果</text>
    <view class="ai-review-card ai-card-{{aiReview.result}}">
      <view class="ai-review-header">
        <text class="ai-result-icon">{{aiReview.result === 'pass' ? '✅' : aiReview.result === 'fail' ? '❌' : '⏳'}}</text>
        <text class="ai-result-label">{{aiReview.resultLabel}}</text>
        <text class="ai-review-time">{{aiReview.reviewedAt}}</text>
      </view>
      <text class="ai-review-comment">{{aiReview.comment}}</text>
      <view wx:if="{{aiReview.result === 'fail' && canManualReview}}" class="manual-review-row">
        <button class="manual-btn approve" bindtap="manualApprove">人工通过</button>
        <button class="manual-btn reject" bindtap="manualReject">确认驳回</button>
      </view>
    </view>
  </view>
  <view class="timeline-section">
    <text class="section-title">执行记录</text>
    <view class="timeline">
      <view wx:for="{{executionRecords}}" wx:key="id" class="timeline-item">
        <view class="timeline-dot dot-{{item.action_type}}" />
        <view class="timeline-content">
          <view class="timeline-header">
            <text class="timeline-action">{{item.actionLabel}}</text>
            <text class="timeline-time">{{item.createdAtStr}}</text>
          </view>
          <text wx:if="{{item.note}}" class="timeline-note">{{item.note}}</text>
          <view wx:if="{{item.photos && item.photos.length > 0}}" class="timeline-photos">
            <image wx:for="{{item.photos}}" wx:key="*this" wx:for-item="photo" class="timeline-photo" src="{{photo}}" mode="aspectFill" bindtap="previewPhoto" data-url="{{photo}}" />
          </view>
          <view wx:if="{{item.count_delta}}" class="timeline-count"><text>+{{item.count_delta}} {{task.unit}}</text></view>
        </view>
      </view>
      <view wx:if="{{executionRecords.length === 0}}" class="timeline-empty"><text>暂无执行记录</text></view>
    </view>
  </view>
  <view class="safe-bottom" />
</view>

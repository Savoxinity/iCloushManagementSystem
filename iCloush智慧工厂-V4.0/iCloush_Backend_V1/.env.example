# ═══════════════════════════════════════════════════
# iCloush 智慧工厂后端 — 环境变量配置
# 复制为 .env 并按需修改
# ═══════════════════════════════════════════════════

# ── 当前环境 ──────────────────────────────────────────
APP_ENV=development

# ── 数据库 ──────────────────────────────────────────
# Docker 容器内：host 必须是 docker-compose 中的服务名 "postgres"
# 本机直连（非 Docker）：将 postgres 改为 localhost
DATABASE_URL=postgresql+asyncpg://icloush:icloush_dev_2026@postgres:5432/icloush_db

# ── JWT 认证 ────────────────────────────────────────
JWT_SECRET=icloush_super_secret_key_2026
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=168

# ── 微信小程序 ──────────────────────────────────────
WX_APPID=your_wx_appid
WX_APPSECRET=your_wx_appsecret

# ── 微信云托管（可选，部署时自动注入） ──────────────
# WX_CLOUD_RUN=true
# 当部署在微信云托管时，请求头会自动携带 x-wx-openid

# ── 腾讯云 COS（图片直传，可选，不配则返回模拟凭证） ──
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-shanghai
COS_BUCKET=

# ── Redis（WebSocket/缓存） ─────────────────────────
# Docker 容器内：host 必须是 "redis"
# 本机直连：将 redis 改为 localhost
REDIS_URL=redis://redis:6379/0

# ── 服务配置 ────────────────────────────────────────
APP_PORT=80
APP_HOST=0.0.0.0

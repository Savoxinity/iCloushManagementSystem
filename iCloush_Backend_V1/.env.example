# ═══════════════════════════════════════════════════
# iCloush 智慧工厂 — 环境变量模板
# Phase 5.1: 微信云托管部署配置
# ═══════════════════════════════════════════════════
# 复制此文件为 .env 并填入实际值
# 微信云托管部署时，在控制台「高级设置 → 环境变量」中逐一配置

# ── 当前环境 ──
APP_ENV=production

# ── 数据库（PostgreSQL） ──
# 格式: postgresql+asyncpg://用户名:密码@主机:端口/数据库名
# 推荐使用腾讯云 RDS PostgreSQL 或 Supabase
# Docker 本地开发: postgresql+asyncpg://icloush:icloush_dev_2026@postgres:5432/icloush_db
DATABASE_URL=postgresql+asyncpg://icloush:your_password@your-pg-host:5432/icloush_db

# ── JWT 认证 ──
JWT_SECRET=your_jwt_secret_key_change_this
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=168

# ── 微信小程序 ──
WX_APPID=your_wx_appid
WX_APPSECRET=your_wx_appsecret

# ── 微信云托管（可选，部署时自动注入） ──
# WX_CLOUD_RUN=true

# ── 腾讯云 API 密钥（OCR + COS 共用） ──
TENCENT_SECRET_ID=your_tencent_secret_id
TENCENT_SECRET_KEY=your_tencent_secret_key
TENCENT_OCR_REGION=ap-shanghai

# ── 腾讯云 COS 对象存储 ──
# 如果 COS 密钥与上面的腾讯云 API 密钥相同，可以不填以下两项
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-shanghai
COS_BUCKET=icloush-your-appid

# ── Redis（可选，不填则自动降级为内存存储） ──
# REDIS_URL=redis://your-redis-host:6379/0

# ── 服务配置 ──
APP_PORT=80
APP_HOST=0.0.0.0

# ── 文件访问基础 URL ──
# 微信云托管：填写云托管分配的公网域名
# 本地开发：填写局域网 IP（如 http://192.168.1.4:8000）
# 注意：配置 COS 后，新上传的文件直接返回 COS URL，此项仅影响本地降级存储
BASE_URL=https://your-cloudrun-domain.sh.run.tcloudbase.com
